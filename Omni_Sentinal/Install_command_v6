"""
Example plugin: auto_tagger
Automatically adds tags to scans based on what was discovered.

Tags added:
    web          — if HTTP/S ports found
    ssh          — if port 22 found
    smb          — if ports 139/445 found
    ad           — if Kerberos/LDAP ports found (88, 389, 636)
    database     — if DB ports found (1433, 3306, 5432, 27017)
    critical-cve — if any CRITICAL CVEs found

Enable with: PATCH /plugins/auto_tagger  {"enabled": true}
"""
import json
import logging
from contextlib import closing

PLUGIN_NAME        = "Auto Tagger"
PLUGIN_VERSION     = "1.0.0"
PLUGIN_DESCRIPTION = "Automatically tags scans based on open ports and CVE severity."
PLUGIN_AUTHOR      = "Omni Sentinal Team"
PLUGIN_HOOKS       = ["on_scan_complete"]

logger = logging.getLogger(__name__)

_PORT_TAGS = {
    frozenset({"80", "443", "8080", "8443", "8000", "8888"}): "web",
    frozenset({"22"}):                                         "ssh",
    frozenset({"139", "445"}):                                 "smb",
    frozenset({"88", "389", "636", "3268", "3269"}):           "ad",
    frozenset({"1433", "3306", "5432", "27017", "5984"}):      "database",
    frozenset({"21"}):                                         "ftp",
    frozenset({"3389"}):                                       "rdp",
    frozenset({"161", "162"}):                                 "snmp",
}


def on_scan_complete(context: dict) -> dict:
    scan_id  = context.get("scan_id", "")
    services = context.get("services", {})
    cves     = context.get("cves", {})
    if not scan_id:
        return {"skipped": "no scan_id in context"}

    open_ports = set(services.keys())
    new_tags: set = set()

    for port_set, tag in _PORT_TAGS.items():
        if open_ports & port_set:
            new_tags.add(tag)

    has_critical = any(
        cve.get("severity") == "CRITICAL"
        for port_cves in cves.values()
        for cve in port_cves
    )
    if has_critical:
        new_tags.add("critical-cve")

    if not new_tags:
        return {"tags_added": []}

    try:
        from core.db_engine import get_db
        with closing(get_db()) as db:
            row = db.execute("SELECT tags FROM scans WHERE id=?", (scan_id,)).fetchone()
            if not row:
                return {"skipped": "scan not found"}
            existing = set(json.loads(row["tags"] or "[]"))
            merged   = sorted(existing | new_tags)
            db.execute("UPDATE scans SET tags=? WHERE id=?", (json.dumps(merged), scan_id))
            db.commit()
        logger.info(f"[auto_tagger] Added tags {new_tags} to scan {scan_id[:8]}")
        return {"tags_added": list(new_tags), "total_tags": merged}
    except Exception as exc:
        logger.error(f"[auto_tagger] Failed to update tags: {exc}")
        return {"error": str(exc)}
