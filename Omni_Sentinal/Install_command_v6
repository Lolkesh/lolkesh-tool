import logging
import re
from typing import Optional

logger = logging.getLogger(__name__)

WEAK_PATTERNS = [
    (re.compile(r"^(.)\1+$"), "Repeated character"),
    (re.compile(r"^(012|123|234|345|456|567|678|789|890|987|876|765|654|543|432|321|210)", re.IGNORECASE), "Sequential digits"),
    (re.compile(r"^(abc|bcd|cde|def|efg|fgh|ghi|hij|ijk|jkl|klm|lmn|mno|nop|opq|pqr|qrs|rst|stu|tuv|uvw|vwx|wxy|xyz)", re.IGNORECASE), "Sequential letters"),
    (re.compile(r"^(password|passwd|pass|pwd)", re.IGNORECASE), "Contains 'password'"),
    (re.compile(r"^(admin|administrator|root|user|guest|test|default|login)", re.IGNORECASE), "Common username-as-password"),
    (re.compile(r"^(qwerty|azerty|dvorak|qazwsx|zxcvbn)", re.IGNORECASE), "Keyboard walk"),
    (re.compile(r"^(letmein|welcome|monkey|dragon|sunshine|master|iloveyou|trustno1|football|shadow|baseball|baseball|batman|superman)", re.IGNORECASE), "Common password"),
    (re.compile(r"^\d{4}$"), "4-digit PIN"),
    (re.compile(r"^\d{6}$"), "6-digit PIN"),
    (re.compile(r"^.{1,5}$"), "Too short (< 6 chars)"),
    (re.compile(r"^[a-z]+$"), "Lowercase only"),
    (re.compile(r"^[A-Z]+$"), "Uppercase only"),
    (re.compile(r"^\d+$"), "Digits only"),
    (re.compile(r"^[a-zA-Z]+\d{1,4}$"), "Word + short number suffix"),
    (re.compile(r"(19|20)\d{2}$"), "Ends with year"),
    (re.compile(r"!+$"), "Only special char is trailing '!'"),
]

COMMON_PASSWORDS_SET = {
    "password", "123456", "12345678", "password1", "qwerty",
    "abc123", "monkey", "letmein", "dragon", "111111",
    "baseball", "iloveyou", "trustno1", "sunshine", "master",
    "welcome", "shadow", "superman", "batman", "admin",
    "root", "pass", "guest", "default", "changeme",
    "passw0rd", "p@ssword", "p@ssw0rd", "admin123", "root123",
}

ENTROPY_CLASSES = [
    (re.compile(r"[a-z]"), "lowercase"),
    (re.compile(r"[A-Z]"), "uppercase"),
    (re.compile(r"\d"), "digits"),
    (re.compile(r"[^a-zA-Z0-9]"), "special"),
]


def _check_entropy(password: str) -> dict:
    classes = [name for pattern, name in ENTROPY_CLASSES if pattern.search(password)]
    length = len(password)
    score = len(classes) + min(length // 4, 4)
    if length < 8:
        score = max(0, score - 2)
    return {
        "length": length,
        "classes": classes,
        "class_count": len(classes),
        "score": score,
        "strength": "WEAK" if score < 3 else "MEDIUM" if score < 5 else "STRONG",
    }


def analyze_password(password: str) -> dict:
    weaknesses = []

    if password.lower() in COMMON_PASSWORDS_SET:
        weaknesses.append("In common password list")

    for pattern, label in WEAK_PATTERNS:
        if pattern.search(password):
            weaknesses.append(label)

    entropy = _check_entropy(password)

    return {
        "password": password[:4] + "***" if len(password) > 4 else "***",
        "length": len(password),
        "weaknesses": list(set(weaknesses)),
        "is_weak": len(weaknesses) > 0 or entropy["strength"] == "WEAK",
        "entropy": entropy,
        "risk": "CRITICAL" if password.lower() in COMMON_PASSWORDS_SET else
                "HIGH" if len(weaknesses) > 2 else
                "MEDIUM" if weaknesses else "LOW",
    }


def analyze_credential_list(credentials: list) -> dict:
    results = []
    weak_count = 0
    for cred in credentials:
        pw = cred.get("password", "")
        if not pw:
            continue
        analysis = analyze_password(pw)
        analysis["username"] = cred.get("username", "")
        analysis["host"] = cred.get("host", "")
        if analysis["is_weak"]:
            weak_count += 1
        results.append(analysis)

    return {
        "total_analyzed": len(results),
        "weak_count": weak_count,
        "weak_percentage": round(weak_count / len(results) * 100, 1) if results else 0,
        "results": results,
    }
