"""
Reverse shell listener manager.
Manages multiple netcat/ncat listeners, logs connections and output.
"""
import logging
import os
import queue
import shutil
import subprocess
import threading
import time
from datetime import datetime, timezone
from pathlib import Path
from typing import Optional

logger = logging.getLogger(__name__)

LOOT_DIR = os.path.expanduser("~/omni-sentinal/output/shells")
_listeners: dict = {}   # port -> {proc, thread, log_path, connected, output_queue}
_lock = threading.Lock()


def _log_path(port: int) -> str:
    Path(LOOT_DIR).mkdir(parents=True, exist_ok=True)
    ts = datetime.now(timezone.utc).strftime("%Y%m%d_%H%M%S")
    return str(Path(LOOT_DIR) / f"shell_{port}_{ts}.log")


def start_listener(port: int, host: str = "0.0.0.0") -> dict:
    with _lock:
        if port in _listeners:
            return {"status": "already_running", "port": port}

    tool = shutil.which("ncat") or shutil.which("nc")
    if not tool:
        return {"status": "error", "message": "ncat/nc not found"}

    log_path = _log_path(port)
    out_q: queue.Queue = queue.Queue(maxsize=500)

    cmd = [tool, "-lnvp", str(port)] if "ncat" not in tool else \
          [tool, "-lnvp", str(port), "--keep-open"]

    try:
        proc = subprocess.Popen(
            cmd, stdin=subprocess.PIPE, stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT, text=True,
        )
    except Exception as exc:
        return {"status": "error", "message": str(exc)}

    def _reader():
        with open(log_path, "w") as logf:
            logf.write(f"[{datetime.now(timezone.utc).isoformat()}] Listener started on {host}:{port}\n")
            while proc.poll() is None:
                try:
                    line = proc.stdout.readline()
                    if line:
                        ts = datetime.now(timezone.utc).strftime("%H:%M:%S")
                        entry = f"[{ts}] {line.rstrip()}"
                        logf.write(entry + "\n")
                        logf.flush()
                        try:
                            out_q.put_nowait(entry)
                        except queue.Full:
                            out_q.get_nowait()
                            out_q.put_nowait(entry)
                except Exception:
                    break

    t = threading.Thread(target=_reader, daemon=True, name=f"listener-{port}")
    t.start()

    with _lock:
        _listeners[port] = {
            "proc": proc, "thread": t, "log_path": log_path,
            "host": host, "port": port, "output_queue": out_q,
            "started_at": datetime.now(timezone.utc).isoformat(),
        }

    logger.info(f"Listener started on {host}:{port} (pid={proc.pid})")
    return {"status": "started", "port": port, "pid": proc.pid, "log_path": log_path}


def stop_listener(port: int) -> dict:
    with _lock:
        info = _listeners.pop(port, None)
    if not info:
        return {"status": "not_found", "port": port}
    try:
        info["proc"].terminate()
        info["proc"].wait(timeout=5)
    except Exception:
        try:
            info["proc"].kill()
        except Exception:
            pass
    logger.info(f"Listener stopped on port {port}")
    return {"status": "stopped", "port": port, "log_path": info["log_path"]}


def send_to_shell(port: int, command: str) -> dict:
    with _lock:
        info = _listeners.get(port)
    if not info:
        return {"status": "not_found"}
    try:
        info["proc"].stdin.write(command + "\n")
        info["proc"].stdin.flush()
        time.sleep(0.3)
        lines = []
        while True:
            try:
                lines.append(info["output_queue"].get_nowait())
            except queue.Empty:
                break
        return {"status": "sent", "output": lines}
    except Exception as exc:
        return {"status": "error", "message": str(exc)}


def get_listener_output(port: int, max_lines: int = 100) -> list:
    with _lock:
        info = _listeners.get(port)
    if not info:
        return []
    lines = []
    while len(lines) < max_lines:
        try:
            lines.append(info["output_queue"].get_nowait())
        except queue.Empty:
            break
    return lines


def list_listeners() -> list:
    with _lock:
        return [
            {"port": p, "host": v["host"], "pid": v["proc"].pid,
             "alive": v["proc"].poll() is None,
             "started_at": v["started_at"], "log_path": v["log_path"]}
            for p, v in _listeners.items()
        ]


def read_shell_log(port: int) -> str:
    with _lock:
        info = _listeners.get(port)
    if not info:
        return ""
    try:
        return Path(info["log_path"]).read_text(errors="replace")
    except Exception:
        return ""
