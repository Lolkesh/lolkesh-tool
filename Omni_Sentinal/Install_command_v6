        os_notes = ["Run LinPEAS after access", "Check sudo -l",
                    "Find SUID binaries", "Check capabilities (getcap -r /)"]

    # Quick box type classification
    box_type = "linux"
    if any(kw in os_lower for kw in ("windows", "iis", "microsoft")):
        box_type = "windows"
    if {"88", "389", "636"} & open_set:
        box_type = "ad"

    return {
        "box_type": box_type,
        "os_hint": os_hint,
        "open_ports": list(open_set),
        "matched_profiles": matched,
        "os_notes": os_notes,
        "quick_wins": [s for m in matched[:2] for s in m["steps"][:3]],
