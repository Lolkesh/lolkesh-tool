@app.post("/scans/{scan_id}/cancel")
def cancel_scan(scan_id: str, user: dict = Depends(verify_token)) -> dict:
    with closing(get_db()) as db:
        row = db.execute("SELECT status, task_id FROM scans WHERE id=?", (scan_id,)).fetchone()
    if not row:
        raise HTTPException(status_code=404, detail="Scan not found")
    if row["status"] not in ("PENDING", "RUNNING"):
        raise HTTPException(status_code=409, detail=f"Scan is already {row['status']} — cannot cancel")
    task_id = row["task_id"]
    if task_id:
        try:
            from celery.result import AsyncResult
            AsyncResult(task_id).revoke(terminate=True, signal="SIGTERM")
        except Exception as exc:
            logger.warning(f"Celery revoke failed for task {task_id}: {exc}")
    with closing(get_db()) as db:
        db.execute("UPDATE scans SET status='CANCELLED', progress=0 WHERE id=?", (scan_id,))
        db.commit()
    log_event(scan_id, "scan_cancelled", f"Cancelled by {user.get('username', 'unknown')}", actor=user.get("username", "unknown"))
    return {"scan_id": scan_id, "status": "CANCELLED"}


