import logging
import time
from collections import defaultdict
from threading import Lock

from fastapi import HTTPException, Request

logger = logging.getLogger(__name__)
_store: dict = defaultdict(list)
_lock = Lock()


def _clean(key: str, window: int) -> None:
    now = time.monotonic()
    _store[key] = [t for t in _store[key] if now - t < window]


def check_rate_limit(
    request: Request,
    max_requests: int = 10,
    window_seconds: int = 60,
    key_prefix: str = "rl",
) -> None:
    ip = request.client.host if request.client else "unknown"
    key = f"{key_prefix}:{ip}"
    with _lock:
        _clean(key, window_seconds)
        _store[key].append(time.monotonic())
        count = len(_store[key])
    if count > max_requests:
        logger.warning(f"Rate limit exceeded: {key} ({count} reqs/{window_seconds}s)")
        raise HTTPException(
            status_code=429,
            detail=f"Too many requests. Limit: {max_requests}/{window_seconds}s",
            headers={"Retry-After": str(window_seconds)},
        )


def auth_rate_limit(request: Request) -> None:
    """Strict rate limit for auth — 5 attempts/min per IP."""
    check_rate_limit(request, max_requests=5, window_seconds=60, key_prefix="auth")
