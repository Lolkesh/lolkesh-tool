import json
import logging
from contextlib import closing
from typing import Optional

from core.db_engine import get_db

logger = logging.getLogger(__name__)

SEVERITY_WEIGHTS = {"CRITICAL": 4, "HIGH": 3, "MEDIUM": 2, "LOW": 1, "UNKNOWN": 0}


def build_heatmap(target: Optional[str] = None, limit: int = 50) -> dict:
    try:
        with closing(get_db()) as db:
            if target:
                rows = db.execute(
                    "SELECT id, target, created_at, data FROM scans WHERE target=? AND status='COMPLETE' ORDER BY created_at ASC LIMIT ?",
                    (target, limit),
                ).fetchall()
            else:
                rows = db.execute(
                    "SELECT id, target, created_at, data FROM scans WHERE status='COMPLETE' ORDER BY created_at DESC LIMIT ?",
                    (limit,),
                ).fetchall()

        points = []
        targets_seen = set()

        for row in rows:
            data = json.loads(row["data"] or "{}")
            cves_by_port = data.get("cves", {})
            targets_seen.add(row["target"])

            counts = {"CRITICAL": 0, "HIGH": 0, "MEDIUM": 0, "LOW": 0, "total": 0}
            score_total = 0

            for port_cves in cves_by_port.values():
                for cve in port_cves:
                    sev = cve.get("severity", "UNKNOWN")
                    counts[sev] = counts.get(sev, 0) + 1
                    counts["total"] += 1
                    score_total += SEVERITY_WEIGHTS.get(sev, 0)

            points.append({
                "scan_id": row["id"],
                "target": row["target"],
                "date": row["created_at"],
                "counts": counts,
                "risk_score": score_total,
                "severity_breakdown": {k: v for k, v in counts.items() if k != "total"},
            })

        # Per-target trend lines
        by_target = {}
        for p in points:
            by_target.setdefault(p["target"], []).append(p)

        return {
            "points": points,
            "by_target": by_target,
            "targets": list(targets_seen),
            "summary": {
                "total_scans": len(points),
                "max_risk_score": max((p["risk_score"] for p in points), default=0),
                "avg_risk_score": round(sum(p["risk_score"] for p in points) / len(points), 2) if points else 0,
            },
        }
    except Exception as exc:
        logger.error(f"Heatmap build failed: {exc}")
        return {"points": [], "by_target": {}, "targets": [], "summary": {}}
