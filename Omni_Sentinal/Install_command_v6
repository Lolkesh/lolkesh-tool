import logging
import os
from typing import Optional

logger = logging.getLogger(__name__)

MSF_HOST = os.getenv("MSF_HOST", "127.0.0.1")
MSF_PORT = int(os.getenv("MSF_PORT", "55553"))
MSF_PASS = os.getenv("MSF_PASS", "msf123")
MSF_SSL  = os.getenv("MSF_SSL", "false").lower() == "true"

try:
    from pymetasploit3.msfrpc import MsfRpcClient
    MSF_AVAILABLE = True
except ImportError:
    MSF_AVAILABLE = False


def _client() -> Optional[object]:
    if not MSF_AVAILABLE:
        return None
    try:
        return MsfRpcClient(MSF_PASS, server=MSF_HOST, port=MSF_PORT, ssl=MSF_SSL)
    except Exception as exc:
        logger.warning(f"MSF RPC connect failed: {exc}")
        return None


def msf_status() -> dict:
    if not MSF_AVAILABLE:
        return {"available": False, "message": "pymetasploit3 not installed"}
    c = _client()
    if not c:
        return {"available": False, "connected": False,
                "message": f"Cannot connect to msfrpcd at {MSF_HOST}:{MSF_PORT}. "
                           f"Start with: msfconsole -x 'load msgrpc Pass={MSF_PASS} SSL=false'"}
    try:
        version = c.core.version()
        return {"available": True, "connected": True,
                "version": version.get("version", "unknown"),
                "ruby": version.get("ruby", ""), "api": version.get("api", "")}
    except Exception as exc:
        return {"available": True, "connected": False, "error": str(exc)}


def list_modules(module_type: str = "exploit", search: str = "") -> list:
    c = _client()
    if not c:
        return []
    try:
        mods = getattr(c.modules, module_type)
        if search:
            return [m for m in mods if search.lower() in m.lower()][:100]
        return list(mods)[:200]
    except Exception as exc:
        logger.error(f"list_modules failed: {exc}")
        return []


def get_module_info(module_type: str, module_name: str) -> dict:
    c = _client()
    if not c:
        return {}
    try:
        mod = c.modules.use(module_type, module_name)
        return {
            "name": module_name,
            "type": module_type,
            "description": getattr(mod, "description", ""),
            "author": getattr(mod, "author", []),
            "rank": getattr(mod, "rank", ""),
            "references": getattr(mod, "references", []),
            "options": {k: {"required": v.get("required"), "default": v.get("default"),
                            "desc": v.get("desc")} for k, v in (getattr(mod, "options", None) or {}).items()},
        }
    except Exception as exc:
        logger.error(f"get_module_info failed: {exc}")
        return {"error": str(exc)}


def run_module(module_type: str, module_name: str, options: dict,
               payload: str = "", payload_options: dict = None) -> dict:
    c = _client()
    if not c:
        return {"error": "MSF not connected"}
    try:
        mod = c.modules.use(module_type, module_name)
        for k, v in options.items():
            mod[k] = v
        if payload and module_type == "exploit":
            p = c.modules.use("payload", payload)
            if payload_options:
                for k, v in payload_options.items():
                    p[k] = v
            job_id = mod.execute(payload=p)
        else:
            job_id = mod.execute()
        return {"status": "launched", "job_id": str(job_id),
                "module": module_name, "options": options}
    except Exception as exc:
        logger.error(f"run_module failed: {exc}")
        return {"error": str(exc)}


def list_sessions() -> dict:
    c = _client()
