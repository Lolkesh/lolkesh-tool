def suggest_methodology(open_ports: list, os_hint: str = "") -> dict:
    open_set = {str(p) for p in open_ports}
    os_lower = (os_hint or "").lower()
    matched = []

    for key, profile in PORT_PROFILES.items():
        if profile["ports"] & open_set:
            matched.append({
                "profile": key,
                "methodology": profile["methodology"],
                "matched_ports": list(profile["ports"] & open_set),
                "steps": profile["steps"],
                "priority": len(profile["ports"] & open_set),
            })

    matched.sort(key=lambda x: -x["priority"])

    # OS-specific hints
    os_notes = []
    if any(kw in os_lower for kw in ("windows", "iis", "microsoft")):
        os_notes = ["Run WinPEAS after access", "Check AlwaysInstallElevated",
                    "Check unquoted service paths", "Check SeImpersonatePrivilege (JuicyPotato/PrintSpoofer)"]
