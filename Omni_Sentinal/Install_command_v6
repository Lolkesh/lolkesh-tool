def lookup_gtfobin(binary: str) -> dict:
    binary = binary.lower().strip()
    local = GTFOBINS_LOCAL.get(binary)
    if local:
        return {
            "binary": binary,
            "found": True,
            "techniques": local,
            "url": GTFOBINS_URL.format(binary=binary),
            "source": "local_cache",
        }
    return {
        "binary": binary,
        "found": False,
        "techniques": {},
        "url": GTFOBINS_URL.format(binary=binary),
        "source": "not_in_cache",
    }


def find_suid_binaries(scan_id: str) -> list:
    """Try to find SUID binaries via SSH or assume local context."""
    suid_cmd = "find / -perm -4000 -type f 2>/dev/null"
    try:
        result = subprocess.run(
            ["bash", "-c", suid_cmd],
            capture_output=True, text=True, timeout=10, check=False,
        )
        lines = [l.strip() for l in result.stdout.splitlines() if l.strip()]
        results = []
        for path in lines:
            binary = path.split("/")[-1]
            gtfo = lookup_gtfobin(binary)
            if gtfo["found"]:
                results.append({"path": path, "binary": binary, "gtfo": gtfo})
        return results
    except Exception as exc:
        logger.debug(f"SUID search failed: {exc}")
        return []


def suggest_gtfobins(binaries: list[str]) -> list:
    results = []
    for binary in binaries:
        info = lookup_gtfobin(binary)
        if info["found"]:
            results.append(info)
    return results
