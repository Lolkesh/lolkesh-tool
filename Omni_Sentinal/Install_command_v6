def osint_ip(ip: str) -> dict:
    results = {
        "target": ip,
        "timestamp": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
    }
    results["shodan_internetdb"] = shodan_internetdb(ip)
    results["bgp"] = bgpview_ip(ip)
    results["greynoise"] = greynoise_ip(ip)
    results["ipinfo"] = ipinfo(ip)
    results["reverse_ip"] = reverse_ip(ip)
    results["reverse_dns"] = _resolve_ptr(ip)
    if ABUSEIPDB_KEY:
        results["abuseipdb"] = abuseipdb_check(ip)
    if SHODAN_KEY:
        results["shodan_full"] = shodan_full(ip)
    if VT_KEY:
        results["virustotal"] = virustotal_ip(ip)
    results["google_dorks"] = [
        f'"{ip}"',
        f'ip:{ip} site:shodan.io',
        f'"{ip}" site:pastebin.com',
        f'"{ip}" site:github.com',
    ]
    return results


def _resolve_ptr(ip: str) -> str:
    try:
        return socket.gethostbyaddr(ip)[0]
    except (socket.herror, socket.gaierror):
        return ""


# ── Email OSINT ───────────────────────────────────────────────────────────────

def osint_email(email: str) -> dict:
    results = {
        "target": email,
        "timestamp": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
    }
    if HIBP_KEY:
        results["hibp"] = hibp_email(email)
    else:
        results["hibp"] = {"available": False, "reason": "OSINT_HIBP_KEY not set"}

    domain = email.split("@")[-1] if "@" in email else ""
    if domain:
        results["domain_intel"] = {
            "mx_records": dns_records(domain).get("records", {}).get("MX", []),
            "ipinfo": ipinfo(_resolve(domain)[0]) if _resolve(domain) else {},
        }
    results["search_dorks"] = [
        f'"{email}"',
        f'"{email}" site:pastebin.com',
        f'"{email}" site:github.com',
        f'"{email}" password OR hash',
        f'"{email}" site:linkedin.com',
    ]
    return results


# ── Scan-Attached OSINT ───────────────────────────────────────────────────────

def osint_from_scan(scan_row: dict, company_name: str = "") -> dict:
    """Run the appropriate OSINT based on whether the scan target is an IP or domain."""
    target = scan_row.get("target", "")
    if _is_ip(target):
        return {"type": "ip", "result": osint_ip(target)}
    else:
        return {"type": "domain", "result": osint_domain(target, company_name=company_name)}
