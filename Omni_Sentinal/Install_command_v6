import json
import logging
from contextlib import closing
from typing import Optional

from core.db_engine import get_db

logger = logging.getLogger(__name__)


def build_report_text(scan_id: str) -> Optional[str]:
    try:
        with closing(get_db()) as db:
            row = db.execute("SELECT * FROM scans WHERE id=?", (scan_id,)).fetchone()
            if not row:
                return None
            notes = db.execute(
                "SELECT content, author, created_at FROM notes WHERE scan_id=? ORDER BY created_at",
                (scan_id,),
            ).fetchall()
            timeline = db.execute(
                "SELECT event, detail, actor, created_at FROM timeline WHERE scan_id=? ORDER BY created_at",
                (scan_id,),
            ).fetchall()

        data = json.loads(row["data"] or "{}")
        services = data.get("services", {})
        cves = data.get("cves", {})

        lines = [
            "# Omni Sentinal Scan Report",
            "",
            f"**Scan ID:** {row['id']}",
            f"**Target:** {row['target']}",
            f"**Status:** {row['status']}",
            f"**OS Hint:** {row['os_hint'] or 'Unknown'}",
            f"**Created:** {row['created_at']}",
