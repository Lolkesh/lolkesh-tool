"""GraphQL introspection + basic fuzzer."""
import logging
from typing import Optional

import requests

logger = logging.getLogger(__name__)
requests.packages.urllib3.disable_warnings()

SESSION = requests.Session()
SESSION.headers.update({"User-Agent": "Mozilla/5.0", "Content-Type": "application/json"})

INTROSPECTION_QUERY = """
{
  __schema {
    queryType { name }
    mutationType { name }
    subscriptionType { name }
    types {
      name
      kind
      fields { name args { name type { name kind } } }
      inputFields { name type { name kind } }
    }
  }
}
"""

BATCH_INTROSPECTION = '[{"query":"{__schema{queryType{name}}}"},{"query":"{__schema{types{name}}}"}]'

SQLI_PAYLOADS  = ["'", "\"", "1 OR 1=1", "' OR '1'='1"]
SSTI_PAYLOADS  = ["{{7*7}}", "${7*7}", "<%= 7*7 %>"]
NOSQLI_PAYLOADS= ['{"$gt":""}', '{"$ne":null}', '{"$regex":".*"}']


def _post(url: str, data, timeout: int = 10):
    try:
        r = SESSION.post(url, json=data, timeout=timeout, verify=False)
        return r
    except Exception:
        return None


def detect_graphql(url: str) -> dict:
    """Try common GraphQL endpoints."""
    paths = ["/graphql", "/api/graphql", "/v1/graphql", "/graph", "/gql",
             "/graphiql", "/playground", "/api/v1/graphql", "/query"]
    found = []
    for path in paths:
        full = url.rstrip("/") + path
        r = _post(full, {"query": "{__typename}"})
        if r and r.status_code in (200, 400) and ("data" in (r.text or "") or "errors" in (r.text or "")):
            found.append({"url": full, "status": r.status_code})
    return {"found": found, "detected": len(found) > 0}


def introspect(url: str) -> dict:
    r = _post(url, {"query": INTROSPECTION_QUERY})
    if not r:
        return {"error": "No response", "introspection_enabled": False}
    if r.status_code != 200:
        return {"error": f"HTTP {r.status_code}", "introspection_enabled": False}
    try:
        data = r.json()
    except Exception:
        return {"error": "Non-JSON response", "introspection_enabled": False}

    if "errors" in data and not data.get("data"):
        return {"introspection_enabled": False, "errors": data["errors"]}

    schema = data.get("data", {}).get("__schema", {})
    types  = schema.get("types", [])
    user_types = [t for t in types if t["name"] and not t["name"].startswith("__")]
    queries    = next((t for t in user_types if t["name"] == schema.get("queryType", {}).get("name")), {})
    mutations  = next((t for t in user_types if t["name"] == (schema.get("mutationType") or {}).get("name")), {})
    interesting = [t["name"] for t in user_types if any(
        kw in t["name"].lower() for kw in ("user", "admin", "pass", "token", "auth", "secret", "key", "flag")
    )]

    return {
        "introspection_enabled": True,
        "query_fields":    [f["name"] for f in (queries.get("fields") or [])],
        "mutation_fields": [f["name"] for f in (mutations.get("fields") or [])],
        "type_count":      len(user_types),
        "interesting_types": interesting,
        "raw_schema":      schema,
    }


def fuzz_fields(url: str, field: str, arg: str) -> list:
    """Fuzz a specific field+arg with injection payloads."""
    findings = []
    for payload in SQLI_PAYLOADS + SSTI_PAYLOADS + NOSQLI_PAYLOADS:
        query = f'{{ {field}({arg}: "{payload}") }}'
        r = _post(url, {"query": query})
        if r and ("error" in r.text.lower() or "syntax" in r.text.lower() or "exception" in r.text.lower()):
            findings.append({"field": field, "arg": arg, "payload": payload,
                              "response_snippet": r.text[:300]})
    return findings


def scan_graphql(url: str) -> dict:
    schema = introspect(url)
    if not schema.get("introspection_enabled"):
        return {"url": url, "introspection_enabled": False, "schema": schema}

    fuzz_results = []
    for field in (schema.get("query_fields", []) + schema.get("mutation_fields", []))[:10]:
        results = fuzz_fields(url, field, "id")
        fuzz_results.extend(results)

    return {
        "url": url,
        "introspection_enabled": True,
        "schema": schema,
        "fuzz_findings": fuzz_results,
        "vulnerable": len(fuzz_results) > 0,
        "issues": (["Introspection enabled — schema exposed"] if schema["introspection_enabled"] else []) +
                  ([f"{len(fuzz_results)} injection finding(s)"] if fuzz_results else []),
    }
