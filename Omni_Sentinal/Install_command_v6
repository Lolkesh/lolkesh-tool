cat > "$BASE/plugins/cve_lookup.py" <<'PY'
import os
import time
from typing import Optional

import requests
from dotenv import load_dotenv

load_dotenv()
NVD_API = "https://services.nvd.nist.gov/rest/json/cves/2.0"
NVD_API_KEY = os.getenv("NVD_API_KEY", "")


def _nvd_fetch(keyword: str) -> list:
    if not keyword or not isinstance(keyword, str):
        return []
    headers = {"User-Agent": "omni-sentinel/21.3"}
    if NVD_API_KEY:
        headers["apiKey"] = NVD_API_KEY
    params = {"keywordSearch": keyword, "resultsPerPage": 5}
    delay = 0.6 if NVD_API_KEY else 6.5
    try:
        resp = requests.get(NVD_API, params=params, headers=headers, timeout=10)
        if resp.status_code == 429:
            time.sleep(delay)
            resp = requests.get(NVD_API, params=params, headers=headers, timeout=10)
        if resp.status_code != 200:
            return []
        data = resp.json()
        return data.get("vulnerabilities", []) if data else []
    except (requests.RequestException, ValueError):
        return []


def _parse_vuln(vuln: dict) -> dict:
    cve = vuln.get("cve", {})
    metrics = cve.get("metrics", {})
    score = "N/A"
    severity = "UNKNOWN"
    vector = ""
    for key in ("cvssMetricV31", "cvssMetricV30", "cvssMetricV2"):
        entries = metrics.get(key, [])
        if entries:
            data = entries[0].get("cvssData", {})
            score = data.get("baseScore", "N/A")
            severity = data.get("baseSeverity", entries[0].get("baseSeverity", "UNKNOWN"))
            vector = data.get("vectorString", "")
            break

    refs = []
    for reference in cve.get("references", [])[:6]:
        tags = reference.get("tags", [])
        if any(tag in tags for tag in ("Exploit", "Patch", "Vendor Advisory", "Third Party Advisory")):
            refs.append({"url": reference.get("url", ""), "tags": tags})

    weaknesses = cve.get("weaknesses", [])
    cwe = ""
    if weaknesses and weaknesses[0].get("description"):
        cwe = weaknesses[0]["description"][0].get("value", "")

    description = ""
    for entry in cve.get("descriptions", []):
        if entry.get("lang") == "en":
            description = entry.get("value", "")
            break

    return {
        "id": cve.get("id", "UNKNOWN"),
        "score": score,
        "severity": severity,
        "vector": vector,
        "cwe": cwe,
        "description": description[:300] if description else "",
        "references": refs,
    }


def search_cves(service: str, version: str) -> list:
    keyword = f"{service} {version}".strip()
    if not keyword:
        return []
    return [_parse_vuln(vuln) for vuln in _nvd_fetch(keyword)]
PY

cat > "$BASE/plugins/exploit_suggester.py" <<'PY'
import json
import re
import shutil
import subprocess
from typing import Optional

MSF_MODULES = {
    "CVE-2021-41773": "exploit/multi/http/apache_normalize_path_rce",
    "CVE-2017-0144": "exploit/windows/smb/ms17_010_eternalblue",
    "CVE-2021-44228": "exploit/multi/misc/log4shell_header_injection",
}

CWE_TECHNIQUES = {
    "CWE-78": {
        "technique": "OS Command Injection",
        "steps": [
            "Identify user-controlled input that reaches a shell command.",
            "Test separators such as ;, &&, and | with a harmless command first.",
            "Use a vetted PoC or Metasploit module only after confirming impact.",
        ],
    },
    "CWE-89": {
        "technique": "SQL Injection",
        "steps": [
            "Confirm injection with a safe boolean-based payload.",
            "Enumerate carefully with sqlmap or manual UNION/error-based techniques.",
            "Review database permissions before attempting file or command execution.",
        ],
    },
}

SEVERITY_STEPS = {
    "CRITICAL": [
        "Review vendor guidance and public PoCs before exploitation.",
        "Set up a listener or capture tooling before running any exploit.",
    ],
    "HIGH": [
        "Confirm the affected version and reachable attack surface.",
        "Search for a public PoC or searchsploit entry for {query}.",
    ],
    "MEDIUM": [
        "Verify the target is actually running the affected component.",
        "Search for supporting advisories or proof-of-concept material.",
    ],
    "LOW": [
        "Treat the issue as a chaining opportunity or hardening task.",
    ],
}


def _sanitize_query(query: str) -> str:
    """Prevent shell injection in queries."""
    return re.sub(r'[;&|`$()\\<>"\']', '', query)[:100]


def get_exploitation_steps(cve_id: str, cwe: str, severity: str, service: str, version: str) -> dict:
    query = _sanitize_query(f"{service} {version}".strip())
    msf_module = MSF_MODULES.get(cve_id, "")
    cwe_info = CWE_TECHNIQUES.get(cwe, {})
    technique = cwe_info.get("technique", "")
    steps = list(cwe_info.get("steps", []))
    if not steps:
        template_steps = SEVERITY_STEPS.get(severity, SEVERITY_STEPS["MEDIUM"])
        steps = [step.format(query=query, cve_id=cve_id) for step in template_steps]
    if msf_module:
        steps.insert(0, f"Metasploit module: {msf_module}")
    return {
        "msf_module": msf_module,
        "technique": technique,
        "steps": steps,
        "searchsploit_cmd": f"searchsploit {query}" if query else f"searchsploit {cve_id}",
        "poc_search": f"https://github.com/search?q={cve_id}+poc&type=repositories",
        "nvd_url": f"https://nvd.nist.gov/vuln/detail/{cve_id}",
    }


def searchsploit(query: str) -> list:
    if not shutil.which("searchsploit"):
        return []
    query = _sanitize_query(query)
    if not query:
        return []
    try:
        result = subprocess.run(
            ["searchsploit", "--json", query],
            capture_output=True,
            text=True,
            timeout=15,
            check=False,
        )
        data = json.loads(result.stdout or "{}")
    except (subprocess.SubprocessError, json.JSONDecodeError):
        return []

    exploits = data.get("RESULTS_EXPLOIT", [])[:5]
    return [
        {
            "title": exploit.get("Title", ""),
            "path": exploit.get("Path", ""),
            "type": exploit.get("Type", ""),
            "edb_id": exploit.get("EDB-ID", ""),
        }
        for exploit in exploits
    ]


def get_exploits(service: str, version: str, cves: list) -> dict:
    query = _sanitize_query(f"{service} {version}".strip())
    exploits = searchsploit(query) if query else []
    for cve in cves[:3]:
        exploits.extend(searchsploit(cve.get("id", "")))

    seen = set()
    unique = []
    for exploit in exploits:
        key = exploit.get("edb_id") or exploit.get("title")
        if key and key not in seen:
            seen.add(key)
            unique.append(exploit)

    exploitation = {
        cve["id"]: get_exploitation_steps(
            cve_id=cve["id"],
            cwe=cve.get("cwe", ""),
            severity=cve.get("severity", "MEDIUM"),
            service=service,
            version=version,
        )
        for cve in cves
    }
    return {"exploits": unique[:8], "exploitation": exploitation}
PY

cat > "$BASE/plugins/screenshotter.py" <<'PY'
import hashlib
import os
import shutil
import subprocess
from typing import Optional

SCREENSHOT_DIR = os.getenv("SCREENSHOT_DIR", os.path.expanduser("~/omni-sentinal/screenshots"))


def take_screenshot(scan_id: str, port: str, url: str) -> Optional[str]:
    binary = shutil.which("chromium-browser") or shutil.which("chromium")
    if not binary:
        return None
    os.makedirs(SCREENSHOT_DIR, exist_ok=True)
    digest = hashlib.md5(url.encode()).hexdigest()[:8]
    filename = f"{scan_id}_{port}_{digest}.png"
    outpath = os.path.join(SCREENSHOT_DIR, filename)
    try:
        subprocess.run(
            [
                binary,
                "--headless",
                "--no-sandbox",
                "--disable-gpu",
                "--disable-dev-shm-usage",
                f"--screenshot={outpath}",
                "--window-size=1280,800",
                "--virtual-time-budget=5000",
                url,
            ],
            capture_output=True,
