cat > "$BASE/plugins/smb_enum.py" <<'PY'
import logging
import re
import shutil
import subprocess
from typing import Optional

logger = logging.getLogger(__name__)

SMB_PORTS = {"139", "445"}


def _run(cmd: list, timeout: int = 60) -> str:
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout, check=False)
        return r.stdout + r.stderr
    except subprocess.TimeoutExpired:
        logger.warning(f"Command timed out: {' '.join(cmd)}")
        return ""
    except Exception as exc:
        logger.debug(f"Command failed: {exc}")
        return ""


def enum4linux_ng(target: str) -> dict:
    tool = shutil.which("enum4linux-ng") or shutil.which("enum4linux")
    if not tool:
        return {"available": False, "message": "enum4linux/enum4linux-ng not found"}

    flags = ["-A", "-oJ", "/tmp/e4l_out"] if "ng" in tool else ["-a"]
    output = _run([tool] + flags + [target], timeout=120)

    result = {
        "available": True,
        "tool": tool,
        "raw": output[:8000],
        "users": [],
        "groups": [],
        "shares": [],
        "os_info": "",
        "password_policy": "",
        "domain": "",
    }

    # Parse users
    for m in re.finditer(r"user:\[([^\]]+)\]", output, re.IGNORECASE):
        u = m.group(1).strip()
        if u and u not in result["users"]:
            result["users"].append(u)

    # Parse shares
    for m in re.finditer(r"Sharename\s+Type\s+Comment[\s\S]*?(?=\n\n|\Z)", output):
        lines = m.group(0).splitlines()
        for line in lines[2:]:
            parts = line.split()
            if parts:
                result["shares"].append({"name": parts[0], "type": parts[1] if len(parts) > 1 else "", "comment": " ".join(parts[2:]) if len(parts) > 2 else ""})

    # Parse OS
    os_m = re.search(r"OS:\s+(.+)", output, re.IGNORECASE)
    if os_m:
        result["os_info"] = os_m.group(1).strip()

    # Parse domain
    dom_m = re.search(r"Domain:\s+(.+)", output, re.IGNORECASE)
    if dom_m:
        result["domain"] = dom_m.group(1).strip()

    # Parse password policy
    pol_m = re.search(r"Password Complexity[\s\S]{0,500}?(?=\n\n|\Z)", output)
    if pol_m:
        result["password_policy"] = pol_m.group(0).strip()[:500]

    return result


def smb_null_session(target: str) -> dict:
    """Try null session enumeration via smbclient."""
    tool = shutil.which("smbclient")
    if not tool:
        return {"available": False}
    output = _run([tool, "-L", f"//{target}", "-N", "--no-pass"], timeout=15)
    shares = []
    for m in re.finditer(r"^\s+(\S+)\s+(Disk|IPC|Printer)\s*(.*)?$", output, re.MULTILINE):
        shares.append({"name": m.group(1), "type": m.group(2), "comment": m.group(3).strip()})
    return {"available": True, "null_session": bool(shares or "Sharename" in output), "shares": shares, "raw": output[:2000]}


def enumerate_smb(target: str) -> dict:
    e4l = enum4linux_ng(target)
    null = smb_null_session(target)
    return {
        "target": target,
        "enum4linux": e4l,
        "null_session": null,
        "users_found": e4l.get("users", []),
        "shares_found": e4l.get("shares", []) or null.get("shares", []),
    }
