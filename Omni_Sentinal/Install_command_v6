"""
Omni Sentinal — Plugin Loader
==============================
Dynamically discovers, loads, enables/disables, and hot-reloads plugins
from the ./plugins/ directory at runtime.

Plugin contract
---------------
A plugin is any .py file in plugins/ that optionally exports one or more
hook functions. The only requirement is that the file is valid Python.

Available hooks (all optional):
    on_startup(context)          Called once when the API server starts.
    on_shutdown(context)         Called once when the API server shuts down.
    on_scan_complete(context)    Called after every successful scan.
    on_scan_failed(context)      Called after a scan fails.
    on_cve_found(context)        Called for each discovered CVE.
    on_loot_added(context)       Called whenever loot is saved.

Each hook receives a single dict `context` with relevant keys and must
return either a dict (preferred) or None.

Plugin metadata (optional module-level constants):
    PLUGIN_NAME        = "human readable name"
    PLUGIN_VERSION     = "1.0.0"
    PLUGIN_DESCRIPTION = "what this plugin does"
    PLUGIN_AUTHOR      = "your name"
    PLUGIN_HOOKS       = ["on_scan_complete"]   # list of hooks implemented
"""

import importlib.util
import json
import logging
import os
import re
import tempfile
import threading
from pathlib import Path
from typing import Any, Dict, List, Optional

logger = logging.getLogger(__name__)

_ROOT_DIR    = Path(__file__).resolve().parent.parent
_PLUGINS_DIR = _ROOT_DIR / "plugins"
_CONFIG_PATH = _ROOT_DIR / "config.json"
_NAME_RE     = re.compile(r"^[a-zA-Z_][a-zA-Z0-9_]*$")

# Thread-safe plugin registry
_loaded_plugins: Dict[str, Any] = {}
_lock = threading.Lock()

# Hooks that plugins can implement
KNOWN_HOOKS = [
    "on_startup",
    "on_shutdown",
    "on_scan_complete",
    "on_scan_failed",
    "on_cve_found",
    "on_loot_added",
]


# ── Filesystem helpers ────────────────────────────────────────────────────────

def _atomic_write_text(path: Path, data: str) -> None:
    """Write data to path atomically using a temp file + rename."""
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile(
        "w", encoding="utf-8", dir=str(path.parent), delete=False, suffix=".tmp"
    ) as tmp:
        tmp.write(data)
        tmp.flush()
        os.fsync(tmp.fileno())
        temp_name = tmp.name
    os.replace(temp_name, path)


def ensure_layout() -> None:
    """Create plugins dir and config.json if they don't exist."""
    _PLUGINS_DIR.mkdir(parents=True, exist_ok=True)
    init = _PLUGINS_DIR / "__init__.py"
    if not init.exists():
        init.touch()
    if not _CONFIG_PATH.exists():
        _atomic_write_text(
            _CONFIG_PATH,
            json.dumps({"plugins": {}, "plugin_settings": {}}, indent=2) + "\n",
        )


# ── Config helpers ────────────────────────────────────────────────────────────

def _read_config() -> Dict[str, Any]:
    ensure_layout()
    try:
        raw = _CONFIG_PATH.read_text(encoding="utf-8")
        return json.loads(raw)
    except Exception as exc:
        logger.warning(f"config.json unreadable, using defaults: {exc}")
        return {"plugins": {}, "plugin_settings": {}}


def _write_config(data: Dict[str, Any]) -> None:
    _atomic_write_text(
        _CONFIG_PATH,
        json.dumps(data, indent=2, sort_keys=True) + "\n",
    )


def get_plugin_setting(plugin_name: str, key: str, default: Any = None) -> Any:
    """Read a per-plugin setting from config.json."""
    cfg = _read_config()
    return cfg.get("plugin_settings", {}).get(plugin_name, {}).get(key, default)


def set_plugin_setting(plugin_name: str, key: str, value: Any) -> None:
    """Write a per-plugin setting to config.json."""
    cfg = _read_config()
    cfg.setdefault("plugin_settings", {}).setdefault(plugin_name, {})[key] = value
    _write_config(cfg)


# ── Discovery ─────────────────────────────────────────────────────────────────

def discover_plugins() -> List[str]:
    """Return sorted list of plugin module names found on disk."""
    ensure_layout()
    return sorted(
        p.stem
        for p in _PLUGINS_DIR.glob("*.py")
        if p.name != "__init__.py" and _NAME_RE.match(p.stem)
    )


# ── Install / Remove ──────────────────────────────────────────────────────────

def install_plugin(module_name: str, source_code: str, enable: bool = True) -> str:
    """Write source_code to plugins/<module_name>.py and register it."""
    if not _NAME_RE.match(module_name):
        raise ValueError(
            f"Invalid plugin name '{module_name}'. "
            "Use only letters, digits, and underscores (must start with a letter/underscore)."
        )
    ensure_layout()
    plugin_path = _PLUGINS_DIR / f"{module_name}.py"
    _atomic_write_text(plugin_path, source_code.rstrip() + "\n")
    cfg = _read_config()
    cfg.setdefault("plugins", {})[module_name] = bool(enable)
    _write_config(cfg)
    logger.info(f"Installed plugin '{module_name}' (enabled={enable})")
    return str(plugin_path)


def uninstall_plugin(module_name: str, delete_file: bool = True) -> bool:
    """Remove a plugin from config and optionally delete its file."""
    cfg = _read_config()
    cfg.get("plugins", {}).pop(module_name, None)
    cfg.get("plugin_settings", {}).pop(module_name, None)
    _write_config(cfg)
    with _lock:
        _loaded_plugins.pop(module_name, None)
    if delete_file:
        plugin_path = _PLUGINS_DIR / f"{module_name}.py"
        try:
            plugin_path.unlink(missing_ok=True)
            logger.info(f"Deleted plugin file: {plugin_path}")
        except OSError as exc:
            logger.warning(f"Could not delete {plugin_path}: {exc}")
            return False
    return True


# ── Enable / Disable ──────────────────────────────────────────────────────────

def set_plugin_enabled(module_name: str, enabled: bool) -> Dict[str, Any]:
    """Toggle a plugin on or off in config.json."""
    cfg = _read_config()
    cfg.setdefault("plugins", {})[module_name] = bool(enabled)
    _write_config(cfg)
    if not enabled:
        with _lock:
            _loaded_plugins.pop(module_name, None)
        logger.info(f"Plugin '{module_name}' disabled and unloaded")
    return cfg


# ── Loading ───────────────────────────────────────────────────────────────────

def _load_one(name: str, plugin_file: Path) -> Optional[Any]:
    """Load a single plugin module from disk. Returns module or None on error."""
    try:
        spec = importlib.util.spec_from_file_location(f"plugins.{name}", plugin_file)
        if spec is None or spec.loader is None:
            raise RuntimeError("Could not create module spec")
        module = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(module)
        logger.info(
            f"Loaded plugin '{name}' "
            f"v{getattr(module, 'PLUGIN_VERSION', '?')} "
            f"— {getattr(module, 'PLUGIN_DESCRIPTION', 'no description')}"
        )
        return module
    except Exception as exc:
        logger.exception(f"Failed to load plugin '{name}': {exc}")
        return None


def load_enabled_plugins() -> Dict[str, Any]:
    """Load all enabled plugins from disk. Skip already-loaded ones."""
    cfg = _read_config()
    with _lock:
        for name, enabled in cfg.get("plugins", {}).items():
            if not enabled:
                _loaded_plugins.pop(name, None)
                continue
            if name in _loaded_plugins:
                continue
            plugin_file = _PLUGINS_DIR / f"{name}.py"
            if not plugin_file.exists():
                logger.warning(f"Plugin '{name}' enabled but file missing: {plugin_file}")
                continue
            module = _load_one(name, plugin_file)
            if module is not None:
                _loaded_plugins[name] = module
    return dict(_loaded_plugins)


def reload_plugin(module_name: str) -> bool:
    """Force-reload a plugin from disk even if already loaded."""
    plugin_file = _PLUGINS_DIR / f"{module_name}.py"
    if not plugin_file.exists():
        logger.warning(f"Cannot reload '{module_name}': file not found")
        return False
    with _lock:
        _loaded_plugins.pop(module_name, None)
        module = _load_one(module_name, plugin_file)
        if module is None:
            return False
        _loaded_plugins[module_name] = module
    return True


# ── Introspection ─────────────────────────────────────────────────────────────

def get_plugin_info(module_name: str) -> Optional[Dict[str, Any]]:
    """Return metadata + hook list for a single plugin."""
    plugin_file = _PLUGINS_DIR / f"{module_name}.py"
    if not plugin_file.exists():
        return None
    cfg = _read_config()
    enabled = bool(cfg.get("plugins", {}).get(module_name, False))
    with _lock:
        module = _loaded_plugins.get(module_name)
    hooks_implemented = []
    if module:
        hooks_implemented = [h for h in KNOWN_HOOKS if callable(getattr(module, h, None))]
    return {
        "name":        module_name,
        "enabled":     enabled,
        "installed":   True,
        "loaded":      module is not None,
        "file":        str(plugin_file),
        "size_bytes":  plugin_file.stat().st_size,
        "hooks":       hooks_implemented,
        "plugin_name":    getattr(module, "PLUGIN_NAME",    module_name) if module else module_name,
        "version":        getattr(module, "PLUGIN_VERSION", "unknown")   if module else "unknown",
        "description":    getattr(module, "PLUGIN_DESCRIPTION", "")      if module else "",
        "author":         getattr(module, "PLUGIN_AUTHOR",  "unknown")   if module else "unknown",
        "settings":    cfg.get("plugin_settings", {}).get(module_name, {}),
    }


def list_plugin_states() -> List[Dict[str, Any]]:
    """Return state for every discovered + configured plugin."""
    cfg = _read_config()
    enabled_map = cfg.get("plugins", {})
    discovered = set(discover_plugins()) | set(enabled_map.keys())
    rows = []
    for name in sorted(discovered):
        info = get_plugin_info(name) or {
            "name": name, "enabled": bool(enabled_map.get(name, False)),
            "installed": (_PLUGINS_DIR / f"{name}.py").exists(),
            "loaded": False, "hooks": [], "version": "unknown",
            "description": "", "author": "unknown", "settings": {},
        }
        rows.append(info)
    return rows


# ── Hook runner ───────────────────────────────────────────────────────────────

def run_hook(hook_name: str, **context: Any) -> List[Dict[str, Any]]:
    """
    Call hook_name on every loaded plugin that implements it.
    Each hook receives a single dict `context` and should return a dict or None.
    Results from all plugins are collected and returned as a list.
    """
    load_enabled_plugins()
    results: List[Dict[str, Any]] = []
    with _lock:
        snapshot = dict(_loaded_plugins)
    for name, module in snapshot.items():
        handler = getattr(module, hook_name, None)
        if not callable(handler):
            continue
        try:
            value = handler(context)
            results.append({"plugin": name, "ok": True, "result": value})
        except Exception as exc:
            logger.exception(f"Plugin '{name}' hook '{hook_name}' raised: {exc}")
            results.append({"plugin": name, "ok": False, "error": str(exc)})
    return results


# ── Startup hook ──────────────────────────────────────────────────────────────

def fire_startup() -> None:
    """Called once at API startup — runs on_startup hook on all plugins."""
    load_enabled_plugins()
    run_hook("on_startup")
PY

