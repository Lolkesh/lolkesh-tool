def wayback_cdx(domain: str) -> dict:
    r = _get("http://web.archive.org/cdx/search/cdx",
             params={"url": f"*.{domain}/*", "output": "json", "limit": 5,
                     "fl": "timestamp,original,statuscode,mimetype",
                     "collapse": "urlkey", "from": "2015"}, timeout=12)
    if not r or r.status_code != 200:
        return {"domain": domain, "snapshots": [], "count": 0}
    try:
        rows = r.json()
        if not rows or len(rows) < 2:
            return {"domain": domain, "snapshots": [], "count": 0}
        headers = rows[0]
        snapshots = []
        for row in rows[1:6]:
            entry = dict(zip(headers, row))
            snapshots.append({
                "timestamp": entry.get("timestamp", ""),
                "url": entry.get("original", ""),
                "status": entry.get("statuscode", ""),
                "type": entry.get("mimetype", ""),
            })
        return {"domain": domain, "snapshots": snapshots, "count": len(rows) - 1}
    except (ValueError, IndexError):
        return {"domain": domain, "snapshots": [], "count": 0}


