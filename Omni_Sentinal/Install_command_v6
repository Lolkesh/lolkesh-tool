import logging
import shutil
import subprocess
from typing import Optional

logger = logging.getLogger(__name__)

COMMON_COMMUNITIES = ["public", "private", "manager", "community", "snmp", "cisco", "admin", "default"]

OID_MAP = {
    "1.3.6.1.2.1.1.1.0": "sysDescr",
    "1.3.6.1.2.1.1.5.0": "sysName",
    "1.3.6.1.2.1.1.6.0": "sysLocation",
    "1.3.6.1.2.1.25.4.2.1.2": "hrSWRunName (processes)",
    "1.3.6.1.2.1.25.6.3.1.2": "hrSWInstalledName (installed software)",
    "1.3.6.1.2.1.6.13.1.3": "tcpConnLocalPort (TCP connections)",
    "1.3.6.1.4.1.77.1.2.25": "Windows user accounts",
    "1.3.6.1.2.1.4.20.1.1": "IP addresses",
    "1.3.6.1.2.1.2.2.1.2": "ifDescr (interfaces)",
}


def _snmpwalk(target: str, community: str, oid: str = ".", version: str = "2c", timeout: int = 10) -> str:
    tool = shutil.which("snmpwalk")
    if not tool:
        return ""
    try:
        r = subprocess.run(
            [tool, "-v", version, "-c", community, "-t", str(timeout), "-r", "1", target, oid],
            capture_output=True, text=True, timeout=timeout + 5, check=False,
        )
        return r.stdout
    except Exception:
        return ""


def _snmpbulkwalk(target: str, community: str, timeout: int = 20) -> str:
    tool = shutil.which("snmpbulkwalk")
    if not tool:
        return _snmpwalk(target, community)
    try:
        r = subprocess.run(
            [tool, "-v2c", "-c", community, "-t", str(timeout), "-r", "1", "-Cn0", "-Cr25", target],
            capture_output=True, text=True, timeout=timeout + 5, check=False,
        )
        return r.stdout
    except Exception:
        return _snmpwalk(target, community)


def brute_community(target: str, port: int = 161) -> Optional[str]:
    for community in COMMON_COMMUNITIES:
        out = _snmpwalk(target, community, "1.3.6.1.2.1.1.1.0", timeout=3)
        if out and "No Such" not in out and "Timeout" not in out and out.strip():
            logger.info(f"SNMP community found: {community} on {target}")
            return community
    return None


def walk_snmp(target: str, community: Optional[str] = None, port: int = 161) -> dict:
    if not community:
        community = brute_community(target, port)

    if not community:
        return {"target": target, "reachable": False, "community": None, "data": {}, "raw": ""}

    full_walk = _snmpbulkwalk(target, community)
    data = {}

    for oid, label in OID_MAP.items():
        out = _snmpwalk(target, community, oid, timeout=5)
        if out.strip():
            lines = [l.strip() for l in out.splitlines() if l.strip()]
            data[label] = lines[:30]

    return {
        "target": target,
        "reachable": True,
        "community": community,
        "data": data,
        "raw": full_walk[:5000],
        "line_count": len(full_walk.splitlines()),
    }
