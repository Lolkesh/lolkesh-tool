def _post(webhook_url: str, text: str, color: str = "#36a64f") -> bool:
    if not webhook_url:
        return False
    payload = {
        "attachments": [{
            "color": color,
            "text":  text,
            "mrkdwn_in": ["text"],
        }]
    }
    try:
        r = requests.post(webhook_url, json=payload, timeout=8)
        return r.status_code == 200
    except Exception as exc:
        logger.warning(f"[slack_notifier] POST failed: {exc}")
        return False


def on_scan_complete(context: dict) -> dict:
