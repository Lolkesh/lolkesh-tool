def _searchsploit(cve_id: str) -> list:
    if not shutil.which("searchsploit"):
        return []
    cve_id = re.sub(r"[^A-Za-z0-9\-]", "", cve_id)
    try:
        import json as _json
        r = subprocess.run(["searchsploit", "--json", cve_id],
                           capture_output=True, text=True, timeout=10, check=False)
        data = _json.loads(r.stdout or "{}")
        return [{"title": e.get("Title",""), "edb_id": e.get("EDB-ID",""),
                 "path": e.get("Path","")} for e in data.get("RESULTS_EXPLOIT",[])[:5]]
    except Exception:
        return []


def _poc_search_url(cve_id: str) -> str:
    return f"https://github.com/search?q={cve_id}+poc&type=repositories&sort=stars"


def chain_cves(cves: list) -> list:
    """
    For each CVE, look up MSF module, searchsploit, and PoC URL.
    Returns sorted by exploitability.
    """
    results = []
    for cve in cves:
        cve_id  = cve.get("id", "")
        severity= cve.get("severity", "UNKNOWN")
        score   = cve.get("score", "N/A")
        msf     = MSF_CVE_MAP.get(cve_id, {})
        sploit  = _searchsploit(cve_id)

        results.append({
            "cve_id":    cve_id,
            "severity":  severity,
            "score":     score,
            "name":      msf.get("name", cve.get("description", "")[:60]),
            "msf_module":msf.get("module", ""),
            "msf_ready": bool(msf.get("module")),
            "searchsploit": sploit,
            "poc_url":   _poc_search_url(cve_id),
            "nvd_url":   f"https://nvd.nist.gov/vuln/detail/{cve_id}",
            "exploitability": 3 if msf.get("module") else (2 if sploit else 1),
        })

    # Sort: MSF-ready first, then by CVSS score
    sev_order = {"CRITICAL": 4, "HIGH": 3, "MEDIUM": 2, "LOW": 1, "UNKNOWN": 0}
    results.sort(key=lambda x: (-x["exploitability"], -sev_order.get(x["severity"], 0)))
    return results
