                    "tunnel_peer": v.get("tunnel_peer"), "via_exploit": v.get("via_exploit"),
                    "info": v.get("info"), "arch": v.get("arch"), "platform": v.get("platform")}
                for k, v in (c.sessions.list or {}).items()}
    except Exception as exc:
        logger.error(f"list_sessions failed: {exc}")
