def _save_labels(labels: dict) -> None:
    Path(SCREENSHOT_DIR).mkdir(parents=True, exist_ok=True)
    Path(LABEL_FILE).write_text(json.dumps(labels, indent=2))


def take_labeled_screenshot(
    scan_id: str, port: str, url: str, service: str = "", version: str = ""
) -> Optional[dict]:
    binary = shutil.which("chromium-browser") or shutil.which("chromium")
    if not binary:
        return None

    os.makedirs(SCREENSHOT_DIR, exist_ok=True)
    ts = datetime.now(timezone.utc).strftime("%Y%m%d_%H%M%S")
    digest = hashlib.md5(url.encode()).hexdigest()[:8]
    filename = f"{scan_id}_{port}_{digest}_{ts}.png"
    outpath = os.path.join(SCREENSHOT_DIR, filename)

    try:
        subprocess.run(
            [
                binary, "--headless", "--no-sandbox", "--disable-gpu",
                "--disable-dev-shm-usage", f"--screenshot={outpath}",
                "--window-size=1280,800", "--virtual-time-budget=5000", url,
            ],
            capture_output=True, timeout=20, check=False,
        )
    except (subprocess.SubprocessError, OSError):
        return None

    if not os.path.exists(outpath):
        return None

    label = {
        "filename": filename,
        "scan_id": scan_id,
        "port": port,
        "url": url,
        "service": service,
        "version": version,
        "timestamp": ts,
        "timestamp_iso": datetime.now(timezone.utc).isoformat(),
        "title": f"Port {port} — {service} {version}".strip() + f" [{url}]",
    }

    labels = _load_labels()
    labels[filename] = label
    _save_labels(labels)

    return label


def get_labels(scan_id: Optional[str] = None) -> dict:
    labels = _load_labels()
    if scan_id:
        return {k: v for k, v in labels.items() if v.get("scan_id") == scan_id}
    return labels
PY

