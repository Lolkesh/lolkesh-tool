import { useCallback, useEffect, useRef, useState } from "react";

const LINE_COLOR = { error: "#ef4444", warn: "#f59e0b", info: "#38bdf8", ok: "#22c55e" };

export function LiveTerminal({ api, scanId, active }) {
  const [lines, setLines] = useState([]);
  const [connected, setConnected] = useState(false);
  const bottomRef = useRef(null);
  const pollRef = useRef(null);
  const lastIdRef = useRef(0);

  const poll = useCallback(async () => {
    if (!scanId || !active) return;
    try {
      const { data } = await api.get(`/scans/${scanId}/timeline`);
      const events = data.events || [];
      const newEvts = events.slice(lastIdRef.current);
      if (newEvts.length > 0) {
        lastIdRef.current = events.length;
        setLines(prev => [...prev, ...newEvts.map(e => ({
          text: `[${e.created_at}] [${e.actor}] ${e.event}${e.detail ? ": " + e.detail : ""}`,
          type: e.event.includes("fail") || e.event.includes("error") ? "error"
              : e.event.includes("warn") ? "warn"
              : e.event.includes("queue") || e.event.includes("start") ? "info" : "ok",
        }))]);
      }
      setConnected(true);
    } catch { setConnected(false); }
  }, [api, scanId, active]);

  useEffect(() => {
    if (!active) return;
    setLines([{ text: `[terminal] Monitoring scan ${scanId?.slice(0,8)}...`, type: "info" }]);
    lastIdRef.current = 0;
    poll();
    pollRef.current = setInterval(poll, 2500);
    return () => clearInterval(pollRef.current);
