// ── Settings ──────────────────────────────────────────────────────────────────
function Settings({ api, onBack }) {
  const [webhookUrl, setWebhookUrl] = useState("");
  const [msg, setMsg] = useState("");

  useEffect(() => {
    api.get("/settings/webhook").then(({ data }) => setWebhookUrl(data.webhook_url || "")).catch(() => {});
  }, [api]);

  const save = async () => {
    try {
      await api.put("/settings/webhook", { url: webhookUrl });
      setMsg("Saved");
      setTimeout(() => setMsg(""), 2000);
    } catch (e) { setMsg(`Error: ${e.message}`); }
  };

  return (
    <div>
      <button style={{ ...S.btn, background: "none", color: "#94a3b8", padding: "4px 0", marginBottom: 16 }} onClick={onBack}>← Back</button>
      <h2>Settings</h2>
      <h3 style={{ color: "#94a3b8", fontWeight: 500 }}>Webhook Notifications</h3>
      <p style={{ color: "#64748b", fontSize: 13 }}>POST alerts are sent to this URL on scan completion and critical CVE detection. Supports Slack, Discord, or any HTTP endpoint.</p>
      <div style={{ maxWidth: 500 }}>
        <input style={S.input} placeholder="https://hooks.slack.com/..." value={webhookUrl} onChange={e => setWebhookUrl(e.target.value)} />
        <button style={S.btn} onClick={save}>Save</button>
        {msg && <p style={{ color: msg.startsWith("Error") ? "#ef4444" : "#22c55e", marginTop: 8 }}>{msg}</p>}
      </div>
    </div>
  );
}

function PluginManagement({ api }) {
  const [plugins, setPlugins] = useState([]);
  const [loading, setLoading] = useState(true);
  const [message, setMessage] = useState("");
  const [installName, setInstallName] = useState("");
  const [installCode, setInstallCode] = useState("");
  const [installEnabled, setInstallEnabled] = useState(true);

  const flash = (text) => {
    setMessage(text);
    setTimeout(() => setMessage(""), 2500);
  };

  const loadPlugins = useCallback(async () => {
    try {
      setLoading(true);
      const { data } = await api.get("/plugins");
      setPlugins(data.plugins || []);
    } catch (e) {
      flash(`Failed to load plugins: ${e.message}`);
    } finally {
      setLoading(false);
    }
  }, [api]);

  useEffect(() => {
    loadPlugins();
  }, [loadPlugins]);

  const togglePlugin = async (name, enabled) => {
    try {
      await api.patch(`/plugins/${name}`, { enabled });
      flash(`${name} ${enabled ? "enabled" : "disabled"}`);
      loadPlugins();
    } catch (e) {
      flash(`Toggle failed: ${e.response?.data?.detail || e.message}`);
    }
  };

  const installPlugin = async (e) => {
    e.preventDefault();
    if (!installName.trim() || !installCode.trim()) return;
    try {
      await api.post("/plugins", {
        module_name: installName.trim(),
        source_code: installCode,
        enabled: installEnabled,
      });
      flash("Plugin installed");
      setInstallName("");
      setInstallCode("");
      setInstallEnabled(true);
      loadPlugins();
    } catch (e2) {
      flash(`Install failed: ${e2.response?.data?.detail || e2.message}`);
    }
  };

  return (
    <div>
      <h2 style={{ marginTop: 0 }}>Plugin Management</h2>
      <p style={{ color: "#94a3b8", fontSize: 13 }}>
        Manage hardcoded plugins from local storage. Enable/disable without deleting source files.
      </p>
      {message && <p style={{ color: message.startsWith("Failed") || message.includes("failed") ? "#ef4444" : "#22c55e" }}>{message}</p>}

      <div style={{ ...S.card, marginBottom: 16 }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 10 }}>
          <h3 style={{ margin: 0 }}>Installed Plugins</h3>
          <button style={S.btn} onClick={loadPlugins}>Refresh</button>
        </div>
        {loading ? (
          <p style={{ color: "#64748b" }}>Loading...</p>
        ) : plugins.length === 0 ? (
          <p style={{ color: "#64748b" }}>No plugins found</p>
        ) : (
          <table style={S.table}>
            <thead>
              <tr>
                <th style={S.th}>Name</th>
                <th style={S.th}>Installed</th>
                <th style={S.th}>Loaded</th>
                <th style={S.th}>Enabled</th>
                <th style={S.th}></th>
              </tr>
            </thead>
            <tbody>
              {plugins.map((p) => (
                <tr key={p.name}>
                  <td style={S.td}><code style={{ color: "#38bdf8" }}>{p.name}</code></td>
                  <td style={S.td}>{p.installed ? "Yes" : "No"}</td>
                  <td style={S.td}>{p.loaded ? "Yes" : "No"}</td>
                  <td style={S.td}>{p.enabled ? "Yes" : "No"}</td>
                  <td style={S.td}>
                    <button
                      style={{ ...S.btn, padding: "4px 10px", fontSize: 12, background: p.enabled ? "#b91c1c" : "#0f766e" }}
                      onClick={() => togglePlugin(p.name, !p.enabled)}
                    >
                      {p.enabled ? "Disable" : "Enable"}
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>

      <div style={S.card}>
        <h3 style={{ marginTop: 0 }}>Upload / Install Plugin</h3>
        <form onSubmit={installPlugin}>
          <label style={S.label}>Module Name</label>
          <input
            style={S.input}
            placeholder="hello_world"
            value={installName}
            onChange={(e) => setInstallName(e.target.value)}
            required
          />
          <label style={S.label}>Source Code</label>
          <textarea
            style={{ ...S.input, minHeight: 180, resize: "vertical", fontFamily: "monospace" }}
            placeholder={"def on_scan_complete(context):\n    print('Hello from plugin')\n"}
            value={installCode}
            onChange={(e) => setInstallCode(e.target.value)}
            required
          />
          <label style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 12, color: "#e2e8f0" }}>
            <input
              type="checkbox"
              checked={installEnabled}
              onChange={(e) => setInstallEnabled(e.target.checked)}
            />
            Enable immediately after install
          </label>
          <button style={S.btn} type="submit">Install Plugin</button>
        </form>
      </div>
    </div>
  );
}

// ── App Root ──────────────────────────────────────────────────────────────────
export default function App() {
  const [token, setToken] = useState(() => localStorage.getItem("omni_token") || "");
  const [view, setView] = useState("list");
  const [selectedScan, setSelectedScan] = useState(null);

  const api = useMemo(() => createApi(token), [token]);

  const login = (t) => { localStorage.setItem("omni_token", t); setToken(t); };
  const logout = () => { localStorage.removeItem("omni_token"); setToken(""); setView("list"); };

  if (!token) return <Login onLogin={login} />;

  return (
    <div style={S.page}>
      <nav style={S.nav}>
        <span style={{ fontWeight: 700, color: "#38bdf8", cursor: "pointer", marginRight: 8 }} onClick={() => setView("list")}>Omni Sentinal</span>
        <button style={{ ...S.btn, background: "none", color: view === "list" ? "#e2e8f0" : "#94a3b8", padding: "4px 10px" }} onClick={() => setView("list")}>Scans</button>
        <button style={{ ...S.btn, background: "none", color: view === "plugins" ? "#e2e8f0" : "#94a3b8", padding: "4px 10px" }} onClick={() => setView("plugins")}>Plugin Management</button>
        <button style={{ ...S.btn, background: "none", color: view === "settings" ? "#e2e8f0" : "#94a3b8", padding: "4px 10px" }} onClick={() => setView("settings")}>Settings</button>
        <div style={{ flex: 1 }} />
        <button style={{ ...S.btn, background: "#7f1d1d", padding: "4px 12px", fontSize: 12 }} onClick={logout}>Logout</button>
      </nav>
      <main style={S.main}>
        {view === "list" && <ScanList api={api} onSelect={id => { setSelectedScan(id); setView("detail"); }} onNewScan={() => setView("new")} />}
        {view === "new" && <NewScan api={api} onBack={() => setView("list")} onCreated={id => { setSelectedScan(id); setView("detail"); }} />}
        {view === "detail" && selectedScan && <ScanDetail api={api} scanId={selectedScan} onBack={() => setView("list")} />}
        {view === "plugins" && <PluginManagement api={api} />}
        {view === "settings" && <Settings api={api} onBack={() => setView("list")} />}
      </main>
    </div>
  );
}
