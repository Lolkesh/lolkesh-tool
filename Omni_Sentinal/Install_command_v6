import logging
from typing import Optional

logger = logging.getLogger(__name__)

try:
    import ldap3
    from ldap3 import Server, Connection, ALL, NTLM, ANONYMOUS, SASL, SIMPLE
    LDAP_AVAILABLE = True
except ImportError:
    LDAP_AVAILABLE = False


COMMON_NAMING_CONTEXTS = [
    "DC=htb,DC=local",
    "DC=domain,DC=local",
    "DC=corp,DC=local",
    "DC=lab,DC=local",
]

AD_FILTERS = {
    "all_users": "(&(objectClass=user)(objectCategory=person))",
    "enabled_users": "(&(objectClass=user)(objectCategory=person)(!(userAccountControl:1.2.840.113556.1.4.803:=2)))",
    "domain_admins": "(&(objectClass=user)(memberOf=CN=Domain Admins,CN=Users,{base_dn}))",
    "computers": "(objectClass=computer)",
    "groups": "(objectClass=group)",
    "spn_users": "(&(objectClass=user)(servicePrincipalName=*))",  # Kerberoastable
    "asrep_users": "(&(objectClass=user)(userAccountControl:1.2.840.113556.1.4.803:=4194304))",  # ASREPRoastable
    "password_not_required": "(&(objectClass=user)(userAccountControl:1.2.840.113556.1.4.803:=32))",
    "unconstrained_delegation": "(&(objectClass=computer)(userAccountControl:1.2.840.113556.1.4.803:=524288))",
    "gpos": "(objectClass=groupPolicyContainer)",
    "ous": "(objectClass=organizationalUnit)",
}

INTERESTING_ATTRS = [
    "sAMAccountName", "cn", "displayName", "mail", "description",
    "memberOf", "userAccountControl", "lastLogon", "pwdLastSet",
    "servicePrincipalName", "operatingSystem", "operatingSystemVersion",
    "distinguishedName", "objectSid", "adminCount", "badPwdCount",
]


def _try_bind(server, username: str = "", password: str = "") -> Optional[object]:
    if not LDAP_AVAILABLE:
        return None
    try:
        if username:
            conn = Connection(server, user=username, password=password, authentication=SIMPLE, auto_bind=True)
        else:
            conn = Connection(server, authentication=ANONYMOUS, auto_bind=True)
        return conn
    except Exception as exc:
        logger.debug(f"LDAP bind failed: {exc}")
        return None


def _detect_base_dn(conn) -> str:
    try:
        conn.search("", "(objectClass=*)", attributes=["namingContexts"], search_scope=ldap3.BASE)
        if conn.entries:
            ncs = conn.entries[0]["namingContexts"].values
            for nc in ncs:
                if "DC=" in nc.upper():
                    return nc
    except Exception:
        pass
    return ""


def _search(conn, base_dn: str, filter_str: str, attrs: list, limit: int = 100) -> list:
    try:
        conn.search(base_dn, filter_str, attributes=attrs, size_limit=limit)
        results = []
        for entry in conn.entries:
            obj = {}
            for attr in attrs:
                try:
                    val = entry[attr].values
                    obj[attr] = val if len(val) != 1 else val[0]
                except Exception:
                    pass
            if obj:
                results.append(obj)
        return results
    except Exception as exc:
        logger.debug(f"LDAP search failed: {exc}")
        return []


def enumerate_ldap(
    target: str,
    port: int = 389,
    username: str = "",
    password: str = "",
    base_dn: str = "",
    use_ssl: bool = False,
) -> dict:
    if not LDAP_AVAILABLE:
        return {"available": False, "message": "ldap3 not installed"}

    try:
        server = Server(target, port=port, use_ssl=use_ssl, get_info=ALL, connect_timeout=10)
        conn = _try_bind(server, username, password)
        if not conn:
            return {"available": True, "bound": False, "message": "Anonymous and credential bind both failed"}

        if not base_dn:
            base_dn = _detect_base_dn(conn)
        if not base_dn:
            for ctx in COMMON_NAMING_CONTEXTS:
                base_dn = ctx
                break

        results = {}
        for key, ldap_filter in AD_FILTERS.items():
            f = ldap_filter.format(base_dn=base_dn)
            found = _search(conn, base_dn, f, INTERESTING_ATTRS, limit=200)
            if found:
                results[key] = found

        conn.unbind()

        kerberoastable = results.get("spn_users", [])
        asrep_roastable = results.get("asrep_users", [])
        domain_admins = results.get("domain_admins", [])

        return {
            "available": True,
            "bound": True,
            "target": target,
            "port": port,
            "base_dn": base_dn,
            "results": results,
            "summary": {
                "users": len(results.get("all_users", [])),
                "computers": len(results.get("computers", [])),
                "groups": len(results.get("groups", [])),
                "kerberoastable": len(kerberoastable),
                "asrep_roastable": len(asrep_roastable),
                "domain_admins": len(domain_admins),
                "spn_accounts": [u.get("sAMAccountName", "") for u in kerberoastable],
                "asrep_accounts": [u.get("sAMAccountName", "") for u in asrep_roastable],
                "admin_accounts": [u.get("sAMAccountName", "") for u in domain_admins],
            },
        }
    except Exception as exc:
        logger.error(f"LDAP enumeration error: {exc}")
        return {"available": True, "bound": False, "error": str(exc)}
