@app.post("/scheduled-scans")
def create_scheduled_scan(request: ScheduleRequest, user: dict = Depends(require_admin)) -> dict:
    key = request.target
    if key in _scheduled:
        return {"message": f"Scan for {request.target} already scheduled", "target": request.target}

    def job():
        from core.worker import scan_target_task
        scan_id = str(uuid.uuid4())
        with closing(get_db()) as db:
            db.execute(
                "INSERT INTO scans (id, target, status, progress, tags, created_by) VALUES (?,?,?,?,?,?)",
                (scan_id, request.target, "PENDING", 0, "[]", "scheduler"),
            )
            db.commit()
        scan_target_task.delay(scan_id, request.target, request.aggressive)

    stop_event = threading.Event()
    _scheduled[key] = {"interval_minutes": request.interval_minutes, "target": request.target, "stop": stop_event}
    threading.Thread(
        target=run_scheduler, args=(job, request.interval_minutes, stop_event), daemon=True, name=f"sched-{key}"
    ).start()
    return {"message": f"Recurring scan scheduled every {request.interval_minutes} min for {request.target}"}


