import importlib.util
import json
import logging
import os
import re
import tempfile
from pathlib import Path
from typing import Any, Dict, List

logger = logging.getLogger(__name__)
_ROOT_DIR = Path(__file__).resolve().parent.parent
_PLUGINS_DIR = _ROOT_DIR / "plugins"
_CONFIG_PATH = _ROOT_DIR / "config.json"
_NAME_RE = re.compile(r"^[a-zA-Z_][a-zA-Z0-9_]*$")
_loaded_plugins: Dict[str, Any] = {}


def _atomic_write_text(path: Path, data: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile("w", encoding="utf-8", dir=str(path.parent), delete=False) as tmp:
        tmp.write(data)
        tmp.flush()
        os.fsync(tmp.fileno())
        temp_name = tmp.name
    os.replace(temp_name, path)


def ensure_layout() -> None:
    _PLUGINS_DIR.mkdir(parents=True, exist_ok=True)
    (_PLUGINS_DIR / "__init__.py").touch(exist_ok=True)
    if not _CONFIG_PATH.exists():
        _atomic_write_text(_CONFIG_PATH, json.dumps({"plugins": {}}, indent=2))


def _read_config() -> Dict[str, Any]:
    ensure_layout()
    try:
        return json.loads(_CONFIG_PATH.read_text(encoding="utf-8"))
    except Exception as exc:
        logger.warning(f"Failed reading config.json, using defaults: {exc}")
        return {"plugins": {}}


def _write_config(data: Dict[str, Any]) -> None:
    _atomic_write_text(_CONFIG_PATH, json.dumps(data, indent=2, sort_keys=True) + "\n")


def discover_plugins() -> List[str]:
    ensure_layout()
    names = []
    for path in sorted(_PLUGINS_DIR.glob("*.py")):
        if path.name == "__init__.py":
            continue
        names.append(path.stem)
    return names


def install_plugin(module_name: str, source_code: str, enable: bool = True) -> str:
    if not _NAME_RE.match(module_name):
        raise ValueError("Invalid plugin module name")
    ensure_layout()
    plugin_path = _PLUGINS_DIR / f"{module_name}.py"
    _atomic_write_text(plugin_path, source_code.rstrip() + "\n")
    cfg = _read_config()
    cfg.setdefault("plugins", {})[module_name] = bool(enable)
    _write_config(cfg)
    return str(plugin_path)


def set_plugin_enabled(module_name: str, enabled: bool) -> Dict[str, Any]:
    cfg = _read_config()
    cfg.setdefault("plugins", {})[module_name] = bool(enabled)
    _write_config(cfg)
    if not enabled:
        _loaded_plugins.pop(module_name, None)
    return cfg


def list_plugin_states() -> List[Dict[str, Any]]:
    cfg = _read_config()
    enabled_map = cfg.get("plugins", {})
    discovered = set(discover_plugins()) | set(enabled_map.keys())
    rows = []
    for name in sorted(discovered):
        rows.append({
            "name": name,
            "enabled": bool(enabled_map.get(name, False)),
            "installed": (_PLUGINS_DIR / f"{name}.py").exists(),
            "loaded": name in _loaded_plugins,
        })
    return rows


def load_enabled_plugins() -> Dict[str, Any]:
    cfg = _read_config()
    for name, enabled in cfg.get("plugins", {}).items():
        if not enabled:
            _loaded_plugins.pop(name, None)
            continue
        plugin_file = _PLUGINS_DIR / f"{name}.py"
        if not plugin_file.exists():
            logger.warning(f"Plugin '{name}' is enabled but file is missing")
            continue
        if name in _loaded_plugins:
            continue
        try:
            spec = importlib.util.spec_from_file_location(f"plugins.{name}", plugin_file)
            if spec is None or spec.loader is None:
                raise RuntimeError("Unable to create module spec")
            module = importlib.util.module_from_spec(spec)
            spec.loader.exec_module(module)
            _loaded_plugins[name] = module
            logger.info(f"Loaded plugin '{name}'")
        except Exception as exc:
            logger.exception(f"Failed to load plugin '{name}': {exc}")
    return _loaded_plugins


def run_hook(hook_name: str, **context: Any) -> List[Dict[str, Any]]:
    load_enabled_plugins()
    results: List[Dict[str, Any]] = []
    for name, module in list(_loaded_plugins.items()):
        handler = getattr(module, hook_name, None)
        if not callable(handler):
            continue
        try:
            value = handler(context)
            results.append({"plugin": name, "ok": True, "result": value})
        except Exception as exc:
            logger.exception(f"Plugin '{name}' hook '{hook_name}' failed: {exc}")
            results.append({"plugin": name, "ok": False, "error": str(exc)})
    return results
PY

