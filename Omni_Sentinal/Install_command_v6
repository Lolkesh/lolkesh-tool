  // Simple force-directed layout approximation
  const positions = {};
  const count = nodes.length;
  nodes.forEach((n, i) => {
    const angle = (i / count) * 2 * Math.PI;
    const r = Math.min(200, 60 * count);
    positions[n.id] = { x: 400 + r * Math.cos(angle), y: 260 + r * Math.sin(angle) };
  });
  return positions;
}

