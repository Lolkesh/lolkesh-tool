const SEV_COLOR = { CRITICAL: "#ef4444", HIGH: "#f97316", MEDIUM: "#f59e0b", LOW: "#22c55e", UNKNOWN: "#64748b" };

function layout(nodes) {
  const positions = {};
  const count = nodes.length;
  nodes.forEach((n, i) => {
    const angle = (i / count) * 2 * Math.PI;
    const r = Math.min(200, 55 * count);
    positions[n.id] = { x: 400 + r * Math.cos(angle), y: 260 + r * Math.sin(angle) };
