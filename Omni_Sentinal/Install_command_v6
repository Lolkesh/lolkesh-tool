    data     = json.loads(row["data"] or "{}")
    services = data.get("services", {})
    cves     = data.get("cves", {})

    # Build compact context
    svc_lines = []
    for port, info in services.items():
        cve_count = len(cves.get(port, []))
        crit = sum(1 for c in cves.get(port, []) if c.get("severity") == "CRITICAL")
        svc_lines.append(f"  - Port {port}: {info.get('service')} {info.get('version','')} "
                         f"({'%d CVEs, %d critical' % (cve_count, crit) if cve_count else 'no CVEs'})")

    # Try to get loot
    loot_lines = []
    try:
        from plugins.loot_organizer import get_loot
        loot = get_loot(scan_id=scan_id)
        for item in loot[:10]:
            loot_lines.append(f"  - [{item['loot_type']}] {item['value'][:60]} ({item['description']})")
    except Exception:
        pass

    note_lines = [f"  - {n['content'][:200]}" for n in notes[:5]]

    return f"""
Target: {row['target']} ({box_name or 'Unknown box'})
OS Hint: {row.get('os_hint') or 'Unknown'}
Status: {row['status']}

Open Services:
{chr(10).join(svc_lines) or '  None discovered'}

Loot Found:
{chr(10).join(loot_lines) or '  None'}

Analyst Notes:
{chr(10).join(note_lines) or '  None'}
""".strip()


def generate_narrative(
    scan_id: str,
    box_name: str = "",
    difficulty: str = "Medium",
    extra_context: str = "",
) -> dict:
    context = _build_context(scan_id, box_name)
    if not context:
        return {"error": "Scan not found"}

    prompt = f"""You are an expert penetration tester writing an HTB writeup.
Based on the following scan data, generate a clear, technical attack path narrative.
Include: initial recon findings, exploitation steps, privilege escalation path, and key takeaways.
Write in past tense as if the box has been completed. Be specific and technical.

Scan Data:
{context}

Box: {box_name or 'Unknown'} | Difficulty: {difficulty}
{('Additional context: ' + extra_context) if extra_context else ''}

Write the attack narrative:"""

    try:
        r = requests.post(
            f"{OLLAMA_BASE}/api/generate",
            json={"model": OLLAMA_MODEL, "prompt": prompt, "stream": False},
            timeout=OLLAMA_TIMEOUT,
        )
        r.raise_for_status()
        data = r.json()
        narrative = data.get("response", "").strip()
        return {
            "scan_id": scan_id,
            "box_name": box_name,
            "narrative": narrative,
            "model": OLLAMA_MODEL,
            "tokens": data.get("eval_count", 0),
        }
    except Exception as exc:
        logger.error(f"Narrative generation failed: {exc}")
        return {"error": str(exc), "scan_id": scan_id}
