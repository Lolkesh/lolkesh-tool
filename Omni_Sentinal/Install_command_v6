import ipaddress
import re

from fastapi import HTTPException

_HOSTNAME_RE = re.compile(
    r"^(?:[a-zA-Z0-9](?:[a-zA-Z0-9\-]{0,61}[a-zA-Z0-9])?\.)*"
    r"[a-zA-Z0-9](?:[a-zA-Z0-9\-]{0,61}[a-zA-Z0-9])?$"
)
_URL_RE = re.compile(r"^https?://[^\s]{1,2000}$", re.IGNORECASE)


def validate_target(target: str) -> str:
    target = target.strip()
    if not target or len(target) > 255:
        raise HTTPException(status_code=400, detail="Invalid target length")
    try:
        ipaddress.ip_address(target)
        return target
    except ValueError:
        pass
    try:
        ipaddress.ip_network(target, strict=False)
        return target
    except ValueError:
        pass
    if _HOSTNAME_RE.match(target):
        return target
    raise HTTPException(status_code=400, detail=f"Invalid target: {target}")


def validate_url(url: str) -> str:
    if not _URL_RE.match(url):
        raise HTTPException(status_code=400, detail=f"Invalid URL: {url}")
    return url


def is_htb_target(target: str) -> bool:
    try:
        ip = ipaddress.ip_address(target)
        for net in [
            ipaddress.ip_network("10.10.10.0/24"),
            ipaddress.ip_network("10.10.11.0/24"),
            ipaddress.ip_network("10.129.0.0/16"),
        ]:
            if ip in net:
                return True
    except ValueError:
        pass
    return False
