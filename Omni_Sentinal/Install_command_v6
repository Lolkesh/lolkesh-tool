logger = logging.getLogger(__name__)

_DEFAULT_MIN_SEVERITY = "HIGH"
_SEV_ORDER = {"CRITICAL": 4, "HIGH": 3, "MEDIUM": 2, "LOW": 1, "UNKNOWN": 0}


def _get_config(context: dict) -> tuple[str, str]:
    """Read webhook_url and min_severity from plugin settings."""
    try:
        from core.plugin_loader import get_plugin_setting
        webhook_url  = get_plugin_setting("slack_notifier", "webhook_url", "")
        min_severity = get_plugin_setting("slack_notifier", "min_severity", _DEFAULT_MIN_SEVERITY)
