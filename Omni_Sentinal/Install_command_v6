        lines.append(f">{emoji} `{cve['id']}` CVSS:{cve.get('score','?')} — {(cve.get('description') or '')[:80]}")

    color = "#ff0000" if any(c.get("severity") == "CRITICAL" for c in notable) else "#f59e0b"
    _post(webhook_url, "\n".join(lines), color=color)
