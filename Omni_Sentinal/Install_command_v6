def hibp_password(password: str) -> dict:
    """Check HIBP k-anonymity password API — sends only first 5 chars of SHA-1 hash."""
    import hashlib
    sha1 = hashlib.sha1(password.encode("utf-8")).hexdigest().upper()
    prefix, suffix = sha1[:5], sha1[5:]
    r = _get(f"https://api.pwnedpasswords.com/range/{prefix}", timeout=8)
    if not r or r.status_code != 200:
        return {"available": False, "reason": "HIBP password API unreachable"}
    for line in r.text.splitlines():
        h, _, count = line.partition(":")
        if h.strip() == suffix:
            return {"available": True, "pwned": True, "count": int(count.strip())}
    return {"available": True, "pwned": False, "count": 0}


# ── Email Pattern Generator ───────────────────────────────────────────────────

def email_patterns(first: str, last: str, domain: str) -> dict:
    f, l = first.lower(), last.lower()
    fi, li = f[0] if f else "", l[0] if l else ""
    patterns = [
        f"{f}.{l}@{domain}",
        f"{f}{l}@{domain}",
        f"{fi}{l}@{domain}",
        f"{f}{li}@{domain}",
        f"{f}_{l}@{domain}",
        f"{l}.{f}@{domain}",
        f"{l}{fi}@{domain}",
        f"{f}@{domain}",
        f"{l}@{domain}",
        f"{f}.{li}@{domain}",
        f"{fi}.{l}@{domain}",
    ]
    return {
        "first": first, "last": last, "domain": domain,
        "patterns": patterns,
        "most_common": [patterns[0], patterns[2], patterns[6]],
    }


