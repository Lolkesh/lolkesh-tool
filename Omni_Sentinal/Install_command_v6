logger = logging.getLogger(__name__)

COMMON_PASSWORDS = [
    "password", "123456", "admin", "root", "letmein",
    "welcome", "monkey", "dragon", "master", "sunshine",
    "password1", "Password1", "Pass123", "Admin123",
