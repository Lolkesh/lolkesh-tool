# ── WHOIS ──────────────────────────────────────────────────────────────────────

def whois_lookup(target: str) -> dict:
    if not shutil.which("whois"):
        return {"target": target, "error": "whois not in PATH"}
    try:
        result = subprocess.run(
            ["whois", target], capture_output=True, text=True, timeout=15, check=False
        )
        raw = result.stdout[:5000]
        parsed = {}
        for line in raw.splitlines():
            if ":" in line:
                key, _, val = line.partition(":")
                key = key.strip().lower().replace(" ", "_")
                val = val.strip()
                if key and val and key not in parsed:
                    parsed[key] = val
        important = {k: parsed[k] for k in (
            "registrar", "creation_date", "updated_date", "expiry_date",
            "name_server", "registrant_name", "registrant_organization",
            "registrant_country", "registrant_email", "admin_email",
            "registrant_state/province", "dnssec", "status"
        ) if k in parsed}
        return {"target": target, "parsed": important, "raw": raw}
    except subprocess.TimeoutExpired:
        return {"target": target, "error": "whois timed out"}
    except Exception as exc:
        return {"target": target, "error": str(exc)}


# ── DNS Records ───────────────────────────────────────────────────────────────

def dns_records(domain: str) -> dict:
    """Resolve common DNS record types using system resolver."""
    record_types = ["A", "AAAA", "MX", "TXT", "NS", "CNAME", "SOA"]
    records = {}

    try:
        import dns.resolver as _res
        resolver = _res.Resolver()
        resolver.lifetime = 3.0
        for rtype in record_types:
            try:
                answers = resolver.resolve(domain, rtype)
                records[rtype] = [str(a) for a in answers]
            except Exception:
                records[rtype] = []
    except ImportError:
        # Fallback to host command
        for rtype in ["A", "MX", "NS"]:
            try:
                out = subprocess.run(
                    ["host", "-t", rtype, domain],
                    capture_output=True, text=True, timeout=5, check=False
                ).stdout
                lines = [l.strip() for l in out.splitlines() if "has" in l or "mail" in l]
                records[rtype] = lines
            except Exception:
                records[rtype] = []

    return {"domain": domain, "records": records}


