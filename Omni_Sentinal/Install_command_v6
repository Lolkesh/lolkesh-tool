    try:
        ipaddress.ip_address(value)
        return True
    except ValueError:
        return False


def _resolve(domain: str) -> list:
    try:
        results = socket.getaddrinfo(domain, None)
        return list({r[4][0] for r in results})
    except socket.gaierror:
        return []


# ── Certificate Transparency (crt.sh) ────────────────────────────────────────

def crtsh_subdomains(domain: str) -> dict:
    """Mine subdomains from certificate transparency logs via crt.sh."""
    url = "https://crt.sh/"
    r = _get(url, params={"q": f"%.{domain}", "output": "json"}, timeout=15)
    if not r or r.status_code != 200:
        return {"domain": domain, "subdomains": [], "count": 0, "error": "crt.sh unavailable"}

    try:
        entries = r.json()
    except (ValueError, KeyError):
        return {"domain": domain, "subdomains": [], "count": 0, "error": "Invalid JSON from crt.sh"}

    seen = set()
    subdomains = []
    for entry in entries:
        names = entry.get("name_value", "").split("\n")
        for name in names:
            name = name.strip().lower().lstrip("*.")
            if name and name.endswith(domain) and name not in seen:
                seen.add(name)
                ips = _resolve(name)
                subdomains.append({
                    "subdomain": name,
                    "ips": ips,
                    "issuer": entry.get("issuer_name", ""),
                    "not_before": entry.get("not_before", ""),
                    "not_after": entry.get("not_after", ""),
                })

    subdomains.sort(key=lambda x: x["subdomain"])
    return {"domain": domain, "subdomains": subdomains, "count": len(subdomains)}


