# ── Auto LinPEAS/WinPEAS via SSH ──────────────────────────────────────────────
cat > "$BASE/plugins/auto_linpeas.py" <<'PY'
"""
Automatically upload and execute LinPEAS/WinPEAS on target via SSH,
then parse and return structured findings.
"""
import io
import logging
import os
import shutil
import tempfile
import time
from pathlib import Path
from typing import Optional

logger = logging.getLogger(__name__)

LINPEAS_URL = "https://github.com/carlospolop/PEASS-ng/releases/latest/download/linpeas.sh"
WINPEAS_URL = "https://github.com/carlospolop/PEASS-ng/releases/latest/download/winPEASx64.exe"
PEAS_CACHE = os.path.expanduser("~/omni-sentinal/output/peas")


def _download_peas(url: str, filename: str) -> Optional[str]:
    import requests
    cache_path = Path(PEAS_CACHE) / filename
    Path(PEAS_CACHE).mkdir(parents=True, exist_ok=True)
    if cache_path.exists() and cache_path.stat().st_size > 10000:
        logger.info(f"Using cached {filename}")
        return str(cache_path)
    try:
        logger.info(f"Downloading {filename} from {url}")
        r = requests.get(url, timeout=30, stream=True)
        r.raise_for_status()
        with open(cache_path, "wb") as f:
            for chunk in r.iter_content(8192):
                f.write(chunk)
        return str(cache_path)
    except Exception as exc:
        logger.error(f"Download failed: {exc}")
        return None


def run_linpeas_ssh(
    host: str,
    username: str,
    password: str = "",
    key_path: str = "",
    port: int = 22,
    timeout: int = 300,
    os_type: str = "linux",
) -> dict:
    try:
        import paramiko
    except ImportError:
        return {"error": "paramiko not installed"}

    peas_url = LINPEAS_URL if os_type == "linux" else WINPEAS_URL
    peas_file = "linpeas.sh" if os_type == "linux" else "winpeas.exe"
    local_path = _download_peas(peas_url, peas_file)
    if not local_path:
        return {"error": f"Failed to download {peas_file}"}

    ssh = paramiko.SSHClient()
    ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())

    try:
        connect_kwargs = {"hostname": host, "port": port, "username": username,
                         "timeout": 15, "banner_timeout": 15}
        if key_path and Path(key_path).exists():
            connect_kwargs["key_filename"] = key_path
        elif password:
            connect_kwargs["password"] = password
        else:
            return {"error": "Provide password or key_path"}

        ssh.connect(**connect_kwargs)
        sftp = ssh.open_sftp()

        remote_path = f"/tmp/.{peas_file}" if os_type == "linux" else f"C:\\Windows\\Temp\\{peas_file}"
        sftp.put(local_path, remote_path)
        sftp.close()

        if os_type == "linux":
            cmd = f"chmod +x {remote_path} && {remote_path} 2>/dev/null; rm -f {remote_path}"
        else:
            cmd = f"{remote_path} 2>nul & del {remote_path}"

        logger.info(f"Executing {peas_file} on {host}")
        _, stdout, stderr = ssh.exec_command(cmd, timeout=timeout)
        output = stdout.read().decode("utf-8", errors="replace")
        ssh.close()

        # Save raw output
        out_dir = Path(os.path.expanduser("~/omni-sentinal/output/peas"))
        out_dir.mkdir(parents=True, exist_ok=True)
        out_file = out_dir / f"{host.replace('.', '_')}_{peas_file}.txt"
        out_file.write_text(output, encoding="utf-8", errors="replace")

        # Parse findings
        from plugins.linpeas_parser import parse_linpeas
        parsed = parse_linpeas(output)

        return {
            "host": host,
            "os_type": os_type,
            "output_file": str(out_file),
            "output_length": len(output),
            "parsed": parsed,
        }

    except Exception as exc:
        logger.error(f"Auto LinPEAS failed: {exc}")
        try:
            ssh.close()
        except Exception:
            pass
        return {"error": str(exc), "host": host}
PY


