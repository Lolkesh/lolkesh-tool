    wordlist = get_wordlist(SUBDOMAIN_WORDLISTS)
    results = []
    try:
        proc = subprocess.Popen(
            [gobuster, "dns", "-d", target, "-w", wordlist, "-t", "20", "-q", "--no-error"],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        if proc.stdout is None:
            logger.error(f"Gobuster (dns) stdout is None for {target}")
            return
        for line in proc.stdout:
            line = line.strip()
            if line and "Found:" in line:
                results.append({"type": "dns", "value": line.replace("Found:", "").strip()})
        proc.wait(timeout=300)
    except subprocess.TimeoutExpired:
        proc.kill()
        logger.error(f"Subdomain enum timeout for {target}")
    except Exception as exc:
        logger.error(f"Subdomain enum failed for {target}: {exc}")
    db_update_fn(scan_id, "subdomains", results)


def launch_gobuster_async(scan_id: str, target: str, services: dict, os_hint: str, db_update_fn: Callable) -> None:
    for port, info in services.items():
        service = info.get("service", "").lower()
        is_web = "http" in service or port in {"80", "443", "8080", "8443", "8000", "8888"}
        if not is_web:
            continue
        scheme = "https" if "ssl" in service or port in {"443", "8443"} else "http"
        cms = detect_cms(f"{scheme}://{target}:{port}")
        wordlist = suggest_wordlist(os_hint, cms=cms)
        thread = threading.Thread(
            target=run_gobuster,
            args=(scan_id, target, port, scheme, wordlist, db_update_fn),
            daemon=False,
            name=f"gobuster-{scan_id}-{port}",
        )
        thread.start()


def launch_subdomain_enum_async(scan_id: str, target: str, db_update_fn: Callable) -> None:
    threading.Thread(
        target=run_subdomain_enum,
        args=(scan_id, target, db_update_fn),
        daemon=False,
        name=f"subdomain-{scan_id}",
    ).start()
