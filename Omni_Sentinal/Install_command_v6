    ips = _resolve(domain)
    ip = ips[0] if ips else ""

    results = {
        "target": domain,
        "resolved_ips": ips,
        "timestamp": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
    }

    # Certificate Transparency
    results["crtsh"] = crtsh_subdomains(domain)

    # WHOIS
    results["whois"] = whois_lookup(domain)

    # DNS Records
    results["dns"] = dns_records(domain)

    # BGP / ASN
    results["bgp"] = bgpview_domain(domain)

    # Wayback Machine
    results["wayback"] = wayback_cdx(domain)

    # URLScan
    results["urlscan"] = urlscan_search(f"domain:{domain}")

    # Reverse IP
    if ip:
        results["reverse_ip"] = reverse_ip(ip)

    # Per-IP intelligence
    if ip:
        results["shodan_internetdb"] = shodan_internetdb(ip)
        results["greynoise"] = greynoise_ip(ip)
        results["ipinfo"] = ipinfo(ip)
        if ABUSEIPDB_KEY:
            results["abuseipdb"] = abuseipdb_check(ip)
        if SHODAN_KEY:
            results["shodan_full"] = shodan_full(ip)
        if VT_KEY:
            results["virustotal"] = virustotal_domain(domain)

    # Dorks
    results["google_dorks"] = google_dorks(domain, company_name)
    results["shodan_dorks"] = shodan_dorks(domain)

    return results


