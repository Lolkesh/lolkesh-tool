    "path_hijack": re.compile(r"Writable folders in PATH", re.IGNORECASE),
    "backup_files": re.compile(r"\.(bak|backup|old|orig|save|swp|~)$", re.IGNORECASE | re.MULTILINE),
}

SEVERITY_MAP = {
    "sudo_nopasswd": "CRITICAL",
    "suid_binary": "HIGH",
    "ssh_key": "CRITICAL",
    "password_in_file": "HIGH",
    "env_variable": "HIGH",
    "capabilities": "HIGH",
    "nfs_no_root_squash": "HIGH",
    "writable_etc": "HIGH",
    "docker_group": "HIGH",
    "path_hijack": "MEDIUM",
    "cron_job": "MEDIUM",
    "writable_path": "MEDIUM",
    "kernel_version": "INFO",
    "os_release": "INFO",
    "backup_files": "LOW",
}


def parse_linpeas(output: str) -> dict:
    if not output:
        return {"findings": [], "summary": {}, "error": "Empty output"}

    findings = []
    for key, pattern in PATTERNS.items():
        matches = pattern.findall(output)
        if matches:
            severity = SEVERITY_MAP.get(key, "INFO")
            for match in matches[:10]:  # cap per category
                value = match if isinstance(match, str) else str(match)
                findings.append({
                    "category": key,
                    "severity": severity,
                    "value": value.strip()[:300],
                })

    # Deduplicate
    seen = set()
    unique = []
    for f in findings:
        key = f"{f['category']}:{f['value'][:50]}"
        if key not in seen:
            seen.add(key)
            unique.append(f)

    # Sort by severity
    sev_order = {"CRITICAL": 0, "HIGH": 1, "MEDIUM": 2, "LOW": 3, "INFO": 4}
    unique.sort(key=lambda x: sev_order.get(x["severity"], 5))

    summary = {
        "critical": sum(1 for f in unique if f["severity"] == "CRITICAL"),
        "high": sum(1 for f in unique if f["severity"] == "HIGH"),
        "medium": sum(1 for f in unique if f["severity"] == "MEDIUM"),
        "low": sum(1 for f in unique if f["severity"] == "LOW"),
        "info": sum(1 for f in unique if f["severity"] == "INFO"),
        "total": len(unique),
    }

    return {"findings": unique, "summary": summary}
