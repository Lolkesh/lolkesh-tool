entries = metrics.get(key, [])
if entries:
d        = entries[0].get(“cvssData”, {})
score    = d.get(“baseScore”, “N/A”)
severity = d.get(“baseSeverity”, entries[0].get(“baseSeverity”, “UNKNOWN”))
vector   = d.get(“vectorString”, “”)
