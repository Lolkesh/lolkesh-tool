def crtsh_subdomains(domain: str) -> dict:
    """Mine subdomains from certificate transparency logs via crt.sh."""
    url = "https://crt.sh/"
    r = _get(url, params={"q": f"%.{domain}", "output": "json"}, timeout=15)
    if not r or r.status_code != 200:
        return {"domain": domain, "subdomains": [], "count": 0, "error": "crt.sh unavailable"}

    try:
        entries = r.json()
    except (ValueError, KeyError):
        return {"domain": domain, "subdomains": [], "count": 0, "error": "Invalid JSON from crt.sh"}

    seen = set()
    subdomains = []
    for entry in entries:
        names = entry.get("name_value", "").split("\n")
        for name in names:
            name = name.strip().lower().lstrip("*.")
            if name and name.endswith(domain) and name not in seen:
                seen.add(name)
                ips = _resolve(name)
                subdomains.append({
