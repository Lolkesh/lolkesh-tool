def _check_entropy(password: str) -> dict:
    classes = [name for pattern, name in ENTROPY_CLASSES if pattern.search(password)]
    length = len(password)
    score = len(classes) + min(length // 4, 4)
    if length < 8:
        score = max(0, score - 2)
    return {
        "length": length,
        "classes": classes,
        "class_count": len(classes),
