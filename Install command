CREATE UNIQUE INDEX IF NOT EXISTS idx_creds_unique ON credentials(host, service, port, username, COALESCE(password,''), COALESCE(hash,''));
"""


def _init_creds_table() -> None:
    with closing(get_db()) as db:
        db.executescript(CRED_SCHEMA)
        db.commit()


def add_credential(
    host: str,
    service: str = "",
    port: str = "",
    username: str = "",
    password: str = "",
    hash_val: str = "",
    hash_type: str = "",
    source: str = "manual",
    valid: bool = False,
    scan_id: str = "",
    notes: str = "",
) -> Optional[int]:
    _init_creds_table()
    try:
        with closing(get_db()) as db:
            cursor = db.execute(
                """INSERT OR IGNORE INTO credentials
                   (scan_id, host, service, port, username, password, hash, hash_type, source, valid, notes)
                   VALUES (?,?,?,?,?,?,?,?,?,?,?)""",
                (scan_id, host, service, port, username, password, hash_val, hash_type, source, int(valid), notes),
            )
            db.commit()
            return cursor.lastrowid
    except sqlite3.Error as exc:
        logger.error(f"Failed to add credential: {exc}")
