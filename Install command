import logging
import os
from pathlib import Path
from typing import Optional

from fpdf import FPDF
import markdown2

logger = logging.getLogger(__name__)


def export_markdown(report_text: str, output_path: str) -> Optional[str]:
    try:
        path = Path(output_path)
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(report_text, encoding="utf-8")
        return str(path)
    except (OSError, IOError) as exc:
        logger.error(f"Failed to export markdown: {exc}")
        return None


def export_html(report_text: str, output_path: str) -> Optional[str]:
    try:
        path = Path(output_path)
        path.parent.mkdir(parents=True, exist_ok=True)
        html_content = markdown2.markdown(report_text)
        path.write_text(html_content, encoding="utf-8")
        return str(path)
    except (OSError, IOError) as exc:
        logger.error(f"Failed to export HTML: {exc}")
        return None


def export_pdf(report_text: str, output_path: str) -> Optional[str]:
    try:
        pdf = FPDF()
        pdf.set_auto_page_break(auto=True, margin=15)
        pdf.add_page()
        pdf.set_font("Helvetica", size=12)
        for line in report_text.splitlines() or [""]:
