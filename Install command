ver = info.get(“version”,””)
lines += [f”## Port {port}/{info.get(‘proto’,‘tcp’)} — {svc} {ver}”.strip(), “”]
exdb  = info.get(“exploits”,{}).get(“exploits”,[])
if exdb:
lines.append(”**Exploit-DB:**”)
for e in exdb: lines.append(f”- {e[‘title’]} (EDB-{e.get(‘edb_id’,’?’)})”)
lines.append(””)
cves = info.get(“cves”,[])
if cves:
lines.append(”**CVEs:**”)
for c in cves:
lines.append(f”- `{c['id']}` Score:{c[‘score’]} {c[‘severity’]} — {c.get(‘description’,’’)}”)
lines.append(””)
dirs = info.get(“gobuster”,[])
if dirs:
lines.append(f”**Directory brute ({len(dirs)} found):**”)
for d in dirs[:20]: lines.append(f”- {d}”)
lines.append(””)
return “\n”.join(lines)

def scan_to_pdf(scan: dict, output_path: str, notes=None) -> str:
from fpdf import FPDF
md    = scan_to_markdown(scan, notes=notes)
clean = re.sub(r’[#*`_]’, ‘’, md)
pdf   = FPDF(); pdf.add_page()
pdf.set_font(“Courier”, size=9); pdf.set_margins(15,15,15)
for line in clean.split(”\n”):
try: pdf.multi_cell(0, 4, line)
except: pass
pdf.output(output_path)
return output_path
