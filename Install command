def whois_lookup(target: str) -> dict:
    if not shutil.which("whois"):
        return {"target": target, "error": "whois not in PATH"}
    try:
        result = subprocess.run(
            ["whois", target], capture_output=True, text=True, timeout=15, check=False
        )
        raw = result.stdout[:5000]
        parsed = {}
        for line in raw.splitlines():
            if ":" in line:
                key, _, val = line.partition(":")
                key = key.strip().lower().replace(" ", "_")
                val = val.strip()
                if key and val and key not in parsed:
                    parsed[key] = val
        important = {k: parsed[k] for k in (
            "registrar", "creation_date", "updated_date", "expiry_date",
            "name_server", "registrant_name", "registrant_organization",
            "registrant_country", "registrant_email", "admin_email",
            "registrant_state/province", "dnssec", "status"
        ) if k in parsed}
        return {"target": target, "parsed": important, "raw": raw}
    except subprocess.TimeoutExpired:
        return {"target": target, "error": "whois timed out"}
    except Exception as exc:
        return {"target": target, "error": str(exc)}


# ── DNS Records ───────────────────────────────────────────────────────────────

def dns_records(domain: str) -> dict:
    """Resolve common DNS record types using system resolver."""
    record_types = ["A", "AAAA", "MX", "TXT", "NS", "CNAME", "SOA"]
    records = {}

    try:
        import dns.resolver as _res
        resolver = _res.Resolver()
        resolver.lifetime = 3.0
        for rtype in record_types:
            try:
                answers = resolver.resolve(domain, rtype)
                records[rtype] = [str(a) for a in answers]
            except Exception:
                records[rtype] = []
    except ImportError:
        # Fallback to host command
        for rtype in ["A", "MX", "NS"]:
            try:
                out = subprocess.run(
                    ["host", "-t", rtype, domain],
                    capture_output=True, text=True, timeout=5, check=False
                ).stdout
                lines = [l.strip() for l in out.splitlines() if "has" in l or "mail" in l]
                records[rtype] = lines
            except Exception:
                records[rtype] = []

    return {"domain": domain, "records": records}


# ── HIBP — Have I Been Pwned ──────────────────────────────────────────────────

def hibp_email(email: str) -> dict:
    if not HIBP_KEY:
        return {"available": False, "reason": "OSINT_HIBP_KEY not set — get free key at haveibeenpwned.com/API"}
    encoded = quote_plus(email)
    r = _get(f"https://haveibeenpwned.com/api/v3/breachedaccount/{encoded}",
             params={"truncateResponse": "false"},
             headers={"hibp-api-key": HIBP_KEY, "User-Agent": "Omni-Sentinel/21.3"},
             timeout=10)
    if not r:
        return {"available": False, "reason": "HIBP unreachable"}
    if r.status_code == 404:
        return {"available": True, "email": email, "breaches": [], "pwned": False}
    if r.status_code == 401:
        return {"available": False, "reason": "Invalid HIBP API key"}
    if r.status_code != 200:
        return {"available": False, "reason": f"HTTP {r.status_code}"}
    try:
        breaches = r.json()
        simplified = [{
            "name": b.get("Name", ""),
            "domain": b.get("Domain", ""),
            "breach_date": b.get("BreachDate", ""),
            "data_classes": b.get("DataClasses", []),
            "pwn_count": b.get("PwnCount", 0),
            "description": (re.sub(r"<[^>]+>", "", b.get("Description", "") or ""))[:200],
        } for b in breaches]
        return {
            "available": True, "email": email,
            "pwned": True,
            "breach_count": len(simplified),
            "breaches": simplified,
        }
    except ValueError:
        return {"available": False, "reason": "Invalid HIBP response"}


def hibp_password(password: str) -> dict:
    """Check HIBP k-anonymity password API — sends only first 5 chars of SHA-1 hash."""
    import hashlib
    sha1 = hashlib.sha1(password.encode("utf-8")).hexdigest().upper()
    prefix, suffix = sha1[:5], sha1[5:]
    r = _get(f"https://api.pwnedpasswords.com/range/{prefix}", timeout=8)
    if not r or r.status_code != 200:
        return {"available": False, "reason": "HIBP password API unreachable"}
    for line in r.text.splitlines():
        h, _, count = line.partition(":")
        if h.strip() == suffix:
            return {"available": True, "pwned": True, "count": int(count.strip())}
    return {"available": True, "pwned": False, "count": 0}


