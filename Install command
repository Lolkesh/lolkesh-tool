def cross_reference(credentials: list) -> list:
    """Find credentials that appear across multiple hosts/services."""
    by_password = {}
    for cred in credentials:
        pw = cred.get("password") or cred.get("hash", "")
        if not pw:
            continue
        by_password.setdefault(pw, []).append(cred)
    return [
        {"password": pw, "found_on": hosts, "count": len(hosts)}
        for pw, hosts in by_password.items()
        if len(hosts) > 1
    ]
