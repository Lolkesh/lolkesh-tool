def get_credentials(scan_id: Optional[str] = None, host: Optional[str] = None) -> list:
    _init_creds_table()
    with closing(get_db()) as db:
        if scan_id:
            rows = db.execute("SELECT * FROM credentials WHERE scan_id=? ORDER BY created_at DESC", (scan_id,)).fetchall()
        elif host:
            rows = db.execute("SELECT * FROM credentials WHERE host=? ORDER BY created_at DESC", (host,)).fetchall()
        else:
            rows = db.execute("SELECT * FROM credentials ORDER BY created_at DESC LIMIT 500").fetchall()
    return [dict(r) for r in rows]


def get_valid_credentials() -> list:
    _init_creds_table()
    with closing(get_db()) as db:
