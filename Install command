def searchsploit(query: str) -> list:
if not shutil.which(“searchsploit”):
return []
try:
r = subprocess.run([“searchsploit”, “–json”, query],
capture_output=True, text=True, timeout=15)
data     = json.loads(r.stdout)
exploits = data.get(“RESULTS_EXPLOIT”, [])[:5]
return [{“title”: e.get(“Title”,””), “path”: e.get(“Path”,””),
“type”: e.get(“Type”,””), “edb_id”: e.get(“EDB-ID”,””)} for e in exploits]
except Exception:
return []

