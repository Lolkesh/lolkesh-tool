@app.task(name="scan_target", bind=True, max_retries=3)
def scan_target_task(self, scan_id: str, target: str, aggressive: bool = False) -> dict:
    try:
        with closing(get_db()) as db:
            db.execute("UPDATE scans SET status='RUNNING', progress=10 WHERE id=?", (scan_id,))
            db.commit()

        services, os_hint = scan_target(target, aggressive=aggressive)

