#!/usr/bin/env bash
set -euo pipefail

BASE="${HOME}/omni-sentinel-v21.3"
UI="${HOME}/omni-ui-v21.3"

log() {
  printf '\033[1;36m[%s]\033[0m %s\n' "$1" "$2"
}

warn() {
  printf '\033[1;33m[!]\033[0m %s\n' "$1"
}

mkdir -p "$BASE"/{core,plugins,dashboard,agents,output,scripts,screenshots}
mkdir -p "$UI/src"

log "OK" "Deploying Omni-Sentinel V21.3 scaffold"

if command -v sudo >/dev/null 2>&1; then
  sudo apt update
  sudo apt install -y \
    python3-pip python3-dev build-essential git \
    nodejs npm redis-server docker.io curl nmap openvpn \
    chromium-browser exploitdb gobuster feroxbuster seclists ffuf \
    libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
    libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 \
    libgbm1 libasound2 libpangocairo-1.0-0 libgtk-3-0
else
  warn "sudo is not available; skipping apt package installation"
fi

python3 -m pip install --upgrade pip
python3 -m pip install \
  fastapi uvicorn celery redis python-dotenv bcrypt PyJWT requests \
  python-nmap cryptography fpdf2 markdown2 schedule dnspython

# Generate secure credentials
SECRET_KEY=$(openssl rand -hex 32)
ADMIN_PASSWORD=$(openssl rand -hex 12)

