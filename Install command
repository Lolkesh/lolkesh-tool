import json
import logging
from contextlib import closing
from typing import Optional

from core.db_engine import get_db

logger = logging.getLogger(__name__)


def build_report_text(scan_id: str) -> Optional[str]:
    try:
        with closing(get_db()) as db:
            row = db.execute("SELECT * FROM scans WHERE id=?", (scan_id,)).fetchone()
            if not row:
                return None
            notes = db.execute(
                "SELECT content, author, created_at FROM notes WHERE scan_id=? ORDER BY created_at",
                (scan_id,),
            ).fetchall()
            timeline = db.execute(
                "SELECT event, detail, actor, created_at FROM timeline WHERE scan_id=? ORDER BY created_at",
                (scan_id,),
            ).fetchall()

        data = json.loads(row["data"] or "{}")
        services = data.get("services", {})
        cves = data.get("cves", {})

        lines = [
            "# Omni-Sentinel Scan Report",
            "",
            f"**Scan ID:** {row['id']}",
            f"**Target:** {row['target']}",
            f"**Status:** {row['status']}",
            f"**OS Hint:** {row['os_hint'] or 'Unknown'}",
            f"**Created:** {row['created_at']}",
            f"**Tags:** {row['tags'] or '[]'}",
            "",
            f"## Open Services ({len(services)} found)",
            "",
        ]

        for port, info in services.items():
            lines.append(
                f"### Port {port}/{info.get('proto', 'tcp')} — "
                f"{info.get('service', 'unknown')} {info.get('version', '')}"
            )
            port_cves = cves.get(port, [])
            if port_cves:
                lines.append(f"**CVEs:** {len(port_cves)} found")
                for cve in port_cves[:5]:
                    desc = (cve.get("description") or "")[:120]
                    lines.append(
                        f"  - {cve.get('id')} "
                        f"(CVSS: {cve.get('score')}, {cve.get('severity')}): {desc}"
                    )
            lines.append("")

        if notes:
            lines += ["## Analyst Notes", ""]
            for note in notes:
                lines.append(f"**{note['author']} @ {note['created_at']}:** {note['content']}")
                lines.append("")

        if timeline:
            lines += ["## Timeline", ""]
            for event in timeline:
                lines.append(
                    f"[{event['created_at']}] [{event['actor']}] "
                    f"{event['event']}: {event['detail']}"
                )

        return "\n".join(lines)
    except Exception as exc:
        logger.error(f"Failed to build report for {scan_id}: {exc}")
        return None
