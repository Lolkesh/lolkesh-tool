    # Deduplicate
    seen = set()
    unique = []
    for f in findings:
        key = f"{f['category']}:{f['value'][:50]}"
        if key not in seen:
            seen.add(key)
            unique.append(f)

    # Sort by severity
    sev_order = {"CRITICAL": 0, "HIGH": 1, "MEDIUM": 2, "LOW": 3, "INFO": 4}
    unique.sort(key=lambda x: sev_order.get(x["severity"], 5))

    summary = {
        "critical": sum(1 for f in unique if f["severity"] == "CRITICAL"),
        "high": sum(1 for f in unique if f["severity"] == "HIGH"),
        "medium": sum(1 for f in unique if f["severity"] == "MEDIUM"),
        "low": sum(1 for f in unique if f["severity"] == "LOW"),
        "info": sum(1 for f in unique if f["severity"] == "INFO"),
        "total": len(unique),
    }

    return {"findings": unique, "summary": summary}
