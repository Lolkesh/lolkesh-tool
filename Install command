def parse_linpeas(output: str) -> dict:
    if not output:
        return {"findings": [], "summary": {}, "error": "Empty output"}

    findings = []
    for key, pattern in PATTERNS.items():
        matches = pattern.findall(output)
        if matches:
            severity = SEVERITY_MAP.get(key, "INFO")
            for match in matches[:10]:  # cap per category
                value = match if isinstance(match, str) else str(match)
                findings.append({
                    "category": key,
                    "severity": severity,
                    "value": value.strip()[:300],
