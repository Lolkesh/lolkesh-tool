def get_wordlist(candidates: list) -> str:
    for path in candidates:
        if os.path.exists(path):
            return path
    return FALLBACK_WORDLIST


def detect_cms(url: str) -> Optional[str]:
    cms_paths = {
        "WordPress": ["/wp-login.php", "/wp-admin/", "/wp-content/"],
        "Joomla": ["/administrator/", "/components/", "/modules/"],
        "Drupal": ["/user/login", "/sites/default/", "/core/"],
    }
    for cms, paths in cms_paths.items():
        hits = 0
        for path in paths:
            try:
                response = requests.get(
                    url + path,
                    timeout=4,
                    allow_redirects=True,
                    verify=False,
                    headers={"User-Agent": "Mozilla/5.0"},
                )
                if response.status_code in (200, 301, 302, 403):
                    hits += 1
            except requests.RequestException:
                continue
        if hits >= 2:
            return cms
    return None


def suggest_wordlist(os_hint: str, cms: Optional[str] = None) -> str:
    cms_lists = {
        "WordPress": "/usr/share/seclists/Discovery/CMS/wordpress.fuzz.txt",
        "Joomla": "/usr/share/seclists/Discovery/CMS/joomla.txt",
        "Drupal": "/usr/share/seclists/Discovery/CMS/drupal.txt",
    }
    if cms and os.path.exists(cms_lists.get(cms, "")):
        return cms_lists[cms]
    hint = (os_hint or "").lower()
    if any(token in hint for token in ("windows", "iis", "microsoft")):
        return get_wordlist(WORDLISTS["iis"])
    return get_wordlist(WORDLISTS["common"])


def run_gobuster(scan_id: str, target: str, port: str, scheme: str, wordlist: str, db_update_fn: Callable) -> None:
    tool = shutil.which("gobuster") or shutil.which("feroxbuster")
    if not tool:
        logger.warning("gobuster or feroxbuster not found")
        return
    url = f"{scheme}://{target}:{port}"
    if "feroxbuster" in tool:
        cmd = [tool, "--url", url, "--wordlist", wordlist, "--threads", "20", "--quiet", "--no-state"]
    else:
        cmd = [tool, "dir", "-u", url, "-w", wordlist, "-t", "20", "--no-error", "-q", "-o", "-"]
    try:
        proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, text=True)
        results = []
        assert proc.stdout is not None
        for line in proc.stdout:
            line = line.strip()
            if line and not line.startswith("#"):
                results.append(line)
                if len(results) % 10 == 0:
                    db_update_fn(scan_id, port, results[:])
        proc.wait(timeout=300)
        db_update_fn(scan_id, port, results)
    except subprocess.TimeoutExpired:
        proc.kill()
        logger.error(f"Gobuster timeout for {url}")
    except Exception as exc:
        logger.error(f"Gobuster failed for {url}: {exc}")


def run_subdomain_enum(scan_id: str, target: str, db_update_fn: Callable) -> None:
    gobuster = shutil.which("gobuster")
    if not gobuster:
        return
    wordlist = get_wordlist(SUBDOMAIN_WORDLISTS)
    results = []
    try:
        proc = subprocess.Popen(
            [gobuster, "dns", "-d", target, "-w", wordlist, "-t", "20", "-q", "--no-error"],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        assert proc.stdout is not None
        for line in proc.stdout:
            line = line.strip()
            if line and "Found:" in line:
                results.append({"type": "dns", "value": line.replace("Found:", "").strip()})
        proc.wait(timeout=300)
    except subprocess.TimeoutExpired:
        proc.kill()
        logger.error(f"Subdomain enum timeout for {target}")
    except Exception as exc:
        logger.error(f"Subdomain enum failed for {target}: {exc}")
    db_update_fn(scan_id, "subdomains", results)


def launch_gobuster_async(scan_id: str, target: str, services: dict, os_hint: str, db_update_fn: Callable) -> None:
    for port, info in services.items():
        service = info.get("service", "").lower()
        is_web = "http" in service or port in {"80", "443", "8080", "8443", "8000", "8888"}
        if not is_web:
            continue
        scheme = "https" if "ssl" in service or port in {"443", "8443"} else "http"
        cms = detect_cms(f"{scheme}://{target}:{port}")
        wordlist = suggest_wordlist(os_hint, cms=cms)
        thread = threading.Thread(
            target=run_gobuster,
            args=(scan_id, target, port, scheme, wordlist, db_update_fn),
            daemon=False,
            name=f"gobuster-{scan_id}-{port}",
        )
        thread.start()


def launch_subdomain_enum_async(scan_id: str, target: str, db_update_fn: Callable) -> None:
    threading.Thread(
        target=run_subdomain_enum,
        args=(scan_id, target, db_update_fn),
        daemon=False,
        name=f"subdomain-{scan_id}",
    ).start()
