                    lines.append(
                        f"  - {cve.get('id')} "
                        f"(CVSS: {cve.get('score')}, {cve.get('severity')}): {desc}"
                    )
            lines.append("")

        if notes:
            lines += ["## Analyst Notes", ""]
            for note in notes:
                lines.append(f"**{note['author']} @ {note['created_at']}:** {note['content']}")
