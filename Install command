// ── Tag bar  (feature #9) ────────────────────────────────────────
function TagBar({ scanId, currentTags }) {
const [tags, setTags] = useState(currentTags || []);

const toggle = async (tag) => {
const next = tags.includes(tag) ? tags.filter(t=>t!==tag) : […tags, tag];
setTags(next);
await fetch(`${API}/api/scan/${scanId}/tags`, {
method:‘PUT’, headers: authH(), body: JSON.stringify({ tags: next })
});
};

return (
<div style={{ display:‘flex’, gap:4, flexWrap:‘wrap’, marginTop:6 }}>
{TAGS.map(t => (
<button key={t} onClick={()=>toggle(t)}
style={{ background: tags.includes(t) ? TAG_COLORS[t]||’#333’ : ‘#0d0d0d’,
color: tags.includes(t)?’#000’:’#333’,
border:‘1px solid’, borderColor: tags.includes(t)?TAG_COLORS[t]||’#333’:’#1a1a1a’,
padding:‘2px 8px’, borderRadius:10, fontSize:10,
cursor:‘pointer’, fontFamily:‘monospace’ }}>
{t}
</button>
))}
</div>
);
}

