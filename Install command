        with closing(get_db()) as db:
            db.execute(
                "UPDATE scans SET status='COMPLETE', progress=100, data=?, os_hint=? WHERE id=?",
                (data, os_hint, scan_id),
            )
            db.commit()

        log_event(scan_id, "scan_complete", f"Discovered {len(services)} open service(s)")
        webhook_url = _get_webhook_url()
        if webhook_url:
            send_webhook(webhook_url, {
                "event": "scan_complete",
                "scan_id": scan_id,
                "target": target,
                "services_found": len(services),
                "critical_cves": critical_count,
                "text": f"Scan complete for {target}: {len(services)} service(s), {critical_count} critical CVE(s).",
            })

        return {"services": services, "os_hint": os_hint}
    except Exception as exc:
        logger.error(f"Scan failed for {target}: {exc}")
        log_event(scan_id, "scan_failed", str(exc), actor="system")
        try:
