@app.post(”/api/login”)
def login(req: LoginReq):
db = get_db()
try:
row = db.execute(“SELECT password,role FROM users WHERE username=?”,
(req.username,)).fetchone()
finally:
db.close()
if not row or not verify_password(req.password, row[“password”]):
raise HTTPException(status_code=401, detail=“Bad credentials”)
return {“token”: create_token(req.username, row[“role”]), “role”: row[“role”]}

