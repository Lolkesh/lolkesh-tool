if not is_web:
continue
scheme  = “https” if “ssl” in svc or port in (“443”,“8443”) else “http”
url     = f”{scheme}://{target}:{port}”
cms     = detect_cms(url)
wordlist = suggest_wordlist(os_hint, cms=cms)
t = threading.Thread(
target=run_gobuster,
args=(scan_id, target, port, scheme, wordlist, db_update_fn),
daemon=True
)
t.start()

