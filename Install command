return fname if os.path.exists(outpath) else None
except Exception:
return None

def screenshot_http_ports(scan_id: str, services: dict) -> list:
results = []
for port, info in services.items():
svc = info.get(“service”, “”).lower()
if “http” in svc or port in (“80”,“443”,“8080”,“8443”,“8000”,“8888”):
scheme = “https” if “ssl” in svc or “https” in svc or port in (“443”,“8443”) else “http”
url    = f”{scheme}://{info.get(’_target’,‘target’)}:{port}”
path   = take_screenshot(scan_id, port, url)
if path:
results.append({“port”: port, “url”: url, “path”: path})
return results
