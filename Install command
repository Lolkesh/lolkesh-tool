  page: { background: "#0f172a", minHeight: "100vh", color: "#e2e8f0", fontFamily: "system-ui, sans-serif" },
  nav: { background: "#1e293b", padding: "0 24px", display: "flex", alignItems: "center", gap: 8, height: 52, borderBottom: "1px solid #334155" },
  main: { padding: 24, maxWidth: 1200, margin: "0 auto" },
  card: { background: "#1e293b", padding: 16, borderRadius: 8 },
  input: { display: "block", width: "100%", marginBottom: 10, padding: "8px 12px", background: "#0f172a", color: "#e2e8f0", border: "1px solid #334155", borderRadius: 6, fontSize: 14, boxSizing: "border-box" },
  btn: { padding: "8px 16px", background: "#3b82f6", color: "#fff", border: "none", borderRadius: 6, cursor: "pointer", fontSize: 14 },
  label: { display: "block", marginBottom: 4, color: "#94a3b8", fontSize: 13 },
  table: { width: "100%", borderCollapse: "collapse", fontSize: 13 },
  th: { textAlign: "left", padding: "8px 12px", borderBottom: "1px solid #334155", color: "#94a3b8", fontWeight: 600 },
  td: { padding: "8px 12px", borderBottom: "1px solid #1e293b", verticalAlign: "middle" },
  tag: { display: "inline-block", background: "#1e3a5f", color: "#38bdf8", padding: "2px 8px", borderRadius: 12, fontSize: 11, marginRight: 4 },
  tabBtn: { padding: "6px 14px", background: "none", color: "#94a3b8", border: "none", cursor: "pointer", borderBottom: "2px solid transparent", fontSize: 13 },
  tabActive: { color: "#38bdf8", borderBottom: "2px solid #38bdf8" },
  center: { display: "flex", justifyContent: "center", alignItems: "center", minHeight: "80vh" },
};

const statusColor = (s) => ({ COMPLETE: "#22c55e", RUNNING: "#f59e0b", PENDING: "#94a3b8", FAILED: "#ef4444" }[s] || "#94a3b8");
const parseTags = (raw) => { try { return JSON.parse(raw || "[]"); } catch { return []; } };

// ── Login ─────────────────────────────────────────────────────────────────────
function Login({ onLogin }) {
  const [username, setUsername] = useState("");
  const [password, setPassword] = useState("");
  const [role, setRole] = useState("admin");
  const [error, setError] = useState("");

  const submit = async (e) => {
    e.preventDefault();
    try {
      const { data } = await axios.post("/api/auth/token", { username, password, role });
      onLogin(data.access_token);
    } catch {
      setError("Login failed — check credentials");
    }
  };

  return (
    <div style={S.center}>
      <div style={{ ...S.card, width: 340 }}>
        <h2 style={{ margin: "0 0 20px", color: "#38bdf8" }}>Omni-Sentinel V21.3</h2>
        <form onSubmit={submit}>
          <label style={S.label}>Username</label>
          <input style={S.input} placeholder="Username" value={username} onChange={e => setUsername(e.target.value)} required />
          <label style={S.label}>Password</label>
          <input style={S.input} type="password" placeholder="Password" value={password} onChange={e => setPassword(e.target.value)} required />
          <label style={S.label}>Role</label>
          <select style={S.input} value={role} onChange={e => setRole(e.target.value)}>
            <option value="admin">Admin</option>
            <option value="viewer">Viewer</option>
          </select>
          {error && <p style={{ color: "#ef4444", margin: "0 0 10px" }}>{error}</p>}
          <button style={{ ...S.btn, width: "100%" }} type="submit">Login</button>
        </form>
      </div>
    </div>
  );
}

// ── Scan List ─────────────────────────────────────────────────────────────────
function ScanList({ api, onSelect, onNewScan }) {
  const [scans, setScans] = useState([]);
  const [tagFilter, setTagFilter] = useState("");
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState("");

  const load = useCallback(async () => {
    try {
      setLoading(true);
      const params = tagFilter ? { tag: tagFilter } : {};
      const { data } = await api.get("/scans", { params });
      setScans(data.scans || []);
      setError("");
    } catch (e) {
      setError(`Failed to load: ${e.message}`);
    } finally {
      setLoading(false);
    }
  }, [api, tagFilter]);

  useEffect(() => { load(); }, [load]);

  return (
    <div>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 16, flexWrap: "wrap", gap: 8 }}>
        <h2 style={{ margin: 0 }}>Scan History</h2>
        <div style={{ display: "flex", gap: 8 }}>
          <input style={{ ...S.input, width: 160, margin: 0 }} placeholder="Filter by tag..." value={tagFilter} onChange={e => setTagFilter(e.target.value)} />
          <button style={S.btn} onClick={load}>Refresh</button>
          <button style={{ ...S.btn, background: "#6366f1" }} onClick={onNewScan}>+ New Scan</button>
        </div>
      </div>
      {error && <p style={{ color: "#ef4444" }}>{error}</p>}
      {loading ? <p style={{ color: "#64748b" }}>Loading...</p> : (
        <table style={S.table}>
          <thead>
            <tr>{["Target", "Status", "Progress", "OS", "Tags", "Created", ""].map(h => <th key={h} style={S.th}>{h}</th>)}</tr>
          </thead>
          <tbody>
            {scans.length === 0 && <tr><td colSpan={7} style={{ padding: 24, textAlign: "center", color: "#64748b" }}>No scans yet — start one above</td></tr>}
            {scans.map(s => {
              const tags = parseTags(s.tags);
              return (
                <tr key={s.id} style={{ cursor: "pointer" }} onClick={() => onSelect(s.id)}>
                  <td style={S.td}><code style={{ color: "#38bdf8" }}>{s.target}</code></td>
                  <td style={S.td}><span style={{ color: statusColor(s.status), fontWeight: 600 }}>{s.status}</span></td>
                  <td style={S.td}>{s.progress}%</td>
                  <td style={S.td}>{s.os_hint || "—"}</td>
                  <td style={S.td}>{tags.map(t => <span key={t} style={S.tag}>{t}</span>)}</td>
                  <td style={S.td}>{s.created_at}</td>
                  <td style={S.td}><button style={{ ...S.btn, padding: "4px 10px", fontSize: 12 }} onClick={e => { e.stopPropagation(); onSelect(s.id); }}>View</button></td>
                </tr>
              );
            })}
          </tbody>
        </table>
      )}
    </div>
  );
}

// ── New Scan ──────────────────────────────────────────────────────────────────
function NewScan({ api, onBack, onCreated }) {
  const [target, setTarget] = useState("");
  const [aggressive, setAggressive] = useState(false);
  const [tags, setTags] = useState("");
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");

  const submit = async (e) => {
    e.preventDefault();
    try {
      setLoading(true);
      const tagList = tags.split(",").map(t => t.trim()).filter(Boolean);
      const { data } = await api.post("/scans", { target, aggressive, tags: tagList });
      onCreated(data.scan_id);
    } catch (ex) {
      setError(ex.response?.data?.detail || ex.message);
    } finally {
      setLoading(false);
    }
  };

  return (
    <div>
      <button style={{ ...S.btn, background: "none", color: "#94a3b8", padding: "4px 0", marginBottom: 16 }} onClick={onBack}>← Back</button>
      <h2>New Scan</h2>
      <form onSubmit={submit} style={{ maxWidth: 480 }}>
        <label style={S.label}>Target (IP or hostname)</label>
        <input style={S.input} placeholder="192.168.1.1 or example.com" value={target} onChange={e => setTarget(e.target.value)} required />
        <label style={S.label}>Tags (comma-separated, optional)</label>
        <input style={S.input} placeholder="internal, web, critical" value={tags} onChange={e => setTags(e.target.value)} />
        <label style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 16, color: "#e2e8f0", cursor: "pointer" }}>
          <input type="checkbox" checked={aggressive} onChange={e => setAggressive(e.target.checked)} />
          Aggressive mode (-A flag, requires root)
        </label>
        {error && <p style={{ color: "#ef4444" }}>{error}</p>}
        <button style={S.btn} type="submit" disabled={loading}>{loading ? "Starting..." : "Start Scan"}</button>
      </form>
    </div>
  );
}

// ── Scan Detail ───────────────────────────────────────────────────────────────
function ScanDetail({ api, scanId, onBack }) {
  const [scan, setScan] = useState(null);
  const [tab, setTab] = useState("overview");
  const [timeline, setTimeline] = useState([]);
  const [ssl, setSsl] = useState(null);
  const [sslPort, setSslPort] = useState(443);
  const [dns, setDns] = useState(null);
  const [diff, setDiff] = useState(null);
  const [note, setNote] = useState("");
  const [tagInput, setTagInput] = useState("");
  const [loading, setLoading] = useState(true);
  const [msg, setMsg] = useState({ text: "", ok: true });

  const flash = (text, ok = true) => { setMsg({ text, ok }); setTimeout(() => setMsg({ text: "", ok: true }), 3000); };

  const load = useCallback(async () => {
    try {
      const { data } = await api.get(`/scans/${scanId}`);
      setScan(data);
      setTagInput(Array.isArray(data.tags) ? data.tags.join(", ") : "");
    } catch (e) {
      flash(`Error: ${e.message}`, false);
    } finally {
      setLoading(false);
    }
  }, [api, scanId]);

  useEffect(() => { load(); }, [load]);

  const loadTimeline = async () => {
    try {
      const { data } = await api.get(`/scans/${scanId}/timeline`);
      setTimeline(data.events || []);
    } catch (e) { flash(`Timeline error: ${e.message}`, false); }
  };

  const runSsl = async () => {
    try {
      flash("Running SSL inspection...");
      const { data } = await api.post(`/scans/${scanId}/ssl`, { port: sslPort });
      setSsl(data);
      flash("SSL inspection complete");
    } catch (e) { flash(`SSL error: ${e.response?.data?.detail || e.message}`, false); }
  };

  const runDns = async () => {
    try {
      flash("Running DNS enumeration...");
      const { data } = await api.post(`/scans/${scanId}/dns`);
      setDns(data);
      flash(`DNS enumeration complete — ${data.total} record(s) found`);
    } catch (e) { flash(`DNS error: ${e.response?.data?.detail || e.message}`, false); }
  };

  const runDiff = async () => {
    try {
      flash("Calculating diff...");
      const { data } = await api.get(`/scans/${scanId}/diff`);
      setDiff(data);
      flash(data.error ? data.error : "Diff complete");
    } catch (e) { flash(`Diff error: ${e.message}`, false); }
  };

  const addNote = async () => {
    if (!note.trim()) return;
    try {
      await api.post(`/scans/${scanId}/notes`, { content: note });
      setNote("");
      load();
    } catch (e) { flash(`Note error: ${e.message}`, false); }
  };

  const saveTags = async () => {
    const tagList = tagInput.split(",").map(t => t.trim()).filter(Boolean);
    try {
      await api.put(`/scans/${scanId}/tags`, { tags: tagList });
      flash("Tags saved");
    } catch (e) { flash(`Tag error: ${e.message}`, false); }
  };

  const downloadReport = async (fmt) => {
    try {
      const resp = await api.post(`/scans/${scanId}/report?fmt=${fmt}`, {}, { responseType: "blob" });
      const url = URL.createObjectURL(resp.data);
      const a = document.createElement("a");
      a.href = url;
      a.download = `report-${scanId.slice(0, 8)}.${fmt}`;
      a.click();
      URL.revokeObjectURL(url);
    } catch (e) { flash(`Report error: ${e.message}`, false); }
  };

  if (loading) return <p style={{ color: "#64748b" }}>Loading...</p>;
  if (!scan) return <p style={{ color: "#ef4444" }}>Scan not found.</p>;

  const services = scan.data?.services || {};
  const cves = scan.data?.cves || {};
  const TABS = ["overview", "timeline", "ssl", "dns", "diff", "notes"];

  return (
    <div>
      <button style={{ ...S.btn, background: "none", color: "#94a3b8", padding: "4px 0", marginBottom: 16 }} onClick={onBack}>← Back to List</button>
      <div style={{ display: "flex", justifyContent: "space-between", flexWrap: "wrap", gap: 8, marginBottom: 12 }}>
        <h2 style={{ margin: 0 }}><code style={{ color: "#38bdf8" }}>{scan.target}</code></h2>
        <div style={{ display: "flex", gap: 8 }}>
          <button style={{ ...S.btn, background: "#0f766e" }} onClick={() => downloadReport("pdf")}>Download PDF</button>
          <button style={{ ...S.btn, background: "#1e40af" }} onClick={() => downloadReport("markdown")}>Download MD</button>
        </div>
      </div>
      <div style={{ display: "flex", gap: 20, marginBottom: 16, flexWrap: "wrap", fontSize: 13 }}>
        <span>Status: <strong style={{ color: statusColor(scan.status) }}>{scan.status}</strong></span>
        <span>Progress: {scan.progress}%</span>
        <span>OS: {scan.os_hint || "Unknown"}</span>
        <span>Created: {scan.created_at}</span>
        <span>By: {scan.created_by}</span>
      </div>
      <div style={{ display: "flex", gap: 8, marginBottom: 16, alignItems: "center" }}>
        <input style={{ ...S.input, flex: 1, maxWidth: 360, margin: 0 }} placeholder="Tags (comma-separated)" value={tagInput} onChange={e => setTagInput(e.target.value)} />
        <button style={{ ...S.btn, padding: "8px 12px" }} onClick={saveTags}>Save Tags</button>
      </div>
      {msg.text && <p style={{ color: msg.ok ? "#22c55e" : "#ef4444", marginBottom: 12 }}>{msg.text}</p>}

      <div style={{ display: "flex", gap: 2, marginBottom: 16, borderBottom: "1px solid #334155" }}>
        {TABS.map(t => (
          <button key={t} onClick={() => { setTab(t); if (t === "timeline") loadTimeline(); }}
            style={{ ...S.tabBtn, ...(tab === t ? S.tabActive : {}) }}>
            {t.charAt(0).toUpperCase() + t.slice(1)}
          </button>
        ))}
      </div>

      {tab === "overview" && (
        <div>
          <h3 style={{ marginTop: 0 }}>Open Services ({Object.keys(services).length})</h3>
          {Object.keys(services).length === 0 && <p style={{ color: "#64748b" }}>No services found yet — scan may still be running</p>}
          {Object.entries(services).map(([port, info]) => {
            const portCves = cves[port] || [];
            const hasCrit = portCves.some(c => c.severity === "CRITICAL");
            return (
              <div key={port} style={{ ...S.card, marginBottom: 10, borderLeft: `3px solid ${hasCrit ? "#ef4444" : "#334155"}` }}>
                <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                  <strong style={{ color: "#38bdf8" }}>:{port}/{info.proto || "tcp"} — {info.service} {info.product} {info.version}</strong>
                  {portCves.length > 0 && <span style={{ color: hasCrit ? "#ef4444" : "#f59e0b", fontSize: 13 }}>{portCves.length} CVE(s)</span>}
                </div>
                {portCves.map(cve => (
                  <div key={cve.id} style={{ marginTop: 6, fontSize: 12, padding: "4px 8px", background: "#0f172a", borderRadius: 4 }}>
                    <strong style={{ color: cve.severity === "CRITICAL" ? "#ef4444" : cve.severity === "HIGH" ? "#f59e0b" : "#94a3b8" }}>{cve.id}</strong>
                    {" "}(CVSS: {cve.score}, {cve.severity}): {cve.description?.slice(0, 150)}
                  </div>
                ))}
              </div>
            );
          })}
        </div>
      )}

      {tab === "timeline" && (
        <div>
          <h3 style={{ marginTop: 0 }}>Timeline</h3>
          {timeline.length === 0 && <p style={{ color: "#64748b" }}>Loading events...</p>}
          {timeline.map((e, i) => (
            <div key={i} style={{ display: "flex", gap: 12, marginBottom: 8, fontSize: 13 }}>
              <span style={{ color: "#64748b", flexShrink: 0, minWidth: 160 }}>{e.created_at}</span>
              <span style={{ color: "#94a3b8", flexShrink: 0 }}>[{e.actor}]</span>
              <span><strong style={{ color: "#38bdf8" }}>{e.event}</strong>{e.detail ? `: ${e.detail}` : ""}</span>
            </div>
          ))}
        </div>
      )}

      {tab === "ssl" && (
        <div>
          <h3 style={{ marginTop: 0 }}>SSL/TLS Inspector</h3>
          <div style={{ display: "flex", gap: 8, marginBottom: 16, alignItems: "center" }}>
            <input type="number" style={{ ...S.input, width: 100, margin: 0 }} value={sslPort} onChange={e => setSslPort(Number(e.target.value))} placeholder="Port" />
            <button style={S.btn} onClick={runSsl}>Inspect</button>
          </div>
          {ssl && (
            <div style={S.card}>
              <p style={{ margin: "0 0 8px" }}>Reachable: <strong style={{ color: ssl.reachable ? "#22c55e" : "#ef4444" }}>{ssl.reachable ? "Yes" : "No"}</strong></p>
              {ssl.error && <p style={{ color: "#ef4444" }}>Error: {ssl.error}</p>}
              {ssl.reachable && (
                <>
                  <p style={{ margin: "0 0 6px" }}>Protocol: <code>{ssl.protocol}</code></p>
                  <p style={{ margin: "0 0 6px" }}>Cipher: <code style={{ color: ssl.weak_cipher ? "#ef4444" : "#22c55e" }}>{ssl.cipher}{ssl.weak_cipher ? " ⚠ WEAK" : ""}</code></p>
                  <p style={{ margin: "0 0 6px" }}>Expires: {ssl.not_after} — <strong style={{ color: ssl.expired ? "#ef4444" : ssl.days_remaining < 30 ? "#f59e0b" : "#22c55e" }}>{ssl.days_remaining} days remaining</strong></p>
                  <p style={{ margin: "0 0 6px" }}>Subject: {ssl.subject?.commonName || JSON.stringify(ssl.subject)}</p>
                  <p style={{ margin: "0 0 6px" }}>Issuer: {ssl.issuer?.organizationName || JSON.stringify(ssl.issuer)}</p>
                  {ssl.san?.length > 0 && <p style={{ margin: 0 }}>SANs: {ssl.san.join(", ")}</p>}
                </>
              )}
            </div>
          )}
        </div>
      )}

      {tab === "dns" && (
        <div>
          <h3 style={{ marginTop: 0 }}>DNS Enumeration</h3>
          <button style={S.btn} onClick={runDns}>Run DNS Enum</button>
          {dns && (
            <div style={{ marginTop: 16 }}>
              <p style={{ color: "#94a3b8" }}>Domain: <code style={{ color: "#38bdf8" }}>{dns.domain}</code> — {dns.total} record(s) found</p>
              {dns.zone_transfer?.length > 0 && (
                <>
                  <h4 style={{ color: "#f59e0b" }}>Zone Transfer Results</h4>
                  {dns.zone_transfer.map((r, i) => <div key={i} style={{ fontSize: 13, color: "#f59e0b", marginBottom: 4 }}>{r.value}</div>)}
                </>
              )}
              {dns.subdomains?.length > 0 && (
                <>
                  <h4>Subdomains</h4>
                  {dns.subdomains.map((r, i) => (
                    <div key={i} style={{ fontSize: 13, marginBottom: 6 }}>
                      <code style={{ color: "#38bdf8" }}>{r.subdomain}</code> <span style={{ color: "#64748b" }}>→ {r.ips?.join(", ")}</span>
                    </div>
                  ))}
                </>
              )}
              {dns.total === 0 && <p style={{ color: "#64748b" }}>No DNS records found</p>}
            </div>
          )}
        </div>
      )}

      {tab === "diff" && (
        <div>
          <h3 style={{ marginTop: 0 }}>Scan Diff</h3>
          <p style={{ color: "#64748b", fontSize: 13 }}>Compares this scan to the previous scan of the same target</p>
          <button style={S.btn} onClick={runDiff}>Calculate Diff</button>
          {diff && !diff.error && (
            <div style={{ marginTop: 16 }}>
              <div style={{ display: "flex", gap: 12, marginBottom: 16, flexWrap: "wrap" }}>
                {[["New", diff.summary?.new, "#22c55e"], ["Closed", diff.summary?.closed, "#ef4444"], ["Changed", diff.summary?.changed, "#f59e0b"], ["Unchanged", diff.summary?.unchanged, "#64748b"]].map(([label, count, color]) => (
                  <div key={label} style={{ ...S.card, textAlign: "center", minWidth: 90 }}>
                    <div style={{ fontSize: 28, fontWeight: 700, color }}>{count}</div>
                    <div style={{ fontSize: 12, color: "#94a3b8" }}>{label}</div>
                  </div>
                ))}
              </div>
              {Object.entries(diff.new_ports || {}).map(([port, info]) => (
                <div key={port} style={{ ...S.card, marginBottom: 8, borderLeft: "3px solid #22c55e" }}>
                  <strong style={{ color: "#22c55e" }}>+ NEW :{port} — {info.service} {info.version}</strong>
                </div>
              ))}
              {Object.entries(diff.closed_ports || {}).map(([port, info]) => (
                <div key={port} style={{ ...S.card, marginBottom: 8, borderLeft: "3px solid #ef4444" }}>
                  <strong style={{ color: "#ef4444" }}>- CLOSED :{port} — {info.service} {info.version}</strong>
                </div>
              ))}
              {Object.entries(diff.changed_services || {}).map(([port, changes]) => (
                <div key={port} style={{ ...S.card, marginBottom: 8, borderLeft: "3px solid #f59e0b" }}>
                  <strong style={{ color: "#f59e0b" }}>~ CHANGED :{port}</strong>
                  {Object.entries(changes).map(([field, { before, after }]) => (
                    <div key={field} style={{ fontSize: 13, marginTop: 4 }}>
                      {field}: <span style={{ color: "#ef4444" }}>{before || "—"}</span> → <span style={{ color: "#22c55e" }}>{after || "—"}</span>
                    </div>
                  ))}
                </div>
              ))}
              <p style={{ color: "#64748b", fontSize: 12, marginTop: 8 }}>Baseline scan ID: {diff.baseline_id}</p>
            </div>
          )}
          {diff?.error && <p style={{ color: "#ef4444", marginTop: 12 }}>{diff.error}</p>}
        </div>
      )}

      {tab === "notes" && (
        <div>
          <h3 style={{ marginTop: 0 }}>Analyst Notes</h3>
          {(scan.notes || []).length === 0 && <p style={{ color: "#64748b" }}>No notes yet</p>}
          {(scan.notes || []).map(n => (
            <div key={n.id} style={{ ...S.card, marginBottom: 8 }}>
              <div style={{ fontSize: 12, color: "#64748b", marginBottom: 4 }}>{n.author} @ {n.created_at}</div>
              <div>{n.content}</div>
            </div>
          ))}
          <div style={{ display: "flex", gap: 8, marginTop: 16 }}>
            <textarea style={{ ...S.input, flex: 1, height: 80, resize: "vertical", fontFamily: "inherit", margin: 0 }} placeholder="Add a note..." value={note} onChange={e => setNote(e.target.value)} />
            <button style={{ ...S.btn, alignSelf: "flex-end" }} onClick={addNote}>Add</button>
          </div>
        </div>
      )}
    </div>
  );
}

// ── Settings ──────────────────────────────────────────────────────────────────
function Settings({ api, onBack }) {
  const [webhookUrl, setWebhookUrl] = useState("");
  const [msg, setMsg] = useState("");

  useEffect(() => {
    api.get("/settings/webhook").then(({ data }) => setWebhookUrl(data.webhook_url || "")).catch(() => {});
  }, [api]);

  const save = async () => {
    try {
      await api.put("/settings/webhook", { url: webhookUrl });
      setMsg("Saved");
      setTimeout(() => setMsg(""), 2000);
    } catch (e) { setMsg(`Error: ${e.message}`); }
  };

  return (
    <div>
      <button style={{ ...S.btn, background: "none", color: "#94a3b8", padding: "4px 0", marginBottom: 16 }} onClick={onBack}>← Back</button>
      <h2>Settings</h2>
      <h3 style={{ color: "#94a3b8", fontWeight: 500 }}>Webhook Notifications</h3>
