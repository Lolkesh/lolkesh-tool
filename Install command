    image: image_name
    container_name: service1_container
    ports:
      - '8080:80'
  service2:
    build:
      context: .
      dockerfile: Dockerfile
    depends_on:
      - service1
"
echo "$yml_content" > docker-compose.yml

# Dockerfile configurations with health checks
cat << EOF > Dockerfile
