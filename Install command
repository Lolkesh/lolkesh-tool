import logging
from typing import Tuple

import nmap

logger = logging.getLogger(__name__)


def detect_os(nm_result, host: str) -> str:
    try:
        osmatches = nm_result[host].get("osmatch", [])
        if osmatches:
            return osmatches[0].get("name", "")
    except (KeyError, AttributeError, IndexError):
        return ""
    return ""


def scan_target(target: str, aggressive: bool = False, concurrent: int = 1) -> Tuple[dict, str]:
    try:
        nm = nmap.PortScanner()
        timing = "-T3" if concurrent > 1 else "-T4"
        # Avoid -O if non-root; add --privileged flag handling
        os_detection = "-O" if os.geteuid() == 0 else ""
        args = f"-A --open {timing} {os_detection}".strip() if aggressive else f"-sV -sC {timing}".strip()
        
        nm.scan(target, arguments=args)
        services = {}
        os_hint = ""
        for host in nm.all_hosts():
            os_hint = detect_os(nm, host)
            for proto in nm[host].all_protocols():
                for port in nm[host][proto]:
                    info = nm[host][proto][port]
                    if info.get("state") == "open":
                        services[str(port)] = {
                            "_target": target,
                            "service": info.get("name", "unknown"),
                            "version": info.get("version", ""),
                            "product": info.get("product", ""),
                            "proto": proto,
                            "scripts": info.get("script", {}),
                        }
        return services, os_hint
    except nmap.PortScannerError as exc:
        logger.error(f"Nmap scan failed for {target}: {exc}")
        return {}, ""
    except Exception as exc:
        logger.error(f"Unexpected error scanning {target}: {exc}")
        return {}, ""


import os
