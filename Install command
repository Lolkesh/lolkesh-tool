    patterns = [
        f"{f}.{l}@{domain}",
        f"{f}{l}@{domain}",
        f"{fi}{l}@{domain}",
        f"{f}{li}@{domain}",
        f"{f}_{l}@{domain}",
        f"{l}.{f}@{domain}",
