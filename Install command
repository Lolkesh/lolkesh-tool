            candidates.append({
                "type": name,
                "hashcat": hashcat_cmd,
                "john": JOHN_MAP.get(name.split("_")[0], "--format=auto"),
                "length": len(hash_str),
            })

    if not candidates:
        candidates.append({
            "type": "unknown",
            "hashcat": "Try hashcat --help for formats",
            "john": "--format=auto",
            "length": len(hash_str),
        })

    return {
        "hash": hash_str[:64] + ("..." if len(hash_str) > 64 else ""),
        "candidates": candidates,
        "most_likely": candidates[0]["type"] if candidates else "unknown",
        "crack_suggestions": {
            "hashcat": candidates[0]["hashcat"] if candidates else "",
            "john": candidates[0]["john"] if candidates else "",
            "wordlist": "rockyou.txt",
            "wordlist_path": "/usr/share/wordlists/rockyou.txt",
        },
    }


def identify_hashes_bulk(hashes: list[str]) -> list:
    return [identify_hash(h) for h in hashes if h.strip()]
