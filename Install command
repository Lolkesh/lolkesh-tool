    if password.lower() in COMMON_PASSWORDS_SET:
        weaknesses.append("In common password list")

    for pattern, label in WEAK_PATTERNS:
        if pattern.search(password):
            weaknesses.append(label)

    entropy = _check_entropy(password)

    return {
        "password": password[:4] + "***" if len(password) > 4 else "***",
        "length": len(password),
        "weaknesses": list(set(weaknesses)),
        "is_weak": len(weaknesses) > 0 or entropy["strength"] == "WEAK",
        "entropy": entropy,
        "risk": "CRITICAL" if password.lower() in COMMON_PASSWORDS_SET else
                "HIGH" if len(weaknesses) > 2 else
                "MEDIUM" if weaknesses else "LOW",
    }


def analyze_credential_list(credentials: list) -> dict:
    results = []
    weak_count = 0
    for cred in credentials:
        pw = cred.get("password", "")
        if not pw:
            continue
        analysis = analyze_password(pw)
        analysis["username"] = cred.get("username", "")
        analysis["host"] = cred.get("host", "")
        if analysis["is_weak"]:
            weak_count += 1
        results.append(analysis)

    return {
        "total_analyzed": len(results),
        "weak_count": weak_count,
        "weak_percentage": round(weak_count / len(results) * 100, 1) if results else 0,
        "results": results,
    }
