@app.post(”/api/scan”)
def start_scan(req: ScanReq, user=Depends(verify_token)):
target = req.target.strip()
if not target:
raise HTTPException(status_code=400, detail=“Target required”)
db = get_db()
try:
active = db.execute(
“SELECT COUNT(*) FROM scans WHERE status IN (‘PENDING’,‘SCANNING’,‘QUEUED’)”
).fetchone()[0]
if active >= MAX_SCANS:
raise HTTPException(status_code=429,
detail=f”Too many active scans ({active}/{MAX_SCANS})”)
scan_id = str(uuid.uuid4())[:8]
db.execute(“INSERT INTO scans (id,target,status,created_by) VALUES (?,?,‘PENDING’,?)”,
(scan_id, target, user[“username”]))
db.commit()
finally:
db.close()
task = run_scan.delay(scan_id, target, req.aggressive)
return {“scan_id”: scan_id, “task_id”: task.id}

@app.delete(”/api/scan/{scan_id}”)
def delete_scan(scan_id: str, _=Depends(verify_token)):
db = get_db()
try:
row = db.execute(“SELECT task_id FROM scans WHERE id=?”, (scan_id,)).fetchone()
if row and row[“task_id”]:
celery_app.control.revoke(row[“task_id”], terminate=True, signal=“SIGTERM”)
db.execute(“DELETE FROM scans WHERE id=?”, (scan_id,))
db.commit()
finally:
db.close()
return {“deleted”: scan_id}

