import logging
import socket
import ssl
from datetime import datetime, timezone
from typing import Optional

logger = logging.getLogger(__name__)

WEAK_CIPHERS = {"RC4", "DES", "3DES", "MD5", "NULL", "EXPORT", "ANON"}


def _is_weak(cipher_name: str) -> bool:
    return any(weak in cipher_name.upper() for weak in WEAK_CIPHERS)


def inspect_ssl(host: str, port: int = 443) -> dict:
    result: dict = {
        "host": host,
        "port": port,
        "reachable": False,
        "error": None,
        "subject": {},
        "issuer": {},
        "not_before": None,
        "not_after": None,
        "days_remaining": None,
        "expired": False,
        "protocol": None,
        "cipher": None,
        "weak_cipher": False,
        "san": [],
    }
    try:
        ctx = ssl.create_default_context()
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE
        with socket.create_connection((host, port), timeout=10) as sock:
            with ctx.wrap_socket(sock, server_hostname=host) as ssock:
                result["reachable"] = True
                result["protocol"] = ssock.version()
                cipher_info = ssock.cipher()
                if cipher_info:
                    result["cipher"] = cipher_info[0]
                    result["weak_cipher"] = _is_weak(cipher_info[0])
                cert = ssock.getpeercert(binary_form=False) or {}
                result["subject"] = dict(x[0] for x in cert.get("subject", []))
                result["issuer"] = dict(x[0] for x in cert.get("issuer", []))
                not_after_str = cert.get("notAfter", "")
                not_before_str = cert.get("notBefore", "")
                if not_after_str:
                    not_after = datetime.strptime(not_after_str, "%b %d %H:%M:%S %Y %Z").replace(tzinfo=timezone.utc)
                    result["not_after"] = not_after.isoformat()
                    result["days_remaining"] = (not_after - datetime.now(timezone.utc)).days
                    result["expired"] = result["days_remaining"] < 0
                if not_before_str:
                    result["not_before"] = datetime.strptime(
                        not_before_str, "%b %d %H:%M:%S %Y %Z"
                    ).replace(tzinfo=timezone.utc).isoformat()
                result["san"] = [v for _, v in cert.get("subjectAltName", [])]
    except (ssl.SSLError, socket.timeout, OSError) as exc:
        result["error"] = str(exc)
    return result
PY

