// ── Timeline  (feature #7) ───────────────────────────────────────
function TimelinePanel({ scanId }) {
const [events, setEvents] = useState([]);
const [open, setOpen]     = useState(false);

useEffect(() => {
if (!open) return;
fetch(`${API}/api/scan/${scanId}/timeline`, { headers: authH() })
.then(r => r.ok ? r.json() : [])
.then(setEvents);
}, [scanId, open]);

const COLOR = { SCAN_STARTED:’#0af’, PORT_FOUND:’#30d158’, OS_DETECTED:’#a78bfa’,
SCAN_COMPLETE:’#30d158’, SCAN_ERROR:’#ff2d55’, NOTE_ADDED:’#f5c400’,
FLAG_SAVED:’#ff6b00’, CRED_FOUND:’#ff2d55’, SCHEDULED:’#555’ };

return (
<div style={{ marginTop:12, borderTop:‘1px solid #1a1a1a’, paddingTop:10 }}>
<div onClick={()=>setOpen(o=>!o)}
style={{ fontSize:11, color:’#555’, marginBottom: open?8:0, letterSpacing:1,
cursor:‘pointer’, userSelect:‘none’ }}>
{open?‘▲’:‘▶’} TIMELINE
</div>
{open && events.map((e,i) => (
<div key={i} style={{ display:‘flex’, gap:10, fontSize:10, marginBottom:4,
borderLeft:`2px solid ${COLOR[e.event]||'#333'}`,
paddingLeft:8 }}>
<span style={{ color:’#333’, minWidth:120 }}>{e.created_at?.slice(11,19)}</span>
<span style={{ color: COLOR[e.event]||’#666’, minWidth:120 }}>{e.event}</span>
<span style={{ color:’#555’ }}>{e.detail}</span>
{e.actor && e.actor!==‘system’ && (
<span style={{ color:’#2a2a2a’ }}>@{e.actor}</span>
)}
</div>
))}
</div>
);
}

// ── Notes ────────────────────────────────────────────────────────
function NotesPanel({ scanId }) {
const [notes, setNotes] = useState([]);
const [draft, setDraft] = useState(’’);

const load = () => fetch(`${API}/api/scan/${scanId}/notes`, { headers: authH() })
.then(r => r.ok ? r.json() : []).then(setNotes);
useEffect(() => { load(); }, [scanId]);

const add = async () => {
if (!draft.trim()) return;
await fetch(`${API}/api/scan/${scanId}/notes`, {
method:‘POST’, headers: authH(), body: JSON.stringify({ content: draft })
});
setDraft(’’); load();
};
const del = async (id) => {
await fetch(`${API}/api/notes/${id}`, { method:‘DELETE’, headers: authH() });
load();
};

return (
<div style={{ marginTop:12, borderTop:‘1px solid #1a1a1a’, paddingTop:10 }}>
<div style={{ fontSize:11, color:’#555’, marginBottom:6, letterSpacing:1 }}>NOTES</div>
{notes.map(n => (
<div key={n.id} style={{ display:‘flex’, gap:8, marginBottom:4 }}>
<span style={{ flex:1, color:’#888’, fontSize:11, whiteSpace:‘pre-wrap’ }}>
{n.author && <span style={{ color:’#333’ }}>@{n.author} </span>}
{n.content}
</span>
<button onClick={()=>del(n.id)}
style={{ background:‘none’, border:‘none’, color:’#2a2a2a’,
cursor:‘pointer’, fontSize:11 }}>✕</button>
</div>
))}
<div style={{ display:‘flex’, gap:6, marginTop:6 }}>
<textarea value={draft} onChange={e=>setDraft(e.target.value)} rows={2}
placeholder=“Notes… (Ctrl+Enter to save)”
onKeyDown={e=>{ if(e.key===‘Enter’&&e.ctrlKey) add(); }}
style={{ flex:1, background:’#080808’, border:‘1px solid #1a1a1a’, color:’#ccc’,
padding:‘6px 8px’, borderRadius:3, fontFamily:‘monospace’, fontSize:11,
resize:‘vertical’ }} />
<button onClick={add}
style={{ background:’#1a1a1a’, border:‘1px solid #2a2a2a’, color:’#0af’,
padding:‘0 10px’, borderRadius:3, cursor:‘pointer’, fontSize:11 }}>ADD</button>
</div>
</div>
);
}

