def _get_scan_context(scan_id: str):
db = get_db()
try:
scan  = db.execute(“SELECT * FROM scans WHERE id=?”, (scan_id,)).fetchone()
if not scan:
raise HTTPException(status_code=404)
notes = db.execute(“SELECT content,author FROM notes WHERE scan_id=?”,
(scan_id,)).fetchall()
return dict(scan), [dict(n) for n in notes]
finally:
db.close()

@app.get(”/api/scan/{scan_id}/export/markdown”)
def export_md(scan_id: str, _=Depends(verify_token)):
scan, notes = *get_scan_context(scan_id)
md = scan_to_markdown(scan, notes=notes)
return Response(content=md, media_type=“text/markdown”,
headers={“Content-Disposition”: f’attachment; filename=“scan*{scan_id}.md”’})

@app.get(”/api/scan/{scan_id}/export/pdf”)
def export_pdf(scan_id: str, _=Depends(verify_token)):
import tempfile
scan, notes = *get_scan_context(scan_id)
with tempfile.NamedTemporaryFile(suffix=”.pdf”, delete=False) as f:
path = f.name
scan_to_pdf(scan, path, notes=notes)
with open(path,“rb”) as f: content = f.read()
os.unlink(path)
return Response(content=content, media_type=“application/pdf”,
headers={“Content-Disposition”: f’attachment; filename=“scan*{scan_id}.pdf”’})

# ── Diff ─────────────────────────────────────────────────────────

@app.get(”/api/scan/{scan_id}/diff/{other_id}”)
def diff_scans(scan_id: str, other_id: str, *=Depends(verify_token)):
db = get_db()
try:
a = db.execute(“SELECT data FROM scans WHERE id=?”, (scan_id,)).fetchone()
b = db.execute(“SELECT data FROM scans WHERE id=?”, (other_id,)).fetchone()
if not a or not b:
raise HTTPException(status_code=404)
da = json.loads(a[“data”] or “{}”); db* = json.loads(b[“data”] or “{}”)
finally:
db.close()
pa = set(da); pb = set(db_)
changed = {}
for p in pa & pb:
if da[p].get(“version”) != db_[p].get(“version”):
changed[p] = {“old_version”: da[p].get(“version”), “new_version”: db_[p].get(“version”)}
new_cves = {c[“id”] for c in db_[p].get(“cves”,[])} - {c[“id”] for c in da[p].get(“cves”,[])}
if new_cves:
changed.setdefault(p, {})[“new_cves”] = list(new_cves)
return {“new_ports”: list(pb-pa), “closed_ports”: list(pa-pb), “changed”: changed}

