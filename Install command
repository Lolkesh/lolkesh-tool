            timeline = db.execute(
                "SELECT event, detail, actor, created_at FROM timeline WHERE scan_id=? ORDER BY created_at",
                (scan_id,),
            ).fetchall()

        data = json.loads(row["data"] or "{}")
        services = data.get("services", {})
        cves = data.get("cves", {})

        lines = [
            "# Omni-Sentinel Scan Report",
            "",
            f"**Scan ID:** {row['id']}",
            f"**Target:** {row['target']}",
            f"**Status:** {row['status']}",
            f"**OS Hint:** {row['os_hint'] or 'Unknown'}",
            f"**Created:** {row['created_at']}",
            f"**Tags:** {row['tags'] or '[]'}",
            "",
            f"## Open Services ({len(services)} found)",
            "",
        ]

        for port, info in services.items():
            lines.append(
                f"### Port {port}/{info.get('proto', 'tcp')} — "
