import json
import logging
from contextlib import closing
from typing import Optional

from core.db_engine import get_db

logger = logging.getLogger(__name__)


def _get_scan_services(scan_id: str) -> dict:
    with closing(get_db()) as db:
        row = db.execute("SELECT data FROM scans WHERE id=?", (scan_id,)).fetchone()
        if not row or not row["data"]:
            return {}
        return json.loads(row["data"]).get("services", {})


def _get_previous_scan_id(target: str, exclude_id: str) -> Optional[str]:
    with closing(get_db()) as db:
        row = db.execute(
            "SELECT id FROM scans WHERE target=? AND id!=? AND status='COMPLETE' ORDER BY created_at DESC LIMIT 1",
            (target, exclude_id),
        ).fetchone()
        return row["id"] if row else None


def diff_scans(scan_id: str, baseline_id: Optional[str] = None) -> dict:
    try:
        with closing(get_db()) as db:
            current = db.execute(
                "SELECT target, created_at FROM scans WHERE id=?", (scan_id,)
            ).fetchone()
            if not current:
                return {"error": "Scan not found"}
            if not baseline_id:
                baseline_id = _get_previous_scan_id(current["target"], scan_id)
            if not baseline_id:
                return {"error": "No previous completed scan found for this target", "scan_id": scan_id}

        current_services = _get_scan_services(scan_id)
        baseline_services = _get_scan_services(baseline_id)

        current_ports = set(current_services.keys())
        baseline_ports = set(baseline_services.keys())
        new_ports = current_ports - baseline_ports
        closed_ports = baseline_ports - current_ports
        common_ports = current_ports & baseline_ports

        changed = {}
        for port in common_ports:
            c = current_services[port]
            b = baseline_services[port]
            port_changes = {
                field: {"before": b.get(field), "after": c.get(field)}
                for field in ("service", "version", "product")
                if c.get(field) != b.get(field)
            }
            if port_changes:
                changed[port] = port_changes

        return {
            "scan_id": scan_id,
            "baseline_id": baseline_id,
            "new_ports": {p: current_services[p] for p in new_ports},
            "closed_ports": {p: baseline_services[p] for p in closed_ports},
            "changed_services": changed,
            "summary": {
                "new": len(new_ports),
                "closed": len(closed_ports),
                "changed": len(changed),
                "unchanged": len(common_ports) - len(changed),
            },
        }
    except Exception as exc:
        logger.error(f"Diff failed for {scan_id}: {exc}")
        return {"error": str(exc)}
