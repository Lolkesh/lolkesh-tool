import json
import re
import shutil
import subprocess
from typing import Optional

MSF_MODULES = {
    "CVE-2021-41773": "exploit/multi/http/apache_normalize_path_rce",
    "CVE-2017-0144": "exploit/windows/smb/ms17_010_eternalblue",
    "CVE-2021-44228": "exploit/multi/misc/log4shell_header_injection",
}

CWE_TECHNIQUES = {
    "CWE-78": {
        "technique": "OS Command Injection",
        "steps": [
            "Identify user-controlled input that reaches a shell command.",
            "Test separators such as ;, &&, and | with a harmless command first.",
            "Use a vetted PoC or Metasploit module only after confirming impact.",
        ],
    },
    "CWE-89": {
        "technique": "SQL Injection",
        "steps": [
            "Confirm injection with a safe boolean-based payload.",
            "Enumerate carefully with sqlmap or manual UNION/error-based techniques.",
            "Review database permissions before attempting file or command execution.",
        ],
    },
}

SEVERITY_STEPS = {
    "CRITICAL": [
        "Review vendor guidance and public PoCs before exploitation.",
        "Set up a listener or capture tooling before running any exploit.",
    ],
    "HIGH": [
        "Confirm the affected version and reachable attack surface.",
        "Search for a public PoC or searchsploit entry for {query}.",
    ],
    "MEDIUM": [
        "Verify the target is actually running the affected component.",
        "Search for supporting advisories or proof-of-concept material.",
    ],
    "LOW": [
        "Treat the issue as a chaining opportunity or hardening task.",
    ],
}


def _sanitize_query(query: str) -> str:
    """Prevent shell injection in queries."""
    return re.sub(r'[;&|`$()\\<>"\']', '', query)[:100]


def get_exploitation_steps(cve_id: str, cwe: str, severity: str, service: str, version: str) -> dict:
    query = _sanitize_query(f"{service} {version}".strip())
    msf_module = MSF_MODULES.get(cve_id, "")
    cwe_info = CWE_TECHNIQUES.get(cwe, {})
    technique = cwe_info.get("technique", "")
    steps = list(cwe_info.get("steps", []))
    if not steps:
        template_steps = SEVERITY_STEPS.get(severity, SEVERITY_STEPS["MEDIUM"])
        steps = [step.format(query=query, cve_id=cve_id) for step in template_steps]
    if msf_module:
        steps.insert(0, f"Metasploit module: {msf_module}")
    return {
        "msf_module": msf_module,
        "technique": technique,
        "steps": steps,
        "searchsploit_cmd": f"searchsploit {query}" if query else f"searchsploit {cve_id}",
        "poc_search": f"https://github.com/search?q={cve_id}+poc&type=repositories",
        "nvd_url": f"https://nvd.nist.gov/vuln/detail/{cve_id}",
    }


def searchsploit(query: str) -> list:
    if not shutil.which("searchsploit"):
        return []
    query = _sanitize_query(query)
    if not query:
        return []
    try:
        result = subprocess.run(
            ["searchsploit", "--json", query],
            capture_output=True,
            text=True,
            timeout=15,
            check=False,
        )
        data = json.loads(result.stdout or "{}")
    except (subprocess.SubprocessError, json.JSONDecodeError):
        return []

    exploits = data.get("RESULTS_EXPLOIT", [])[:5]
    return [
        {
            "title": exploit.get("Title", ""),
            "path": exploit.get("Path", ""),
            "type": exploit.get("Type", ""),
            "edb_id": exploit.get("EDB-ID", ""),
        }
        for exploit in exploits
    ]


def get_exploits(service: str, version: str, cves: list) -> dict:
    query = _sanitize_query(f"{service} {version}".strip())
    exploits = searchsploit(query) if query else []
    for cve in cves[:3]:
        exploits.extend(searchsploit(cve.get("id", "")))

    seen = set()
    unique = []
    for exploit in exploits:
        key = exploit.get("edb_id") or exploit.get("title")
        if key and key not in seen:
            seen.add(key)
            unique.append(exploit)

    exploitation = {
        cve["id"]: get_exploitation_steps(
            cve_id=cve["id"],
            cwe=cve.get("cwe", ""),
            severity=cve.get("severity", "MEDIUM"),
            service=service,
            version=version,
        )
        for cve in cves
    }
    return {"exploits": unique[:8], "exploitation": exploitation}
