import hashlib
import os
import shutil
import subprocess
from typing import Optional

SCREENSHOT_DIR = os.path.expanduser("~/omni-sentinel-v21.3/screenshots")


def take_screenshot(scan_id: str, port: str, url: str) -> Optional[str]:
    binary = shutil.which("chromium-browser") or shutil.which("chromium")
    if not binary:
        return None
    os.makedirs(SCREENSHOT_DIR, exist_ok=True)
    digest = hashlib.md5(url.encode()).hexdigest()[:8]
    filename = f"{scan_id}_{port}_{digest}.png"
    outpath = os.path.join(SCREENSHOT_DIR, filename)
    try:
        subprocess.run(
            [
                binary,
                "--headless",
                "--no-sandbox",
                "--disable-gpu",
                "--disable-dev-shm-usage",
                f"--screenshot={outpath}",
                "--window-size=1280,800",
                "--virtual-time-budget=5000",
                url,
            ],
            capture_output=True,
            timeout=20,
            check=False,
        )
    except (subprocess.SubprocessError, OSError):
        return None
    return filename if os.path.exists(outpath) else None


def screenshot_http_ports(scan_id: str, services: dict) -> list:
    results = []
    for port, info in services.items():
        service = info.get("service", "").lower()
        if "http" not in service and port not in {"80", "443", "8080", "8443", "8000", "8888"}:
            continue
        scheme = "https" if "ssl" in service or "https" in service or port in {"443", "8443"} else "http"
        target = info.get("_target", "target")
        url = f"{scheme}://{target}:{port}"
        path = take_screenshot(scan_id, port, url)
        if path:
            results.append({"port": port, "url": url, "path": path})
    return results
