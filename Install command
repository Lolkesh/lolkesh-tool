import json
import logging
import sqlite3
from contextlib import closing
from typing import Optional

from core.db_engine import get_db

logger = logging.getLogger(__name__)

CRED_SCHEMA = """
CREATE TABLE IF NOT EXISTS credentials (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    scan_id TEXT,
    host TEXT,
    service TEXT,
    port TEXT,
    username TEXT,
    password TEXT,
    hash TEXT,
