# ── Shodan Dork Generator ─────────────────────────────────────────────────────

def shodan_dorks(domain: str, org: str = "") -> dict:
    dorks = [
        f'hostname:"{domain}"',
        f'ssl.cert.subject.cn:"{domain}"',
        f'ssl.cert.subject.cn:"*.{domain}"',
    ]
    if org:
        dorks += [
            f'org:"{org}"',
            f'org:"{org}" port:22',
            f'org:"{org}" port:3389',
            f'org:"{org}" port:8080 OR port:8443',
            f'org:"{org}" http.favicon.hash:*',
            f'org:"{org}" "default password"',
        ]
    return {"domain": domain, "org": org, "dorks": dorks}


