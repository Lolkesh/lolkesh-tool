f”**Status:** {scan.get(‘status’,’?’)}  “,
“”, “—”, “”
]
if notes:
lines += [”## Notes”, “”]
for n in notes:
lines.append(f”- {n[‘content’]}”)
lines.append(””)
if not data:
lines.append(”*No scan data.*”)
return “\n”.join(lines)
for port, info in data.items():
