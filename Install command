import logging
from typing import Optional

logger = logging.getLogger(__name__)

try:
    import dns.query
    import dns.resolver
    import dns.zone
    DNS_AVAILABLE = True
except ImportError:
    DNS_AVAILABLE = False

COMMON_SUBDOMAINS = [
    "www", "mail", "ftp", "smtp", "pop", "ns1", "ns2", "mx",
    "admin", "portal", "api", "dev", "staging", "test", "vpn",
    "remote", "ssh", "blog", "cdn", "static", "assets",
]


def zone_transfer(domain: str) -> list:
    if not DNS_AVAILABLE:
        return []
    results = []
    try:
        ns_records = dns.resolver.resolve(domain, "NS")
        for ns in ns_records:
            ns_host = str(ns.target).rstrip(".")
            try:
                import socket
                ns_ip = socket.gethostbyname(ns_host)
                zone = dns.zone.from_xfr(dns.query.xfr(ns_ip, domain, timeout=5))
                for name in zone.nodes.keys():
                    results.append({"type": "AXFR", "value": f"{name}.{domain}"})
            except Exception:
                continue
    except Exception as exc:
        logger.debug(f"Zone transfer failed for {domain}: {exc}")
    return results


def brute_subdomains(domain: str, wordlist: Optional[list] = None) -> list:
    if not DNS_AVAILABLE:
        return []
    targets = wordlist or COMMON_SUBDOMAINS
    results = []
    resolver = dns.resolver.Resolver()
    resolver.lifetime = 2.0
    for sub in targets:
        fqdn = f"{sub}.{domain}"
        try:
            answers = resolver.resolve(fqdn, "A")
            results.append({"type": "A", "subdomain": fqdn, "ips": [str(r) for r in answers]})
        except Exception:
            continue
    return results


def enumerate_dns(domain: str) -> dict:
    zt = zone_transfer(domain)
    brute = brute_subdomains(domain)
    return {
        "domain": domain,
        "zone_transfer": zt,
        "subdomains": brute,
        "total": len(zt) + len(brute),
    }
