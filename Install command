cat > "$BASE/plugins/scanner.py" <<'PY'
import nmap


def detect_os(nm_result, host: str) -> str:
    try:
        osmatches = nm_result[host].get("osmatch", [])
        if osmatches:
            return osmatches[0].get("name", "")
    except Exception:
        return ""
    return ""


def scan_target(target: str, aggressive: bool = False, concurrent: int = 1) -> tuple[dict, str]:
    nm = nmap.PortScanner()
    timing = "-T3" if concurrent > 1 else "-T4"
    args = f"-A --open {timing}" if aggressive else f"-sV -sC -O --open {timing}"
    nm.scan(target, arguments=args)
    services = {}
    os_hint = ""
    for host in nm.all_hosts():
        os_hint = detect_os(nm, host)
        for proto in nm[host].all_protocols():
            for port in nm[host][proto]:
                info = nm[host][proto][port]
                if info.get("state") == "open":
                    services[str(port)] = {
                        "_target": target,
                        "service": info.get("name", "unknown"),
                        "version": info.get("version", ""),
                        "product": info.get("product", ""),
                        "proto": proto,
                        "scripts": info.get("script", {}),
                    }
    return services, os_hint
PY

cat > "$BASE/plugins/gobuster_runner.py" <<'PY'
import os
import shutil
import subprocess
import threading

import requests

WORDLISTS = {
    "common": [
        "/usr/share/seclists/Discovery/Web-Content/common.txt",
        "/usr/share/seclists/Discovery/Web-Content/directory-list-2.3-small.txt",
        "/usr/share/wordlists/dirb/common.txt",
    ],
    "iis": [
        "/usr/share/seclists/Discovery/Web-Content/IIS.fuzz.txt",
        "/usr/share/seclists/Discovery/Web-Content/common.txt",
    ],
}
FALLBACK_WORDLIST = "/usr/share/wordlists/dirb/common.txt"
SUBDOMAIN_WORDLISTS = [
    "/usr/share/seclists/Discovery/DNS/subdomains-top1million-5000.txt",
    "/usr/share/seclists/Discovery/DNS/bitquark-subdomains-top100000.txt",
    FALLBACK_WORDLIST,
]


def get_wordlist(candidates: list) -> str:
    for path in candidates:
        if os.path.exists(path):
            return path
    return FALLBACK_WORDLIST


def detect_cms(url: str) -> str | None:
    cms_paths = {
        "WordPress": ["/wp-login.php", "/wp-admin/", "/wp-content/"],
        "Joomla": ["/administrator/", "/components/", "/modules/"],
        "Drupal": ["/user/login", "/sites/default/", "/core/"],
    }
    for cms, paths in cms_paths.items():
        hits = 0
        for path in paths:
            try:
                response = requests.get(
                    url + path,
                    timeout=4,
                    allow_redirects=True,
                    verify=False,
                    headers={"User-Agent": "Mozilla/5.0"},
                )
                if response.status_code in (200, 301, 302, 403):
                    hits += 1
            except requests.RequestException:
                continue
        if hits >= 2:
            return cms
    return None


def suggest_wordlist(os_hint: str, cms: str | None = None) -> str:
    cms_lists = {
        "WordPress": "/usr/share/seclists/Discovery/CMS/wordpress.fuzz.txt",
        "Joomla": "/usr/share/seclists/Discovery/CMS/joomla.txt",
        "Drupal": "/usr/share/seclists/Discovery/CMS/drupal.txt",
    }
    if cms and os.path.exists(cms_lists.get(cms, "")):
        return cms_lists[cms]
    hint = (os_hint or "").lower()
    if any(token in hint for token in ("windows", "iis", "microsoft")):
        return get_wordlist(WORDLISTS["iis"])
    return get_wordlist(WORDLISTS["common"])


def run_gobuster(scan_id: str, target: str, port: str, scheme: str, wordlist: str, db_update_fn) -> None:
    tool = shutil.which("gobuster") or shutil.which("feroxbuster")
    if not tool:
        return
    url = f"{scheme}://{target}:{port}"
    if "feroxbuster" in tool:
        cmd = [tool, "--url", url, "--wordlist", wordlist, "--threads", "20", "--quiet", "--no-state"]
    else:
        cmd = [tool, "dir", "-u", url, "-w", wordlist, "-t", "20", "--no-error", "-q", "-o", "-"]
    try:
        proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, text=True)
        results = []
        assert proc.stdout is not None
        for line in proc.stdout:
            line = line.strip()
            if line and not line.startswith("#"):
                results.append(line)
                if len(results) % 10 == 0:
                    db_update_fn(scan_id, port, results[:])
        proc.wait()
        db_update_fn(scan_id, port, results)
    except Exception:
        return


def run_subdomain_enum(scan_id: str, target: str, db_update_fn) -> None:
    gobuster = shutil.which("gobuster")
    if not gobuster:
        return
    wordlist = get_wordlist(SUBDOMAIN_WORDLISTS)
    results = []
    try:
        proc = subprocess.Popen(
            [gobuster, "dns", "-d", target, "-w", wordlist, "-t", "20", "-q", "--no-error"],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        assert proc.stdout is not None
        for line in proc.stdout:
            line = line.strip()
            if line and "Found:" in line:
                results.append({"type": "dns", "value": line.replace("Found:", "").strip()})
        proc.wait()
    except Exception:
        return
    db_update_fn(scan_id, "subdomains", results)


def launch_gobuster_async(scan_id: str, target: str, services: dict, os_hint: str, db_update_fn) -> None:
    for port, info in services.items():
        service = info.get("service", "").lower()
        is_web = "http" in service or port in {"80", "443", "8080", "8443", "8000", "8888"}
        if not is_web:
            continue
        scheme = "https" if "ssl" in service or port in {"443", "8443"} else "http"
        cms = detect_cms(f"{scheme}://{target}:{port}")
        wordlist = suggest_wordlist(os_hint, cms=cms)
        thread = threading.Thread(
            target=run_gobuster,
            args=(scan_id, target, port, scheme, wordlist, db_update_fn),
            daemon=True,
        )
        thread.start()


def launch_subdomain_enum_async(scan_id: str, target: str, db_update_fn) -> None:
