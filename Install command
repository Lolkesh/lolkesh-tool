import logging
import socket
import ssl
from typing import Optional

logger = logging.getLogger(__name__)

BANNER_PROBES = {
    "generic": b"\r\n",
    "http": b"HEAD / HTTP/1.0\r\nHost: target\r\n\r\n",
    "ftp": b"",        # FTP sends banner on connect
    "smtp": b"",       # SMTP sends banner on connect
    "ssh": b"",        # SSH sends banner on connect
    "pop3": b"",
    "imap": b"",
    "rdp": b"",
}

SSL_PORTS = {443, 8443, 993, 995, 465, 636, 8444}

SERVICE_HINTS = {
    21: "ftp", 22: "ssh", 23: "telnet", 25: "smtp",
    53: "dns", 80: "http", 110: "pop3", 143: "imap",
    389: "ldap", 443: "https", 445: "smb", 636: "ldaps",
    993: "imaps", 995: "pop3s", 1433: "mssql", 3306: "mysql",
    3389: "rdp", 5432: "postgresql", 5900: "vnc",
    6379: "redis", 8080: "http-alt", 8443: "https-alt",
    27017: "mongodb",
}


def _grab_raw(host: str, port: int, timeout: int = 5, use_ssl: bool = False) -> Optional[str]:
    try:
        sock = socket.create_connection((host, port), timeout=timeout)
        if use_ssl or port in SSL_PORTS:
            ctx = ssl.create_default_context()
            ctx.check_hostname = False
            ctx.verify_mode = ssl.CERT_NONE
            sock = ctx.wrap_socket(sock, server_hostname=host)

        # Try to receive immediate banner
        sock.settimeout(timeout)
        try:
            data = sock.recv(1024)
            if data:
                sock.close()
                return data.decode("utf-8", errors="replace").strip()
        except socket.timeout:
            pass

        # Send HTTP probe if nothing received
        probe = SERVICE_HINTS.get(port, "generic")
        if probe in ("http", "https") or port in (80, 8080, 443, 8443):
            sock.sendall(b"HEAD / HTTP/1.0\r\n\r\n")
        else:
            sock.sendall(b"\r\n")

        try:
            data = sock.recv(2048)
            sock.close()
            return data.decode("utf-8", errors="replace").strip()
        except socket.timeout:
            sock.close()
            return None
    except Exception as exc:
        logger.debug(f"Banner grab failed {host}:{port}: {exc}")
        return None


def grab_banner(host: str, port: int, timeout: int = 5) -> dict:
    use_ssl = port in SSL_PORTS
    banner = _grab_raw(host, port, timeout=timeout, use_ssl=use_ssl)

    # Try SSL if plain fails and port is typically SSL
    if not banner and not use_ssl and port in (443, 8443, 993, 995):
        banner = _grab_raw(host, port, timeout=timeout, use_ssl=True)

    service_hint = SERVICE_HINTS.get(port, "unknown")

    return {
        "host": host,
        "port": port,
        "service_hint": service_hint,
        "banner": banner[:500] if banner else None,
        "banner_length": len(banner) if banner else 0,
        "ssl": use_ssl,
    }


def grab_all_banners(host: str, ports: list) -> dict:
    results = {}
    for port in ports:
        results[str(port)] = grab_banner(host, int(port))
    return results


def enrich_services_with_banners(host: str, services: dict) -> dict:
    """Add banner info to existing nmap service dict."""
    for port, info in services.items():
        banner_result = grab_banner(host, int(port))
        info["banner"] = banner_result.get("banner")
        info["banner_ssl"] = banner_result.get("ssl")
    return services
